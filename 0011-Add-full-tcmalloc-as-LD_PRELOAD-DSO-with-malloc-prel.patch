+  namespace {                                                                                    \
+  static void google_init_module_##name() { body; }                                              \
+  GoogleInitializer google_initializer_module_##name(#name, google_init_module_##name, nullptr); \
+  }
+
+#define REGISTER_MODULE_DESTRUCTOR(name, body)                                                      \
