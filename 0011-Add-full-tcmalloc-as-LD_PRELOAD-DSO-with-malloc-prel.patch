index 0000000000..71b0b5f404
--- /dev/null
+++ b/malloc/tcmalloc/src/common.h
@@ -0,0 +1,293 @@
+// -*- Mode: C++; c-basic-offset: 2; indent-tabs-mode: nil -*-
+// Copyright (c) 2008, Google Inc.
+// All rights reserved.
+//
