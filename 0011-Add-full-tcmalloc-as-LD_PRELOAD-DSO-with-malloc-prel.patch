+++ b/malloc/tcmalloc/src/base/spinlock.cc
@@ -0,0 +1,163 @@
+// -*- Mode: C++; c-basic-offset: 2; indent-tabs-mode: nil -*-
+/* Copyright (c) 2006, Google Inc.
