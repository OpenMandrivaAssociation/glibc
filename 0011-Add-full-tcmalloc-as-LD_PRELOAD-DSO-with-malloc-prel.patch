+extern "C" PERFTOOLS_DLL_DECL void* tc_new_nothrow(size_t size, const std::nothrow_t&) PERFTOOLS_NOTHROW {
+  void* ptr = debug_cpp_alloc(size, MallocBlock::kNewType, true);
+  tcmalloc::InvokeNewHook(ptr, size);
+  return ptr;
+}
