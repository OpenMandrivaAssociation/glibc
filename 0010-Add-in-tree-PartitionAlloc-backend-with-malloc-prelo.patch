+constexpr auto span_from_ref(T& t PA_LIFETIME_BOUND) {
+  // SAFETY: It's safe to read the memory at `t`'s address as long as the
+  // provided reference is valid.
+  return PA_UNSAFE_BUFFERS(span<T, 1>(std::addressof(t), 1u));
