+#if !PA_CONFIG(HAS_LINUX_KERNEL) && !PA_BUILDFLAG(IS_WIN) && \
+    !PA_BUILDFLAG(IS_APPLE) && !PA_BUILDFLAG(IS_POSIX) &&    \
+    !PA_BUILDFLAG(IS_FUCHSIA)
+#include "partition_alloc/partition_alloc_base/threading/platform_thread.h"
