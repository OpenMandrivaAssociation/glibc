+PA_ALWAYS_INLINE size_t
+PartitionRoot::GetSlotUsableSize(const SlotSpanMetadata* slot_span) {
+  return AdjustSizeForExtrasSubtract(slot_span->GetUtilizedSlotSize());
+}
