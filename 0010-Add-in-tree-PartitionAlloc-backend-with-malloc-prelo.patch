+  PA_EXPECT_CHECK_DEATH(empty_dynamic_span.copy_from(static_span));
+  PA_EXPECT_CHECK_DEATH(empty_dynamic_span.copy_from(dynamic_span));
+  PA_EXPECT_CHECK_DEATH(dynamic_span.last(2u).copy_from(static_span));
