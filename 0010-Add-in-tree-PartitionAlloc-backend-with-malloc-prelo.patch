+PA_ALWAYS_INLINE internal::InSlotMetadata*
+PartitionRoot::InSlotMetadataPointerFromSlotStartAndSize(
+    internal::UntaggedSlotStart slot_start,
+    size_t slot_size) {
+  return internal::InSlotMetadataPointer(slot_start.value(), slot_size);
+}
