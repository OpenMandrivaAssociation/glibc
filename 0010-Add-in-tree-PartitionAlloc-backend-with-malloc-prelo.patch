+// Ensure that the `kUseCountingImplForTest` flag selects the test impl.
+static_assert(std::is_same_v<CountingRawPtr<int>::Impl, RawPtrCountingImpl>);
+
+template <typename T>
+using CountingRawPtrMayDangle =
+    raw_ptr<T,
