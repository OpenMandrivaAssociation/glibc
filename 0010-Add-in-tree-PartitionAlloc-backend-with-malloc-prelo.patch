+void PartitionRoot::DecommitEmptySlotSpans() {
+  ShrinkEmptySlotSpansRing(0);
+  // Just decommitted everything, and holding the lock, should be exactly 0.
+  PA_DCHECK(empty_slot_spans_dirty_bytes_ == 0);
+}
