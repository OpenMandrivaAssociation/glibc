+  PA_LOG(INFO) << mock_log_source.Log();
+  PA_LOG_IF(INFO, false) << mock_log_source.Log();
+  PA_PLOG(INFO) << mock_log_source.Log();
+  PA_PLOG_IF(INFO, false) << mock_log_source.Log();
