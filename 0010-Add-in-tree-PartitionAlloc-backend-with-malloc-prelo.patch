+// We want this size to be big enough that we have time to start up other
+// scripts _before_ we wrap around.
+static constexpr size_t kAllocInfoSize = 1 << 24;
+
+struct AllocInfo {
+  std::atomic<size_t> index{0};
+  struct {
+    uintptr_t addr;
+    size_t size;
+  } allocs[kAllocInfoSize] = {};
+};
