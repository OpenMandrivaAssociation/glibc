+  root()->Free(data);
+  EXPECT_EQ(1u, cache_fill_counter.Delta());
+  EXPECT_EQ(1u, cache_fill_hits_counter.Delta());
+  EXPECT_EQ(0u, cache_fill_misses_counter.Delta());
