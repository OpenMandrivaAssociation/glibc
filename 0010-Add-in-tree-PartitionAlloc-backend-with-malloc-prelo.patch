diff --git a/malloc/malloc-partitionalloc-preload.cc b/malloc/malloc-partitionalloc-preload.cc
new file mode 100644
index 0000000000..121be37902
--- /dev/null
+++ b/malloc/malloc-partitionalloc-preload.cc
@@ -0,0 +1,58 @@
+/* LD_PRELOAD override exporting malloc via PartitionAlloc.
+   Copyright (C) 2026 Free Software Foundation, Inc.
+   Linked as libglibc_malloc_partitionalloc.so against libc + libstdc++
+   (one-way: DSO depends on libc, never the reverse).  */
+
+#include <errno.h>
+#include <stddef.h>
+#include <unistd.h>
+
+extern "C" {
+void *pa_malloc (size_t);
+void pa_free (void *);
+void *pa_realloc (void *, size_t);
+void *pa_calloc (size_t, size_t);
+void *pa_memalign (size_t, size_t);
+size_t pa_usable_size (void *);
+void pa_trim (void);
+}
+
+extern "C" {
+
+void *malloc (size_t n) { return pa_malloc (n); }
+void free (void *p) { pa_free (p); }
+void *calloc (size_t n, size_t s) { return pa_calloc (n, s); }
+void *realloc (void *p, size_t n) {
+  if (n == 0) { if (p) pa_free (p); return nullptr; }
+  if (!p) return pa_malloc (n);
+  return pa_realloc (p, n);
+}
+void *memalign (size_t a, size_t n) { return pa_memalign (a, n); }
+void *aligned_alloc (size_t a, size_t n) {
+  if (a == 0 || (a & (a - 1)) != 0) { errno = EINVAL; return nullptr; }
+  return pa_memalign (a, n);
+}
+int posix_memalign (void **m, size_t a, size_t n) {
+  if (!m || !a || (a & (a - 1)) || a % sizeof (void *)) return EINVAL;
+  void *p = pa_memalign (a, n);
+  if (!p) return ENOMEM;
+  *m = p; return 0;
+}
+void *valloc (size_t n) { return pa_memalign ((size_t) sysconf (_SC_PAGESIZE), n); }
+void *pvalloc (size_t n) {
+  size_t ps = (size_t) sysconf (_SC_PAGESIZE);
+  return pa_memalign (ps, (n + ps - 1) & ~(ps - 1));
+}
+size_t malloc_usable_size (void *p) { return pa_usable_size (p); }
+int malloc_trim (size_t) { pa_trim (); return 1; }
+void *__libc_malloc (size_t n) { return malloc (n); }
+void __libc_free (void *p) { free (p); }
+void *__libc_realloc (void *p, size_t n) { return realloc (p, n); }
+void *__libc_calloc (size_t n, size_t s) { return calloc (n, s); }
+void *__libc_memalign (size_t a, size_t n) { return memalign (a, n); }
+void *__libc_valloc (size_t n) { return valloc (n); }
+void *__libc_pvalloc (size_t n) { return pvalloc (n); }
+
+}
+
+#include "malloc-partitionalloc-api.cc"
