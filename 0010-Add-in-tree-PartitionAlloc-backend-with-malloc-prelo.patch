+  EXPECT_EQ(std::numeric_limits<ssize_t>::max() - 1,
+            SafeSNPrintf(buf, 4, fmt, "A"));
+  EXPECT_EQ("   ", std::string(buf));
+  SafeSPrintf(fmt, "%%%ds",
+              static_cast<size_t>(std::numeric_limits<ssize_t>::max()));
+#if !PA_BUILDFLAG(IS_DEBUG)
+  EXPECT_EQ(2, SafeSPrintf(buf, fmt, "A"));
