+  EXPECT_EQ(4u, tcache->thread_alloc_stats().alloc_count);
+  EXPECT_EQ(expected_total_size, tcache->thread_alloc_stats().alloc_total_size);
+  EXPECT_EQ(4u, tcache->thread_alloc_stats().dealloc_count);
