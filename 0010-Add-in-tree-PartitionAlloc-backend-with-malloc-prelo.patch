+++ b/malloc/malloc-partitionalloc-api.cc
@@ -0,0 +1,97 @@
+/* C API wrapper around a single PartitionRoot for glibc embed.
+   Copyright (C) 2026 Free Software Foundation, Inc.  */
+
+#include "partition_alloc/partition_alloc.h"
+#include "partition_alloc/partition_root.h"
+#include "partition_alloc/partition_alloc_constants.h"
+#include "partition_alloc/memory_reclaimer.h"
+
+#include <cstddef>
+#include <cstring>
+#include <new>
+#include <pthread.h>
+
+using partition_alloc::PartitionOptions;
+using partition_alloc::PartitionRoot;
+
+namespace {
+
+PartitionRoot *g_root = nullptr;
+pthread_once_t g_once = PTHREAD_ONCE_INIT;
+alignas (64) unsigned char g_root_storage[sizeof (PartitionRoot)];
+
+void init_root ()
+{
+  g_root = new (g_root_storage) PartitionRoot ();
+  PartitionOptions opts;
+  g_root->Init (opts);
+}
+
+inline PartitionRoot *
+root ()
+{
+  pthread_once (&g_once, init_root);
+  return g_root;
+}
+
+} // namespace
+
+extern "C" {
+
+void *
+pa_malloc (size_t size)
+{
+  return root ()->Alloc (size, "glibc");
+}
+
+void
+pa_free (void *ptr)
+{
+  if (ptr != nullptr)
+    root ()->Free (ptr);
+}
+
+void *
+pa_calloc (size_t n, size_t size)
+{
+  size_t total;
+  if (__builtin_mul_overflow (n, size, &total))
+    return nullptr;
+  void *p = root ()->Alloc (total, "glibc");
+  if (p != nullptr)
+    std::memset (p, 0, total);
+  return p;
+}
+
+void *
+pa_realloc (void *ptr, size_t size)
+{
+  if (ptr == nullptr)
+    return pa_malloc (size);
+  if (size == 0)
+    {
+      pa_free (ptr);
+      return nullptr;
+    }
+  return root ()->Realloc (ptr, size, "glibc");
+}
+
+void *
+pa_memalign (size_t alignment, size_t size)
+{
+  return root ()->AlignedAlloc (alignment, size);
+}
+
+size_t
+pa_usable_size (void *ptr)
+{
+  return ptr != nullptr ? PartitionRoot::GetUsableSize (ptr) : 0;
+}
+
+void
+pa_trim (void)
+{
+  partition_alloc::MemoryReclaimer::Instance ()->ReclaimAll ();
+}
+
+}
