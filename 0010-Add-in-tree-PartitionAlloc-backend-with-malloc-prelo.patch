+    ThreadIsolationOption thread_isolation_opt;
+    if (UseThreadIsolatedPool() && pkey_ != kInvalidPkey) {
+      thread_isolation_opt = ThreadIsolationOption(pkey_);
+#if PA_BUILDFLAG(ENABLE_BACKUP_REF_PTR_SUPPORT)
