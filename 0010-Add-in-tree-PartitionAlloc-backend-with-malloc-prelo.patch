+    PA_BUILDFLAG(ENABLE_BACKUP_REF_PTR_SUPPORT)
+    blocklist_size_ = address_space_stats->blocklist_size;
+#endif
+  }
+
+  size_t regular_pool_usage_ = 0;
+  size_t regular_pool_largest_reservation_ = 0;
+  size_t blocklist_size_ = 0;
+};
