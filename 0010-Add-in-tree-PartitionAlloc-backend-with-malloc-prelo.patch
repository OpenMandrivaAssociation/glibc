+    PartitionOptions opts = GetCommonPartitionOptions();
+#if PA_BUILDFLAG(ENABLE_BACKUP_REF_PTR_SUPPORT)
+    opts.backup_ref_ptr = enable_backup_ref_ptr;
+#endif
+#if PA_BUILDFLAG(ENABLE_PKEYS)
