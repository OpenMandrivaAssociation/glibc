+TEST_P(PartitionAllocThreadCacheTest, DynamicCountPerBucket) {
+  auto* tcache = root()->thread_cache_for_testing();
+  size_t bucket_index =
+      FillThreadCacheAndReturnIndex(kMediumSize, kDefaultCountForMediumBucket);
