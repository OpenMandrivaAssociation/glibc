+    static_assert(span.data() == subspan.data());
+    static_assert(3 == subspan.size());
+    static_assert(3 == decltype(subspan)::extent);
+    static_assert(1 == subspan[0]);
+    static_assert(2 == subspan[1]);
+    static_assert(3 == subspan[2]);
