+  new_functions.size = [](malloc_zone_t* zone, const void* ptr) -> size_t {
+    return ShimGetSizeEstimate(ptr, zone);
+  };
+  new_functions.good_size = [](malloc_zone_t* zone, size_t size) -> size_t {
