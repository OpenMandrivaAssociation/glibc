+      "-Wnon-c-typedef-for-linkage",
+      "-Wpessimizing-move",
+      "-Wrange-loop-analysis",
+      "-Wredundant-move",
+      "-Wreturn-type",
+      "-Wshadow-field",
+      "-Wstrict-prototypes",
+      "-Wsuggest-destructor-override",
