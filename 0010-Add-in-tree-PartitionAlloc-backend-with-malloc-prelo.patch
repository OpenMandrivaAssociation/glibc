+  TypedTree<TypeParam> x;
+  EXPECT_EQ(0u, base::EraseIf(x, [](int) { return false; }));
+  EXPECT_THAT(x, ElementsAre());
+
+  x = {1, 2, 3};
+  EXPECT_EQ(1u, base::EraseIf(x, [](int elem) { return !(elem & 1); }));
+  EXPECT_THAT(x, ElementsAre(1, 3));
