+/* Phasecast adaptive malloc implementation.
+   Copyright (C) 2026 Free Software Foundation, Inc.
+   This file is part of the GNU C Library.
+
+   MVP: per-thread size-class caches, central span heap, allocation-site
+   table with direct function pointers, and optional ephemeral bump
+   arenas entered via phase_push/pop.  */
+#include "phasecast.h"
+
+#include <errno.h>
+#include <limits.h>
+#include <stdalign.h>
+#include <stdatomic.h>
+#include <stdbool.h>
+#include <stdint.h>
+#include <stdio.h>
+#include <string.h>
+#include <sys/mman.h>
+#include <unistd.h>
+
+#define PC_MAGIC 0x5043u /* 'PC' */
+#define PC_SPAN_SIZE (256u * 1024u)
+#define PC_MAX_SMALL (32u * 1024u)
+#define PC_MAX_CLASSES 128u
+#define PC_SITE_BITS 16
+#define PC_SITE_N (1u << PC_SITE_BITS)
+#define PC_SITE_MASK (PC_SITE_N - 1u)
+#define PC_WARMUP 32u
+#define PC_EPH_SLAB (1024u * 1024u)
+#define PC_ALIGN 16u
+#define PC_SLOT_ALIGN 128u
+
+#define PC_F_EPH 1u
+#define PC_F_MMAP 2u
+
+typedef struct pc_hdr
+{
+  uint32_t magic;
+  uint16_t class_id;
+  uint16_t flags;
+  size_t size;
+} pc_hdr_t;
+
+#define PC_HDR_SIZE sizeof (pc_hdr_t)
+
+static inline int
+pc_size_too_large (size_t size)
+{
+  return size > (size_t) PTRDIFF_MAX;
+}
+
+static inline size_t
+pc_pagesize (void)
+{
+  long p = sysconf (_SC_PAGESIZE);
+  return p > 0 ? (size_t) p : 4096u;
+}
+
+typedef struct pc_span
+{
+  struct pc_span *next;
+  uint16_t class_id;
+  uint16_t nslots;
+  uint32_t nfree;
+  void *free_list;
+  char *slots;
+} pc_span_t;
+
+typedef struct pc_remote
+{
+  void *head;
+} pc_remote_t;
+
+struct pc_site;
+
+typedef struct pc_tls
+{
+  int inited;
+  void *cache[PC_MAX_CLASSES];
+  pc_remote_t remote;
+  char *eph_base;
+  char *eph_cur;
+  char *eph_end;
+  struct pc_tls *eph_prev_tls_link;
+  int eph_depth;
+  unsigned slow_ticks;
+} pc_tls_t;
+
+typedef void *(*pc_alloc_fn) (struct pc_site *, size_t);
+
+typedef struct pc_site
+{
+  _Atomic uintptr_t alloc;
+  uint32_t class_id;
+  uint32_t hits;
+  uint32_t frees;
+  uint32_t flags;
+} pc_site_t;
+
+static uint16_t pc_class_size[PC_MAX_CLASSES];
+static unsigned pc_nclasses;
+static pc_span_t *pc_span_lists[PC_MAX_CLASSES];
+static atomic_int pc_lock;
+static int pc_global_inited;
+static pc_site_t pc_sites[PC_SITE_N];
+static __thread pc_tls_t pc_tls;
+
+static inline void
+pc_lock_acquire (void)
+{
+  while (atomic_exchange_explicit (&pc_lock, 1, memory_order_acquire))
+    {
+      while (atomic_load_explicit (&pc_lock, memory_order_relaxed))
+	__atomic_thread_fence (memory_order_relaxed);
+    }
+}
+
+static inline void
+pc_lock_release (void)
+{
+  atomic_store_explicit (&pc_lock, 0, memory_order_release);
+}
+
+static inline pc_alloc_fn
+pc_site_load_alloc (pc_site_t *site)
+{
+  return (pc_alloc_fn) (uintptr_t) atomic_load_explicit (&site->alloc,
+							 memory_order_acquire);
+}
+
+static inline void
+pc_site_store_alloc (pc_site_t *site, pc_alloc_fn fn)
+{
+  atomic_store_explicit (&site->alloc, (uintptr_t) fn, memory_order_release);
+}
+
+static inline size_t pc_align_up (size_t x, size_t a)
+{
+  return (x + a - 1) & ~(a - 1);
+}
+
+static inline pc_hdr_t *pc_hdr_of (void *p)
+{
+  return (pc_hdr_t *) ((char *) p - PC_HDR_SIZE);
+}
+
+static inline void *pc_payload (pc_hdr_t *h)
+{
+  return (char *) h + PC_HDR_SIZE;
+}
+
+static unsigned pc_init_classes (void)
+{
+  unsigned n = 0;
+  unsigned s;
+  for (s = 16; s <= 128; s += 16)
+    pc_class_size[n++] = (uint16_t) s;
+  for (s = 160; s <= 512; s += 32)
+    pc_class_size[n++] = (uint16_t) s;
+  for (s = 576; s <= 1024; s += 64)
+    pc_class_size[n++] = (uint16_t) s;
+  for (s = 1280; s <= 4096; s += 256)
+    pc_class_size[n++] = (uint16_t) s;
+  for (s = 5120; s <= PC_MAX_SMALL; s += 1024)
+    {
+      if (n >= PC_MAX_CLASSES)
+	break;
+      pc_class_size[n++] = (uint16_t) s;
+    }
+  return n;
+}
+
+static unsigned pc_size_class (size_t size)
+{
+  unsigned i;
+  size_t need;
+  if (__builtin_add_overflow (size, PC_HDR_SIZE, &need))
+    return UINT32_MAX;
+  for (i = 0; i < pc_nclasses; i++)
+    if (pc_class_size[i] >= need)
+      return i;
+  return UINT32_MAX;
+}
+
+static unsigned pc_size_class_aligned (size_t size, size_t alignment)
+{
+  unsigned i;
+  size_t need;
+  if (alignment < PC_ALIGN)
+    alignment = PC_ALIGN;
+  if (__builtin_add_overflow (size, PC_HDR_SIZE, &need))
+    return UINT32_MAX;
+  for (i = 0; i < pc_nclasses; i++)
+    {
+      size_t cs = pc_class_size[i];
+      /* Span payloads are aligned to PC_SLOT_ALIGN; the stride must be a
+	 multiple of both that and the requested alignment so every slot
+	 payload stays aligned (header sits immediately before payload).  */
+      if (cs >= need && (cs % alignment) == 0
+	  && (alignment <= PC_ALIGN || (cs % PC_SLOT_ALIGN) == 0))
+	return i;
+    }
+  return UINT32_MAX;
+}
+
+static inline uint32_t pc_mix (uintptr_t x)
+{
+  x ^= x >> 16;
+  x *= 0x7feb352dU;
+  x ^= x >> 15;
+  x *= 0x846ca68bU;
+  x ^= x >> 16;
+  return (uint32_t) x;
+}
+
+static inline uint32_t pc_site_index (uintptr_t pc, unsigned class_id)
+{
+  return (pc_mix (pc) ^ (class_id * 0x9e3779b9u)) & PC_SITE_MASK;
+}
+
+static void *pc_mmap (size_t n)
+{
+  void *p = mmap (NULL, n, PROT_READ | PROT_WRITE,
+		  MAP_PRIVATE | MAP_ANONYMOUS, -1, 0);
+  return p == MAP_FAILED ? NULL : p;
+}
+
+static void pc_munmap (void *p, size_t n)
+{
+  if (p)
+    munmap (p, n);
+}
+
+static pc_span_t *pc_span_new (unsigned class_id)
+{
+  size_t slot = pc_class_size[class_id];
+  size_t meta = pc_align_up (sizeof (pc_span_t), PC_ALIGN);
+  char *mem = pc_mmap (PC_SPAN_SIZE);
+  pc_span_t *sp;
+  size_t avail, nslots, i;
+  char *slots;
+  uintptr_t payload0, aligned_payload;
+  if (!mem)
+    return NULL;
+  sp = (pc_span_t *) mem;
+  /* Align the first payload to PC_SLOT_ALIGN so memalign up to that
+     granularity can reuse size-class slots (header precedes payload).  */
+  payload0 = (uintptr_t) mem + meta + PC_HDR_SIZE;
+  aligned_payload = pc_align_up (payload0, PC_SLOT_ALIGN);
+  if (aligned_payload < payload0)
+    {
+      pc_munmap (mem, PC_SPAN_SIZE);
+      return NULL;
+    }
+  slots = (char *) (aligned_payload - PC_HDR_SIZE);
+  if (slots < mem + meta)
+    {
+      pc_munmap (mem, PC_SPAN_SIZE);
+      return NULL;
+    }
+  avail = (size_t) (mem + PC_SPAN_SIZE - slots);
+  nslots = avail / slot;
+  if (nslots == 0)
+    {
+      pc_munmap (mem, PC_SPAN_SIZE);
+      return NULL;
+    }
+  sp->next = NULL;
+  sp->class_id = (uint16_t) class_id;
+  sp->nslots = (uint16_t) nslots;
+  sp->nfree = (uint32_t) nslots;
+  sp->slots = slots;
+  sp->free_list = NULL;
+  for (i = 0; i < nslots; i++)
+    {
+      void *s = slots + i * slot;
+      *(void **) s = sp->free_list;
+      sp->free_list = s;
+    }
+  return sp;
+}
+
+static void pc_central_push_span (pc_span_t *sp)
+{
+  unsigned c = sp->class_id;
+  pc_lock_acquire ();
+  sp->next = pc_span_lists[c];
+  pc_span_lists[c] = sp;
+  pc_lock_release ();
+}
+
+static pc_span_t *pc_central_pop_span (unsigned class_id)
+{
+  pc_span_t *sp;
+  pc_lock_acquire ();
+  sp = pc_span_lists[class_id];
+  if (sp)
+    pc_span_lists[class_id] = sp->next;
+  pc_lock_release ();
+  if (sp)
+    sp->next = NULL;
+  return sp;
+}
+
+static void pc_tls_drain_remote (pc_tls_t *t)
+{
+  void *h = atomic_exchange_explicit ((_Atomic (void *) *) &t->remote.head,
+				      NULL, memory_order_acq_rel);
+  while (h)
+    {
+      void *next = *(void **) h;
+      pc_hdr_t *hdr = (pc_hdr_t *) h;
+      unsigned c = hdr->class_id;
+      if (c < pc_nclasses)
+	{
+	  *(void **) h = t->cache[c];
+	  t->cache[c] = h;
+	}
+      h = next;
+    }
+}
+
+static void *pc_alloc_from_cache (pc_tls_t *t, unsigned class_id)
+{
+  void *slot = t->cache[class_id];
+  pc_hdr_t *hdr;
+  if (slot)
+    {
+      t->cache[class_id] = *(void **) slot;
+      hdr = (pc_hdr_t *) slot;
+      hdr->magic = PC_MAGIC;
+      hdr->class_id = (uint16_t) class_id;
+      hdr->flags = 0;
+      hdr->size = pc_class_size[class_id] - PC_HDR_SIZE;
+      return pc_payload (hdr);
+    }
+  return NULL;
+}
+
+static int pc_refill_cache (pc_tls_t *t, unsigned class_id)
+{
+  pc_span_t *sp = pc_central_pop_span (class_id);
+  unsigned take, i;
+  if (!sp)
+    {
+      sp = pc_span_new (class_id);
+      if (!sp)
+	return -1;
+    }
+  take = sp->nfree < 32 ? sp->nfree : 32;
+  for (i = 0; i < take; i++)
+    {
+      void *s = sp->free_list;
+      if (!s)
+	break;
+      sp->free_list = *(void **) s;
+      sp->nfree--;
+      *(void **) s = t->cache[class_id];
+      t->cache[class_id] = s;
+    }
+  if (sp->nfree)
+    pc_central_push_span (sp);
+  return t->cache[class_id] ? 0 : -1;
+}
+
+static void *pc_alloc_mmap (size_t size, size_t alignment)
+{
+  size_t need, total, pagesz, prefix;
+  char *mem;
+  pc_hdr_t *hdr;
+  uintptr_t raw, aligned, start;
+  if (pc_size_too_large (size) || alignment == 0
+      || (alignment & (alignment - 1)) != 0 || pc_size_too_large (alignment))
+    return NULL;
+  if (alignment < PC_ALIGN)
+    alignment = PC_ALIGN;
+  pagesz = pc_pagesize ();
+  prefix = sizeof (size_t) + sizeof (void *);
+  if (__builtin_add_overflow (size, PC_HDR_SIZE, &need)
+      || __builtin_add_overflow (need, alignment, &need)
+      || __builtin_add_overflow (need, prefix, &need))
+    return NULL;
+  total = pc_align_up (need, pagesz);
+  if (total < need || total == 0)
+    return NULL;
+  mem = pc_mmap (total);
+  if (!mem)
+    return NULL;
+  start = (uintptr_t) mem + prefix;
+  raw = start + PC_HDR_SIZE;
+  aligned = (raw + alignment - 1) & ~(uintptr_t) (alignment - 1);
+  if (aligned < raw || aligned + size < aligned
+      || aligned + size > (uintptr_t) mem + total)
+    {
+      pc_munmap (mem, total);
+      return NULL;
+    }
+  hdr = (pc_hdr_t *) (aligned - PC_HDR_SIZE);
+  hdr->magic = PC_MAGIC;
+  hdr->class_id = 0xffff;
+  hdr->flags = PC_F_MMAP;
+  hdr->size = (size_t) ((uintptr_t) mem + total - aligned);
+  ((size_t *) mem)[0] = total;
+  *(void **) ((char *) hdr - sizeof (void *)) = mem;
+  return (void *) aligned;
+}
+
+static void pc_free_mmap (pc_hdr_t *hdr)
+{
+  void *base = *(void **) ((char *) hdr - sizeof (void *));
+  size_t total = *(size_t *) base;
+  pc_munmap (base, total);
+}
+
+static void *pc_alloc_reusable (unsigned class_id, size_t size)
+{
+  pc_tls_t *t = &pc_tls;
+  void *p;
+  (void) size;
+  if (!t->inited)
+    phasecast_thread_init ();
+  if ((++t->slow_ticks & 63u) == 0)
+    pc_tls_drain_remote (t);
+  p = pc_alloc_from_cache (t, class_id);
+  if (p)
+    return p;
+  if (pc_refill_cache (t, class_id) != 0)
+    return NULL;
+  return pc_alloc_from_cache (t, class_id);
+}
+
+static void pc_free_reusable (void *slot)
+{
+  pc_hdr_t *hdr = (pc_hdr_t *) slot;
+  pc_tls_t *t = &pc_tls;
+  unsigned c = hdr->class_id;
+  if (!t->inited)
+    phasecast_thread_init ();
+  if (c < pc_nclasses)
+    {
+      *(void **) slot = t->cache[c];
+      t->cache[c] = slot;
+    }
+}
+
+static void *pc_alloc_eph (size_t size)
+{
+  pc_tls_t *t = &pc_tls;
+  size_t need, slab;
+  pc_hdr_t *hdr;
+  if (pc_size_too_large (size))
+    return NULL;
+  if (__builtin_add_overflow (size, PC_HDR_SIZE, &need))
+    return NULL;
+  need = pc_align_up (need, PC_ALIGN);
+  if (!t->eph_base || (size_t) (t->eph_end - t->eph_cur) < need)
+    {
+      if (need > PC_EPH_SLAB)
+	{
+	  slab = pc_align_up (need, pc_pagesize ());
+	  if (slab < need)
+	    return NULL;
+	}
+      else
+	slab = PC_EPH_SLAB;
+      char *mem = pc_mmap (slab);
+      if (!mem)
+	return NULL;
+      /* Chain previous slab pointer at start for pop cleanup.  */
+      ((void **) mem)[0] = t->eph_base;
+      ((size_t *) mem)[1] = slab;
+      t->eph_base = mem;
+      t->eph_cur = mem + 64;
+      t->eph_end = mem + slab;
+    }
+  hdr = (pc_hdr_t *) t->eph_cur;
+  t->eph_cur += need;
+  hdr->magic = PC_MAGIC;
+  hdr->class_id = 0xfffe;
+  hdr->flags = PC_F_EPH;
+  hdr->size = size;
+  return pc_payload (hdr);
+}
+
+static void *pc_site_alloc_fast (pc_site_t *site, size_t size)
+{
+  (void) size;
+  return pc_alloc_reusable (site->class_id, size);
+}
+
+static void *pc_site_alloc_eph (pc_site_t *site, size_t size)
+{
+  (void) site;
+  return pc_alloc_eph (size);
+}
+
+static void *pc_site_alloc_slow (pc_site_t *site, size_t size);
+
+static void pc_site_consider (pc_site_t *site, unsigned class_id)
+{
+  uint32_t hits = ++site->hits;
+  if (site->class_id == UINT32_MAX)
+    site->class_id = class_id;
+  else if (site->class_id != class_id)
+    site->class_id = UINT32_MAX - 1; /* mixed sizes */
+  if (hits == PC_WARMUP && site->class_id < pc_nclasses)
+    {
+      if (site->frees * 2 >= hits && pc_tls.eph_depth > 0)
+	{
+	  site->flags |= 1;
+	  pc_site_store_alloc (site, pc_site_alloc_eph);
+	}
+      else
+	pc_site_store_alloc (site, pc_site_alloc_fast);
+    }
+}
+
+static void *pc_site_alloc_slow (pc_site_t *site, size_t size)
+{
+  unsigned c = pc_size_class (size);
+  void *p;
+  if (c == UINT32_MAX)
+    {
+      if (pc_size_too_large (size))
+	return NULL;
+      return pc_alloc_mmap (size, PC_ALIGN);
+    }
+  pc_site_consider (site, c);
+  if (pc_tls.eph_depth > 0 && (site->flags & 1))
+    p = pc_alloc_eph (size);
+  else
+    p = pc_alloc_reusable (c, size);
+  return p;
+}
+
+static void pc_sites_init (void)
+{
+  unsigned i;
+  for (i = 0; i < PC_SITE_N; i++)
+    {
+      pc_site_store_alloc (&pc_sites[i], pc_site_alloc_slow);
+      pc_sites[i].class_id = UINT32_MAX;
+      pc_sites[i].hits = 0;
+      pc_sites[i].frees = 0;
+      pc_sites[i].flags = 0;
+    }
+}
+
+void
+phasecast_init (void)
+{
+  if (pc_global_inited)
+    return;
+  pc_nclasses = pc_init_classes ();
+  pc_sites_init ();
+  pc_global_inited = 1;
+}
+
+void
+phasecast_thread_init (void)
+{
+  if (!pc_global_inited)
+    phasecast_init ();
+  if (pc_tls.inited)
+    return;
+  memset (&pc_tls, 0, sizeof pc_tls);
+  pc_tls.inited = 1;
+}
+
+void
+phasecast_thread_fini (void)
+{
+  unsigned i;
+  if (!pc_tls.inited)
+    return;
+  pc_tls_drain_remote (&pc_tls);
+  for (i = 0; i < pc_nclasses; i++)
+    pc_tls.cache[i] = NULL;
+  while (pc_tls.eph_base)
+    {
+      void *prev = ((void **) pc_tls.eph_base)[0];
+      size_t slab = ((size_t *) pc_tls.eph_base)[1];
+      pc_munmap (pc_tls.eph_base, slab);
+      pc_tls.eph_base = prev;
+    }
+  pc_tls.eph_cur = pc_tls.eph_end = NULL;
+  pc_tls.eph_depth = 0;
+  pc_tls.inited = 0;
+}
+
+static pc_site_t *pc_lookup_site_pc (size_t size, void *caller_pc)
+{
+  uintptr_t pc = (uintptr_t) caller_pc;
+  unsigned c = pc_size_class (size);
+  uint32_t idx = pc_site_index (pc, c == UINT32_MAX ? 0xffffu : c);
+  return &pc_sites[idx];
+}
+
+void *
+phasecast_malloc_at (size_t size, void *caller_pc)
+{
+  pc_site_t *site;
+  pc_alloc_fn fn;
+  if (pc_size_too_large (size))
+    return NULL;
+  if (!pc_tls.inited)
+    phasecast_thread_init ();
+  if (size == 0)
+    size = 1;
+  if (caller_pc == NULL)
+    caller_pc = __builtin_extract_return_addr (__builtin_return_address (0));
+  site = pc_lookup_site_pc (size, caller_pc);
+  fn = pc_site_load_alloc (site);
+  return fn (site, size);
+}
+
+void *
+phasecast_malloc (size_t size)
+{
+  return phasecast_malloc_at (size,
+			      __builtin_extract_return_addr (__builtin_return_address (0)));
+}
+
+void
+phasecast_free_at (void *ptr, void *caller_pc)
+{
+  pc_hdr_t *hdr;
+  void *slot;
+  if (!ptr)
+    return;
+  hdr = pc_hdr_of (ptr);
+  if (hdr->magic != PC_MAGIC)
+    return;
+  if (hdr->flags & PC_F_EPH)
+    {
+      /* Reclaimed on phase_pop.  */
+      return;
+    }
+  if (hdr->flags & PC_F_MMAP)
+    {
+      pc_free_mmap (hdr);
+      return;
+    }
+  slot = hdr;
+  if (caller_pc == NULL)
+    caller_pc = __builtin_extract_return_addr (__builtin_return_address (0));
+  {
+    uint32_t idx = pc_site_index ((uintptr_t) caller_pc, hdr->class_id);
+    pc_sites[idx].frees++;
+  }
+  pc_free_reusable (slot);
+}
+
+void
+phasecast_free (void *ptr)
+{
+  phasecast_free_at (ptr,
+		     __builtin_extract_return_addr (__builtin_return_address (0)));
+}
+
+void *
+phasecast_realloc (void *ptr, size_t size)
+{
+  pc_hdr_t *hdr;
+  void *n;
+  size_t old;
+  if (!ptr)
+    return phasecast_malloc (size);
+  if (size == 0)
+    {
+      phasecast_free (ptr);
+      return NULL;
+    }
+  if (pc_size_too_large (size))
+    return NULL;
+  hdr = pc_hdr_of (ptr);
+  if (hdr->magic != PC_MAGIC)
+    return NULL;
+  old = hdr->size;
+  if (size <= old)
+    return ptr;
+  n = phasecast_malloc (size);
+  if (!n)
+    return NULL;
+  memcpy (n, ptr, old < size ? old : size);
+  phasecast_free (ptr);
+  return n;
+}
+
+void *
+phasecast_calloc (size_t n, size_t size)
+{
+  size_t bytes;
+  void *p;
+  if (__builtin_mul_overflow (n, size, &bytes) || pc_size_too_large (bytes))
+    return NULL;
+  p = phasecast_malloc (bytes);
+  if (p)
+    memset (p, 0, bytes);
+  return p;
+}
+
+void *
+phasecast_memalign (size_t alignment, size_t size)
+{
+  unsigned c;
+  void *p;
+  if (alignment == 0 || (alignment & (alignment - 1)) != 0)
+    return NULL;
+  if (pc_size_too_large (size) || pc_size_too_large (alignment))
+    return NULL;
+  if (!pc_tls.inited)
+    phasecast_thread_init ();
+  if (size == 0)
+    size = 1;
+  if (alignment < PC_ALIGN)
+    alignment = PC_ALIGN;
+  if (alignment > PC_SLOT_ALIGN)
+    return pc_alloc_mmap (size, alignment);
+  c = pc_size_class_aligned (size, alignment);
+  if (c == UINT32_MAX)
+    return pc_alloc_mmap (size, alignment);
+  p = pc_alloc_reusable (c, size);
+  if (p == NULL)
+    return NULL;
+  if (((uintptr_t) p & (alignment - 1)) != 0)
+    {
+      phasecast_free (p);
+      return pc_alloc_mmap (size, alignment);
+    }
+  return p;
+}
+
+size_t
+phasecast_usable_size (void *ptr)
+{
+  pc_hdr_t *hdr;
+  if (!ptr)
+    return 0;
+  hdr = pc_hdr_of (ptr);
+  if (hdr->magic != PC_MAGIC)
+    return 0;
+  return hdr->size;
+}
+
+void
+phasecast_fork_lock (void)
+{
+  pc_lock_acquire ();
+}
+
+void
+phasecast_fork_unlock_parent (void)
+{
+  pc_lock_release ();
+}
+
+void
+phasecast_fork_unlock_child (void)
+{
+  unsigned i;
+  atomic_store_explicit (&pc_lock, 0, memory_order_relaxed);
+  for (i = 0; i < PC_MAX_CLASSES; i++)
+    pc_span_lists[i] = NULL;
+  memset (&pc_tls, 0, sizeof pc_tls);
+  phasecast_thread_init ();
+}
+
+void
+phasecast_phase_push (const char *name)
+{
+  (void) name;
+  if (!pc_tls.inited)
+    phasecast_thread_init ();
+  pc_tls.eph_depth++;
+}
+
+void
+phasecast_phase_pop (void)
+{
+  if (!pc_tls.inited || pc_tls.eph_depth == 0)
+    return;
+  pc_tls.eph_depth--;
+  if (pc_tls.eph_depth == 0)
+    {
+      while (pc_tls.eph_base)
+	{
+	  void *prev = ((void **) pc_tls.eph_base)[0];
+	  size_t slab = ((size_t *) pc_tls.eph_base)[1];
+	  pc_munmap (pc_tls.eph_base, slab);
+	  pc_tls.eph_base = prev;
+	}
+      pc_tls.eph_cur = pc_tls.eph_end = NULL;
+    }
+}
+
+int
+phasecast_load_profile (const char *path)
+{
+  FILE *f;
+  char line[256];
+  if (!path)
+    return -1;
+  if (!pc_global_inited)
+    phasecast_init ();
+  f = fopen (path, "r");
+  if (!f)
+    return -1;
+  while (fgets (line, sizeof line, f))
+    {
+      unsigned idx, class_id, flags;
+      if (sscanf (line, "%u %u %u", &idx, &class_id, &flags) != 3)
+	continue;
+      if (idx >= PC_SITE_N || class_id >= pc_nclasses)
+	continue;
+      pc_sites[idx].class_id = class_id;
+      pc_sites[idx].hits = PC_WARMUP;
+      pc_sites[idx].flags = flags;
+      pc_site_store_alloc (&pc_sites[idx],
+			   (flags & 1) ? pc_site_alloc_eph : pc_site_alloc_fast);
+    }
+  fclose (f);
+  return 0;
+}
+
+int
+phasecast_save_profile (const char *path)
+{
+  FILE *f;
+  unsigned i;
+  if (!path)
+    return -1;
+  f = fopen (path, "w");
+  if (!f)
+    return -1;
+  for (i = 0; i < PC_SITE_N; i++)
+    if (pc_sites[i].hits >= PC_WARMUP && pc_sites[i].class_id < pc_nclasses)
+      fprintf (f, "%u %u %u\n", i, pc_sites[i].class_id, pc_sites[i].flags);
+  fclose (f);
+  return 0;
+}
