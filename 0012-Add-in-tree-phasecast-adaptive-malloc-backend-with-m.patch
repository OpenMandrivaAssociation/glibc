diff --git a/malloc/malloc-phasecast.c b/malloc/malloc-phasecast.c
new file mode 100644
index 0000000000..cce2401a12
--- /dev/null
+++ b/malloc/malloc-phasecast.c
@@ -0,0 +1,469 @@
+/* Shim to use phasecast as the malloc implementation inside glibc.
+   Copyright (C) 2026 Free Software Foundation, Inc.
+   This file is part of the GNU C Library.
+
+   The GNU C Library is free software; you can redistribute it and/or
+   modify it under the terms of the GNU Lesser General Public License as
+   published by the Free Software Foundation; either version 2.1 of the
+   License, or (at your option) any later version.
+
+   The GNU C Library is distributed in the hope that it will be useful,
+   but WITHOUT ANY WARRANTY; without even the implied warranty of
+   MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the GNU
+   Lesser General Public License for more details.
+
+   You should have received a copy of the GNU Lesser General Public
+   License along with the GNU C Library; see the file COPYING.LIB.  If
+   not, see <https://www.gnu.org/licenses/>.  */
+
+#include "phasecast/phasecast.h"
+
+#include <errno.h>
+#include <stdio.h>
+#include <string.h>
+#include <malloc.h>
+#include <libc-symbols.h>
+#include <shlib-compat.h>
+#include <malloc-internal.h>
+#include "malloc-shim-compat.h"
+
+#ifdef MALLOC_MULTI_BACKEND
+# define __libc_malloc __malloc_phasecast_malloc
+# define __libc_free __malloc_phasecast_free
+# define __libc_realloc __malloc_phasecast_realloc
+# define __libc_calloc __malloc_phasecast_calloc
+# define __libc_memalign __malloc_phasecast_memalign
+# define __libc_valloc __malloc_phasecast_valloc
+# define __libc_pvalloc __malloc_phasecast_pvalloc
+# define __posix_memalign __malloc_phasecast_posix_memalign
+# define aligned_alloc __malloc_phasecast_aligned_alloc
+# define free_sized __malloc_phasecast_free_sized
+# define free_aligned_sized __malloc_phasecast_free_aligned_sized
+# define __malloc_usable_size __malloc_phasecast_usable_size
+# define __libc_mallopt __malloc_phasecast_mallopt
+# define __libc_mallinfo __malloc_phasecast_mallinfo
+# define __libc_mallinfo2 __malloc_phasecast_mallinfo2
+# define __malloc_info __malloc_phasecast_malloc_info
+# define __malloc_stats __malloc_phasecast_malloc_stats
+# define __malloc_trim __malloc_phasecast_malloc_trim
+# define __malloc_fork_lock_parent __malloc_phasecast_fork_lock_parent
+# define __malloc_fork_unlock_parent __malloc_phasecast_fork_unlock_parent
+# define __malloc_fork_unlock_child __malloc_phasecast_fork_unlock_child
+# define __malloc_arena_thread_freeres __malloc_phasecast_arena_thread_freeres
+# define __malloc_check_init __malloc_phasecast_check_init
+# define __ptmalloc_init __malloc_phasecast_ptmalloc_init
+# define __glibc_morecore __malloc_phasecast_morecore
+# pragma push_macro("libc_hidden_proto")
+# pragma push_macro("libc_hidden_def")
+# pragma push_macro("weak_function")
+# undef libc_hidden_proto
+# define libc_hidden_proto(...) /* nothing */
+# undef libc_hidden_def
+# define libc_hidden_def(...) /* nothing */
+# undef weak_function
+# define weak_function /* nothing */
+# define MALLOC_MULTI_HIDDEN_PUSHED 1
+#endif
+
+static __thread int pc_thread_inited;
+static int pc_global_inited;
+
+static inline void
+pc_ensure_init (void)
+{
+  if (__builtin_expect (!pc_global_inited, 0))
+    {
+      phasecast_init ();
+      pc_global_inited = 1;
+    }
+  if (__builtin_expect (!pc_thread_inited, 0))
+    {
+      phasecast_thread_init ();
+      pc_thread_inited = 1;
+    }
+}
+
+void *__libc_malloc (size_t);
+libc_hidden_proto (__libc_malloc)
+void __libc_free (void *);
+libc_hidden_proto (__libc_free)
+void *__libc_realloc (void *, size_t);
+libc_hidden_proto (__libc_realloc)
+void *__libc_memalign (size_t, size_t);
+libc_hidden_proto (__libc_memalign)
+struct mallinfo2 __libc_mallinfo2 (void);
+libc_hidden_proto (__libc_mallinfo2)
+int __libc_mallopt (int, int);
+libc_hidden_proto (__libc_mallopt)
+void *__libc_calloc (size_t, size_t);
+libc_hidden_proto (__libc_calloc)
+void *__libc_valloc (size_t);
+libc_hidden_proto (__libc_valloc)
+void *__libc_pvalloc (size_t);
+libc_hidden_proto (__libc_pvalloc)
+int __posix_memalign (void **, size_t, size_t);
+libc_hidden_proto (__posix_memalign)
+size_t __malloc_usable_size (void *);
+libc_hidden_proto (__malloc_usable_size)
+
+void *
+__libc_malloc (size_t bytes)
+{
+  if (malloc_shim_size_too_large (bytes))
+    return malloc_shim_fail_oom ();
+  pc_ensure_init ();
+  return MALLOC_SHIM_CALL (phasecast_malloc_at (bytes, __builtin_return_address (0)));
+}
+libc_hidden_def (__libc_malloc)
+
+void
+__libc_free (void *mem)
+{
+  if (mem == NULL)
+    return;
+  pc_ensure_init ();
+  MALLOC_SHIM_FREE (phasecast_free_at (mem, __builtin_return_address (0)));
+}
+libc_hidden_def (__libc_free)
+
+void *
+__libc_realloc (void *oldmem, size_t bytes)
+{
+  void *p;
+  if (bytes == 0)
+    {
+      pc_ensure_init ();
+      if (oldmem != NULL)
+	{
+	  phasecast_free (oldmem);
+	  return NULL;
+	}
+      return MALLOC_SHIM_CALL (phasecast_malloc (0));
+    }
+  if (malloc_shim_size_too_large (bytes))
+    return malloc_shim_fail_oom ();
+  pc_ensure_init ();
+  if (oldmem == NULL)
+    return MALLOC_SHIM_CALL (phasecast_malloc (bytes));
+  if (bytes <= phasecast_usable_size (oldmem))
+    return oldmem;
+  p = phasecast_realloc (oldmem, bytes);
+  if (p == NULL)
+    __set_errno (ENOMEM);
+  return p;
+}
+libc_hidden_def (__libc_realloc)
+
+void *
+__libc_calloc (size_t n, size_t elem_size)
+{
+  size_t bytes;
+  if (__builtin_mul_overflow (n, elem_size, &bytes) || malloc_shim_size_too_large (bytes))
+    return malloc_shim_fail_oom ();
+  pc_ensure_init ();
+  return MALLOC_SHIM_CALL (phasecast_calloc (n, elem_size));
+}
+libc_hidden_def (__libc_calloc)
+
+void *
+__libc_memalign (size_t alignment, size_t bytes)
+{
+  void *p;
+  alignment = malloc_shim_align_pow2 (alignment);
+  if (alignment == 0 || malloc_shim_size_too_large (bytes)
+      || malloc_shim_size_too_large (alignment))
+    {
+      __set_errno (alignment == 0 ? EINVAL : ENOMEM);
+      return NULL;
+    }
+  pc_ensure_init ();
+  p = phasecast_memalign (alignment, bytes);
+  if (p == NULL)
+    __set_errno (ENOMEM);
+  return p;
+}
+libc_hidden_def (__libc_memalign)
+
+void *
+__libc_valloc (size_t bytes)
+{
+  return __libc_memalign (__getpagesize (), bytes);
+}
+libc_hidden_def (__libc_valloc)
+
+void *
+__libc_pvalloc (size_t bytes)
+{
+  size_t rounded = malloc_shim_pvalloc_size (bytes);
+  if (rounded == 0)
+    return malloc_shim_fail_oom ();
+  return __libc_memalign (__getpagesize (), rounded);
+}
+libc_hidden_def (__libc_pvalloc)
+
+int
+__posix_memalign (void **memptr, size_t alignment, size_t size)
+{
+  void *p;
+  if (memptr == NULL
+      || alignment == 0
+      || (alignment & (alignment - 1)) != 0
+      || alignment % sizeof (void *) != 0)
+    return EINVAL;
+  if (malloc_shim_size_too_large (size))
+    return ENOMEM;
+  pc_ensure_init ();
+  p = phasecast_memalign (alignment, size);
+  if (p == NULL)
+    return ENOMEM;
+  *memptr = p;
+  return 0;
+}
+libc_hidden_def (__posix_memalign)
+
+void *
+weak_function
+aligned_alloc (size_t alignment, size_t bytes)
+{
+  void *p;
+  if (alignment == 0 || (alignment & (alignment - 1)) != 0)
+    {
+      __set_errno (EINVAL);
+      return NULL;
+    }
+  if (malloc_shim_size_too_large (bytes) || malloc_shim_size_too_large (alignment))
+    return malloc_shim_fail_oom ();
+  pc_ensure_init ();
+  p = phasecast_memalign (alignment, bytes);
+  if (p == NULL)
+    __set_errno (ENOMEM);
+  return p;
+}
+
+void
+weak_function
+free_sized (void *ptr, size_t size __attribute_maybe_unused__)
+{
+  if (ptr == NULL)
+    return;
+  pc_ensure_init ();
+  MALLOC_SHIM_FREE (phasecast_free_at (ptr, __builtin_return_address (0)));
+}
+
+void
+weak_function
+free_aligned_sized (void *ptr, size_t alignment __attribute_maybe_unused__,
+		    size_t size __attribute_maybe_unused__)
+{
+  if (ptr == NULL)
+    return;
+  pc_ensure_init ();
+  MALLOC_SHIM_FREE (phasecast_free_at (ptr, __builtin_return_address (0)));
+}
+
+size_t
+__malloc_usable_size (void *mem)
+{
+  if (mem == NULL)
+    return 0;
+  pc_ensure_init ();
+  return phasecast_usable_size (mem);
+}
+libc_hidden_def (__malloc_usable_size)
+
+int
+__libc_mallopt (int param_number, int value)
+{
+  return malloc_shim_mallopt_ignore (param_number, value);
+}
+#if IS_IN (libc) && !defined (MALLOC_MULTI_BACKEND)
+libc_hidden_def (__libc_mallopt)
+#endif
+
+struct mallinfo
+__libc_mallinfo (void)
+{
+  struct mallinfo info;
+  memset (&info, 0, sizeof (info));
+  return info;
+}
+
+struct mallinfo2
+__libc_mallinfo2 (void)
+{
+  struct mallinfo2 info;
+  memset (&info, 0, sizeof (info));
+  return info;
+}
+libc_hidden_def (__libc_mallinfo2)
+
+int
+__malloc_info (int options __attribute__ ((unused)), FILE *fp)
+{
+  fprintf (fp, "<malloc version=\"phasecast\">\n</malloc>\n");
+  return 0;
+}
+
+void
+__malloc_stats (void)
+{
+}
+
+int
+__malloc_trim (size_t pad __attribute__ ((unused)))
+{
+  return 0;
+}
+
+void
+__malloc_fork_lock_parent (void)
+{
+  phasecast_fork_lock ();
+}
+
+void
+__malloc_fork_unlock_parent (void)
+{
+  phasecast_fork_unlock_parent ();
+}
+
+void
+__malloc_fork_unlock_child (void)
+{
+  phasecast_fork_unlock_child ();
+  pc_thread_inited = 1;
+  pc_global_inited = 1;
+}
+
+void
+__malloc_arena_thread_freeres (void)
+{
+  if (pc_thread_inited)
+    {
+      phasecast_thread_fini ();
+      pc_thread_inited = 0;
+    }
+}
+
+void
+__malloc_check_init (void)
+{
+}
+
+void
+__ptmalloc_init (void)
+{
+  phasecast_init ();
+  pc_global_inited = 1;
+  phasecast_thread_init ();
+  pc_thread_inited = 1;
+}
+
+#ifndef MALLOC_MULTI_BACKEND
+void *__malloc_initialize_hook = NULL;
+void *__free_hook = NULL;
+void *__malloc_hook = NULL;
+void *__realloc_hook = NULL;
+void *__memalign_hook = NULL;
+void *__after_morecore_hook = NULL;
+void *__morecore = NULL;
+#endif
+
+void *
+__glibc_morecore (ptrdiff_t increment __attribute__ ((unused)))
+{
+  return NULL;
+}
+#if SHLIB_COMPAT (libc, GLIBC_2_0, GLIBC_2_34) && !defined (MALLOC_MULTI_BACKEND)
+compat_symbol (libc, __glibc_morecore, __default_morecore, GLIBC_2_0);
+#endif
+
+#if IS_IN (libc) && !defined (MALLOC_MULTI_BACKEND)
+strong_alias (__libc_malloc, malloc)
+strong_alias (__libc_realloc, realloc)
+strong_alias (__libc_free, free)
+weak_alias (__libc_calloc, calloc)
+weak_alias (__libc_memalign, memalign)
+weak_alias (__posix_memalign, posix_memalign)
+weak_alias (__libc_valloc, valloc)
+weak_alias (__libc_pvalloc, pvalloc)
+weak_alias (__malloc_usable_size, malloc_usable_size)
+weak_alias (__malloc_info, malloc_info)
+weak_alias (__libc_mallinfo, mallinfo)
+weak_alias (__libc_mallinfo2, mallinfo2)
+weak_alias (__libc_mallopt, mallopt)
+weak_alias (__malloc_stats, malloc_stats)
+weak_alias (__malloc_trim, malloc_trim)
+#endif
+
+#if SHLIB_COMPAT (libc, GLIBC_2_0, GLIBC_2_26) && !defined (MALLOC_MULTI_BACKEND)
+compat_symbol (libc, __libc_free, cfree, GLIBC_2_0);
+#endif
+
+/* Phase markers are meaningful only with this backend; exported under
+   stable names even in multi-backend builds so tools can link them.  */
+void
+gnu_malloc_phase_push (const char *name)
+{
+  pc_ensure_init ();
+  phasecast_phase_push (name);
+}
+
+void
+gnu_malloc_phase_pop (void)
+{
+  pc_ensure_init ();
+  phasecast_phase_pop ();
+}
+
+int
+gnu_malloc_phase_load_profile (const char *path)
+{
+  pc_ensure_init ();
+  return phasecast_load_profile (path);
+}
+
+int
+gnu_malloc_phase_save_profile (const char *path)
+{
+  pc_ensure_init ();
+  return phasecast_save_profile (path);
+}
+
+#ifdef MALLOC_MULTI_BACKEND
+# ifdef MALLOC_MULTI_HIDDEN_PUSHED
+#  pragma pop_macro("weak_function")
+#  pragma pop_macro("libc_hidden_def")
+#  pragma pop_macro("libc_hidden_proto")
+# endif
+#include <malloc-backend.h>
+
+const struct libc_malloc_backend __libc_malloc_backend_phasecast =
+{
+  .name = "phasecast",
+  .init = __malloc_phasecast_ptmalloc_init,
+  .malloc = __malloc_phasecast_malloc,
+  .free = __malloc_phasecast_free,
+  .realloc = __malloc_phasecast_realloc,
+  .calloc = __malloc_phasecast_calloc,
+  .memalign = __malloc_phasecast_memalign,
+  .valloc = __malloc_phasecast_valloc,
+  .pvalloc = __malloc_phasecast_pvalloc,
+  .posix_memalign = __malloc_phasecast_posix_memalign,
+  .aligned_alloc = __malloc_phasecast_aligned_alloc,
+  .free_sized = __malloc_phasecast_free_sized,
+  .free_aligned_sized = __malloc_phasecast_free_aligned_sized,
+  .usable_size = __malloc_phasecast_usable_size,
+  .mallopt = __malloc_phasecast_mallopt,
+  .mallinfo = __malloc_phasecast_mallinfo,
+  .mallinfo2 = __malloc_phasecast_mallinfo2,
+  .malloc_info = __malloc_phasecast_malloc_info,
+  .malloc_stats = __malloc_phasecast_malloc_stats,
+  .malloc_trim = __malloc_phasecast_malloc_trim,
+  .fork_lock_parent = __malloc_phasecast_fork_lock_parent,
+  .fork_unlock_parent = __malloc_phasecast_fork_unlock_parent,
+  .fork_unlock_child = __malloc_phasecast_fork_unlock_child,
+  .arena_thread_freeres = __malloc_phasecast_arena_thread_freeres,
+  .check_init = __malloc_phasecast_check_init,
+};
+#endif /* MALLOC_MULTI_BACKEND */
diff --git a/malloc/malloc-select.c b/malloc/malloc-select.c
index 1746b375b7..4373651798 100644
--- a/malloc/malloc-select.c
+++ b/malloc/malloc-select.c
@@ -330,13 +330,13 @@ struct match_result
 
 /* Selection tiers (effective priority, higher wins).  In-file priority=
    only orders within a drop-in tier and is clamped to [0, 99] so a
-   distro snippet cannot outrank $(sysconfdir)/glibc/malloc.conf.
+   distro snippet cannot outrank /etc/glibc/malloc.conf.
 
      1000       GLIBC_MALLOC_IMPL
-      800       $(sysconfdir)/glibc/malloc.conf per-basename lines
-      600..699  $(sysconfdir)/glibc/malloc.d/<name>.conf  (admin / local)
-      500       $(sysconfdir)/glibc/malloc.conf default= (overrides distro)
-      400..499  $(datadir)/glibc/malloc.d/<name>.conf (distro-provided)
+      800       /etc/glibc/malloc.conf per-basename lines
+      600..699  /etc/glibc/malloc.d/<name>.conf  (admin / local)
+      500       /etc/glibc/malloc.conf default= (overrides distro drop-ins)
+      400..499  DATADIR/glibc/malloc.d/<name>.conf (distro-provided, arch-independent)
       <0        heuristics / compile-time default (fallthrough)  */
 enum
   {
@@ -1017,15 +1017,10 @@ choose_backend (int *external_out)
   }
 
   /* Scan all sources; effective priorities enforce:
-     $(sysconfdir)/malloc.conf per-basename >
-     $(sysconfdir)/malloc.d >
-     $(sysconfdir)/malloc.conf default= >
-     distro $(datadir)/malloc.d.  */
-#ifndef SYSCONFDIR
-# define SYSCONFDIR "/etc"
-#endif
-  scan_global_conf (SYSCONFDIR "/glibc/malloc.conf", exe_base_p, &best);
-  scan_dropin_dir (SYSCONFDIR "/glibc/malloc.d", exe_path_p, exe_base_p,
+     malloc.conf per-basename > /etc/malloc.d > malloc.conf default=
+     > distro DATADIR/malloc.d.  */
+  scan_global_conf ("/etc/glibc/malloc.conf", exe_base_p, &best);
+  scan_dropin_dir ("/etc/glibc/malloc.d", exe_path_p, exe_base_p,
 		   PRIO_ETC_MALLOCD_BASE, &best);
   scan_dropin_dir (DATADIR "/glibc/malloc.d", exe_path_p, exe_base_p,
 		   PRIO_DATA_MALLOCD_BASE, &best);
diff --git a/malloc/malloc.h b/malloc/malloc.h
index 76a57ee40d..dfdda69dae 100644
--- a/malloc/malloc.h
+++ b/malloc/malloc.h
@@ -164,5 +164,12 @@ extern int gnu_get_libc_malloc_impls (char *__buf, size_t __len) __THROW;
