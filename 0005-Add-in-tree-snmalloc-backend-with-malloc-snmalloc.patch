+
+/* This file compiles snmalloc's C++ core directly into glibc,
+   eliminating the need for an external CMake build and removing
+   the runtime dependency on libstdc++.
+
+   Key build flags (set via CPPFLAGS in malloc/Makefile):
+   - SNMALLOC_USE_SELF_VENDORED_STL: use snmalloc's own STL replacements
+   - SNMALLOC_USE_CXX11_THREAD_ATEXIT_DIRECT: use glibc's __cxa_thread_atexit_impl
+   - SNMALLOC_STATIC_LIBRARY_PREFIX=sn_: export sn_* prefixed C symbols
+   - NDEBUG: release build
+   - SNMALLOC_PLATFORM_HAS_GETENTROPY: glibc provides getentropy
+   - SNMALLOC_HAS_LINUX_RANDOM_H: linux/random.h available
+   - SNMALLOC_HAS_LINUX_FUTEX_H: linux/futex.h available  */
+
+/* Pull in the snmalloc library.  This is a header-only C++ library;
+   the override *.cc files provide the C entry points.  */
+
+/* Include the malloc override - this provides sn_malloc, sn_free, etc.  */
+#include "snmalloc/override/malloc.cc"
+
+/* Include the memcpy override - this provides sn_memcpy.  */
+#include "snmalloc/override/memcpy.cc"
+
+/* Provide the pure-virtual handler that the C++ runtime normally supplies.
+   Since we compile with -fno-rtti -fno-exceptions and -nostdlib, we need
+   to provide this ourselves in case any vtable contains a pure virtual.  */
+extern "C" void __cxa_pure_virtual ()
+{
+  __builtin_trap ();
+}
+
+extern "C" void __sn_initialize (void)
+{
+  snmalloc::StandardConfigClientMeta<>::ensure_init();
+}
