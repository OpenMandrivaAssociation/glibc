diff --git a/benchtests/bench-memcpy-snmalloc.cc b/benchtests/bench-memcpy-snmalloc.cc
new file mode 100644
index 0000000000..8f4fa24726
--- /dev/null
+++ b/benchtests/bench-memcpy-snmalloc.cc
@@ -0,0 +1,160 @@
+/* Benchmark comparing glibc memcpy vs snmalloc memcpy.
+   Copyright (C) 2026 Free Software Foundation, Inc.
+   This file is part of the GNU C Library.
+
+   The GNU C Library is free software; you can redistribute it and/or
+   modify it under the terms of the GNU Lesser General Public License as
+   published by the Free Software Foundation; either version 2.1 of the
+   License, or (at your option) any later version.
+
+   The GNU C Library is distributed in the hope that it will be useful,
+   but WITHOUT ANY WARRANTY; without even the implied warranty of
+   MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the GNU
+   Lesser General Public License for more details.
+
+   You should have received a copy of the GNU Lesser General Public
+   License along with the GNU C Library; see the file COPYING.LIB.  If
+   not, see <https://www.gnu.org/licenses/>.  */
+
+/* This benchmark compares glibc's memcpy (IFUNC-selected) against
+   snmalloc's X86_64Arch memcpy across a range of copy sizes.
+
+   snmalloc's memcpy strategy (x86-64):
+   - sizes <= 16: jump table of power-of-two sized loads/stores
+   - sizes 17-511: SSE 16-byte block copy loop
+   - sizes >= 512: cache-line aligned rep movsb
+
+   glibc's x86-64 memcpy (IFUNC-selected) typically:
+   - AVX/SSE moves for small/medium
+   - ERMS (rep movsb) for large copies
+
+   Compile:
+     g++ -O2 -std=c++17 -fno-exceptions -fno-rtti \
+       -DSNMALLOC_USE_SELF_VENDORED_STL \
+       -DNDEBUG \
+       -I<glibc-src>/malloc \
+       -o bench-memcpy-snmalloc bench-memcpy-snmalloc.cc  */
+
+/* snmalloc defines its own snmalloc::memcpy which shadows ::memcpy.
+   We must capture glibc's memcpy pointer before including snmalloc.  */
+#include <string.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <time.h>
+#include <stdint.h>
+
+typedef void *(*memcpy_fn_t)(void *__restrict, const void *__restrict, size_t);
+
+/* Capture glibc's memcpy function pointer before snmalloc headers
+   potentially shadow it.  Force through a volatile to prevent the
+   compiler from seeing through to snmalloc::memcpy.  */
+static volatile memcpy_fn_t glibc_memcpy_ptr =
+    reinterpret_cast<memcpy_fn_t>(memcpy);
+
+/* Now include snmalloc to get X86_64Arch::copy.  */
+#define SNMALLOC_USE_SELF_VENDORED_STL 1
+#define SNMALLOC_PLATFORM_HAS_GETENTROPY 1
+#define NDEBUG 1
+#include "snmalloc/snmalloc.h"
+
+/* Wrapper so snmalloc memcpy has the same signature as glibc's.
+   Uses X86_64Arch::copy directly -- no bounds checks, no allocator.  */
+static void *
+sn_memcpy_bench (void *__restrict dst, const void *__restrict src, size_t len)
+{
+  return snmalloc::DefaultArch::copy (dst, src, len);
+}
+
+/* Prevent the compiler from optimizing away results.  */
+static void *volatile sink;
+
+/* High-resolution timer.  */
+static inline uint64_t
+now_ns (void)
+{
+  struct timespec ts;
+  clock_gettime (CLOCK_MONOTONIC, &ts);
+  return (uint64_t)ts.tv_sec * 1000000000ULL + (uint64_t)ts.tv_nsec;
+}
+
+static const size_t WARMUP_ITERS = 2000;
+static const size_t BENCH_ITERS = 200000;
+
+static void
+bench_one_size (size_t size, size_t iters)
+{
+  void *src = nullptr, *dst = nullptr;
+  if (posix_memalign (&src, 64, size + 64) != 0
+      || posix_memalign (&dst, 64, size + 64) != 0)
+    {
+      fprintf (stderr, "allocation failed for size %zu\n", size);
+      exit (1);
+    }
+
+  ::memset (src, 0xAA, size);
+  ::memset (dst, 0x55, size);
+
+  uint64_t t0, t1;
+  double glibc_ns, sn_ns;
+  memcpy_fn_t glibc_mc = glibc_memcpy_ptr;
+
+  /* Warmup + bench glibc memcpy.  */
+  for (size_t i = 0; i < WARMUP_ITERS; i++)
+    sink = glibc_mc (dst, src, size);
+  t0 = now_ns ();
+  for (size_t i = 0; i < iters; i++)
+    sink = glibc_mc (dst, src, size);
+  t1 = now_ns ();
+  glibc_ns = (double)(t1 - t0) / (double)iters;
+
+  /* Warmup + bench snmalloc memcpy.  */
+  for (size_t i = 0; i < WARMUP_ITERS; i++)
+    sink = sn_memcpy_bench (dst, src, size);
+  t0 = now_ns ();
+  for (size_t i = 0; i < iters; i++)
+    sink = sn_memcpy_bench (dst, src, size);
+  t1 = now_ns ();
+  sn_ns = (double)(t1 - t0) / (double)iters;
+
+  const char *winner = glibc_ns <= sn_ns ? "glibc" : "snmalloc";
+  double ratio = glibc_ns > sn_ns ? glibc_ns / sn_ns : sn_ns / glibc_ns;
+
+  printf ("%8zu  %10.2f  %10.2f  %8s  %.2fx\n",
+          size, glibc_ns, sn_ns, winner, ratio);
+
+  free (src);
+  free (dst);
+}
+
+int
+main (void)
+{
+  printf ("# memcpy benchmark: glibc vs snmalloc (unchecked)\n");
+  printf ("# Each measurement: %zu iterations after %zu warmup\n",
+          BENCH_ITERS, WARMUP_ITERS);
+  printf ("#\n");
+  printf ("#%7s  %10s  %12s  %8s  %s\n",
+          "size", "glibc(ns)", "snmalloc(ns)", "winner", "ratio");
+
+  /* Small sizes: 1-64 bytes.  */
+  for (size_t s = 1; s <= 64; s++)
+    bench_one_size (s, BENCH_ITERS);
+
+  /* Medium sizes: 80-512, step 16.  */
+  for (size_t s = 80; s <= 512; s += 16)
+    bench_one_size (s, BENCH_ITERS);
+
+  /* Larger sizes: 640-4096, step 128.  */
+  for (size_t s = 640; s <= 4096; s += 128)
+    bench_one_size (s, BENCH_ITERS);
+
+  /* Large sizes: 8K-256K, doubling.  */
+  for (size_t s = 8192; s <= 256 * 1024; s <<= 1)
+    bench_one_size (s, BENCH_ITERS / 10);
+
+  /* Very large: 512K-4M, doubling.  */
+  for (size_t s = 512 * 1024; s <= 4 * 1024 * 1024; s <<= 1)
+    bench_one_size (s, BENCH_ITERS / 100);
+
+  return 0;
+}
