+libc_hidden_def (__libc_free)
+
+void *
+__libc_realloc (void *oldmem, size_t bytes)
+{
+  void *p;
+  if (bytes == 0)
+    {
+      if (oldmem != NULL)
+	{
+	  MALLOC_SHIM_FREE (sn_free (oldmem));
+	  return NULL;
+	}
+      return MALLOC_SHIM_CALL (sn_malloc (0));
+    }
+  if (malloc_shim_size_too_large (bytes))
+    return malloc_shim_fail_oom ();
+  if (oldmem == NULL)
+      if (oldmem == NULL)
+    return MALLOC_SHIM_CALL (sn_malloc (bytes));
+  /* Shrink-in-place: glibc leaves the block unmoved when the new size
+     fits in the existing usable region (tst-realloc).  */
+  if (bytes <= sn_malloc_usable_size (oldmem))
+    return oldmem;
+  p = sn_realloc (oldmem, bytes);
