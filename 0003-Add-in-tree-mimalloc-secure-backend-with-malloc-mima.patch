+/* Second amalgamation of mimalloc compiled with MI_SECURE=4.  Symbol
+   renames (mi_* -> mis_*, _mi_* -> _mis_*) come from
+   malloc-mimalloc-secure-rename.h so this TU can link alongside the
+   non-secure mimalloc backend.  */
