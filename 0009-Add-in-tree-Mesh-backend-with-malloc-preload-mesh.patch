+
+  template <class OBJTYPE>
+  class DynStack {
+  public:
+    DynStack()
+      : numItems (0)
+    {
+      items[0] = 0;
+    }
+
+    int length() const { return numItems; }
+
+    inline void push (OBJTYPE * ptr) {
+      numItems++;
+      items[numItems] = ptr;
+    }
+
+    inline OBJTYPE * pop() {
+      OBJTYPE * ptr = 0;
+      if (numItems > 0) {
+        ptr = items[numItems];
+        numItems--;
+        // The array has shrunk, so potentially trim it.
+        items.trim (numItems + 1);
+      }
+      return ptr;
+    }
+
+    inline OBJTYPE * top() {
+      OBJTYPE * ptr = NULL;
+      if (numItems > 0) {
+        ptr = items[numItems];
+      }
+      return ptr;
+    }
+
+    inline void clear() {
+      items.clear();
+    }
