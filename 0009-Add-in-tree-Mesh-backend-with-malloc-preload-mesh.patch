+template <size_t PageSize>
+static void cxx_delete_impl(void *ptr) {
+  auto *localHeap = ThreadLocalHeap<PageSize>::GetHeapIfPresent();
+  if (unlikely(localHeap == nullptr)) {
+    mesh::freeSlowpath<PageSize>(ptr);
