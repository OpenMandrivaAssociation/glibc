+//////////
+//////////
+
+// All replacement functions get the prefix "replace_".
+
+extern "C" {
+
+MESH_EXPORT void *replace_malloc(size_t sz) {
+  void *ptr = xxmalloc(sz);
+  return ptr;
+}
+
+#if 0  // Disabled pending wider support for sized deallocation.
