+    // 0 == no items.
+    // 1 == items[1] has the single item, etc.
+    // i.e., we waste entry zero.
+
+    int numItems;
+
+    // The array of remembered objects.
+
+    HL::DynamicArray<OBJTYPE *> items;
+  };
