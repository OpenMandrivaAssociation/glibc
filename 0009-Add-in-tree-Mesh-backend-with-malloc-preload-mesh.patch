+// -*- C++ -*-
+
+#ifndef HL_OBSTACKREAP_H
+#define HL_OBSTACKREAP_H
+
+#include <assert.h>
+
+/*
+
+  ObstackReap layers obstack functionality on top of reaps.
+
+ */
+
+#if WIN32
+#include <windows.h>
+#endif
+
+#include "utility/dynarray.h"
+
+namespace ObstackReapNS {
+
