+template <class Header>
+class bins<Header, 16384> {
+public:
+
+  bins()
+  {
+    static_assert(BIG_OBJECT > 0,
+		  "Big object must be positive.");
+  }
+
+  enum { NUM_BINS = 24 };
+  enum { NUM_SIZECLASSES = 2044 };
