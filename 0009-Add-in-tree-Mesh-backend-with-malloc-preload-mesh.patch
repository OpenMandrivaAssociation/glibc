+  TEST(float_fmt, float_val);
+  TEST(long_fmt, long_val);
+  TEST(ulong_fmt, ulong_val);
+  TEST(llong_fmt, llong_val);
+  TEST(string_fmt, string_val);
+#if !OS_SYSV /* SysV uses a different format than we do. */
+  TEST(pointer_fmt, pointer_val);
+#endif /* !OS_SYSV */
