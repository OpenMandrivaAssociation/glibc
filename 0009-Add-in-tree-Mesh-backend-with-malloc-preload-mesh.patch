+ */
+
+namespace HL {
+
+  class SLList {
+  public:
+    
+    inline SLList() {
+      clear();
+    }
+
+    class Entry;
+  
+    /// Clear the list.
+    inline void clear() {
+      head.next = nullptr;
+    }
+
+    /// Is the list empty?
+    inline bool isEmpty() const {
+      return (head.next == nullptr);
+    }
+
+    /// Get the head of the list.
+    inline Entry * get() {
+      const Entry * e = head.next;
+      if (e == nullptr) {
