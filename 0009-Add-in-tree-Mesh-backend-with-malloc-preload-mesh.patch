+/* C++ amalgamation of plasma-umass Mesh embedded in glibc.
+   Copyright (C) 2026 Free Software Foundation, Inc.
+   This file is part of the GNU C Library.  */
+
+#define MESH_EMBEDDED_IN_LIBC 1
+#ifndef MESH_EXPORT
+# define MESH_EXPORT __attribute__ ((visibility ("hidden")))
+#endif
+
+#include "mesh/src/d_assert.cc"
+#include "mesh/src/real.cc"
+#include "mesh/src/runtime.cc"
+#include "mesh/src/global_heap.cc"
+#include "mesh/src/meshable_arena.cc"
+#include "mesh/src/thread_local_heap.cc"
+#include "mesh/src/memory_stats_linux.cc"
+#include "mesh/src/libmesh.cc"
+
+#include "runtime.h"
+
+extern "C" void mesh_fork_prepare (void) {
+  if (mesh::getPageSize() == mesh::kPageSize4K)
+    mesh::runtime<mesh::kPageSize4K>().heap().lock();
+  else
+    mesh::runtime<mesh::kPageSize16K>().heap().lock();
+}
+extern "C" void mesh_fork_parent (void) {
+  if (mesh::getPageSize() == mesh::kPageSize4K)
+    mesh::runtime<mesh::kPageSize4K>().heap().unlock();
+  else
+    mesh::runtime<mesh::kPageSize16K>().heap().unlock();
+}
+extern "C" void mesh_fork_child (void) {
+  if (mesh::getPageSize() == mesh::kPageSize4K)
+    mesh::runtime<mesh::kPageSize4K>().heap().unlock();
+  else
+    mesh::runtime<mesh::kPageSize16K>().heap().unlock();
+}
