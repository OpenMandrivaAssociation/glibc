+  for (i = 0; i < 100; i++) {
+    value = pow(10, i) * digits;
+    (void)sprintf(buf1, "%.1f", value);
+    (void)snprintf(buf2, sizeof(buf2), "%.1f", value);
+    if (strcmp(buf1, buf2) != 0) {
+      (void)printf("apparently %d.\n", i);
+      break;
+    }
+  }
+  return (failed == 0) ? 0 : 1;
+}
