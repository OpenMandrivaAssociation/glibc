+
+ARCH_FLAGS = select({
+    "@platforms//cpu:x86_64": [
+        "-march=westmere",
+        "-mavx2",
+    ],
+    "@platforms//cpu:aarch64": [
+        "-march=armv8.2-a",
+    ],
+    "//conditions:default": [],
+})
+
+LINUX_FLAGS = select({
+    "@platforms//os:linux": [
+        "-Wa,--noexecstack",
+    ],
+    "//conditions:default": [],
+})
+
+LTO_FLAGS = select({
+    "//src:opt_build": [
+        "-U_FORTIFY_SOURCE",
+        "-D_FORTIFY_SOURCE=2",
+        "-flto",
+    ],
+    "//conditions:default": [],
