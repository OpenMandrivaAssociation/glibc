@@ -0,0 +1,57 @@
+/* LD_PRELOAD entry for Mesh.  Copyright (C) 2026 Free Software Foundation.
+   Separate DSO linked with libstdc++; depends on libc, never linked into it. */
+
+#define MESH_EMBEDDED_IN_LIBC 1
+#define MESHING_ENABLED 1
+#define SHUFFLE_ON_INIT 1
+#define SHUFFLE_ON_FREE 0
+#ifndef MESH_EXPORT
+# define MESH_EXPORT __attribute__((visibility("default")))
+#endif
+
+#include "mesh/src/d_assert.cc"
+#include "mesh/src/real.cc"
+#include "mesh/src/runtime.cc"
+#include "mesh/src/global_heap.cc"
+#include "mesh/src/meshable_arena.cc"
+#include "mesh/src/thread_local_heap.cc"
+#include "mesh/src/memory_stats_linux.cc"
+#include "mesh/src/libmesh.cc"
+
+#include <errno.h>
+#include <stddef.h>
+#include <unistd.h>
+
+extern "C" {
+void *mesh_malloc(size_t);
+void mesh_free(void *);
+void *mesh_realloc(void *, size_t);
+void *mesh_calloc(size_t, size_t);
+void *mesh_memalign(size_t, size_t);
+size_t mesh_malloc_usable_size(void *);
+}
+
+extern "C" {
+void *malloc(size_t n) { return mesh_malloc(n); }
+void free(void *p) { mesh_free(p); }
+void *calloc(size_t n, size_t s) { return mesh_calloc(n, s); }
+void *realloc(void *p, size_t n) { return mesh_realloc(p, n); }
+void *memalign(size_t a, size_t n) { return mesh_memalign(a, n); }
+void *aligned_alloc(size_t a, size_t n) {
+  if (!a || (a & (a - 1))) { errno = EINVAL; return nullptr; }
+  return mesh_memalign(a, n);
+}
+int posix_memalign(void **m, size_t a, size_t n) {
+  if (!m || !a || (a & (a - 1)) || a % sizeof(void *)) return EINVAL;
+  void *p = mesh_memalign(a, n);
+  if (!p) return ENOMEM;
+  *m = p; return 0;
+}
+void *valloc(size_t n) { return mesh_memalign((size_t)sysconf(_SC_PAGESIZE), n); }
+size_t malloc_usable_size(void *p) { return mesh_malloc_usable_size(p); }
+void *__libc_malloc(size_t n) { return malloc(n); }
+void __libc_free(void *p) { free(p); }
+void *__libc_realloc(void *p, size_t n) { return realloc(p, n); }
+void *__libc_calloc(size_t n, size_t s) { return calloc(n, s); }
+void *__libc_memalign(size_t a, size_t n) { return memalign(a, n); }
+}
