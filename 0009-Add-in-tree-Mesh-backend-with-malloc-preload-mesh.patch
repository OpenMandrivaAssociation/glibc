+              "\t sprintf(3): [%s] (%d)\n"                  \
+              "\tsnprintf(3): [%s] (%d)\n",                 \
+              fmt[i], buf1, r1, buf2, r2);                  \
+          failed++;                                         \
+        }                                                   \
+        num++;                                              \
+      }                                                     \
+  } while (/* CONSTCOND */ 0)
