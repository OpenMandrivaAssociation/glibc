diff --git a/malloc/malloc.d-README b/malloc/malloc.d-README
new file mode 100644
index 0000000000..99fbbfd78a
--- /dev/null
+++ b/malloc/malloc.d-README
@@ -0,0 +1,57 @@
+# Drop-in malloc implementation selection
+#
+# Files in this directory named *.conf are read at process startup when
+# glibc is built with multiple embedded malloc implementations
+# (--with-malloc=a,b,...).  Selection precedence (highest wins):
+#
+#   1. External interposition of public malloc (active reports "external")
+#   2. GLIBC_MALLOC_IMPL environment variable (ignored if AT_SECURE)
+#   3. /etc/glibc/malloc.conf per-basename lines (e.g. clang,clang++=snmalloc)
+#      — user/admin overrides; beats every drop-in file
+#   4. /etc/glibc/malloc.d/*.conf (admin/local drop-ins)
+#   5. /etc/glibc/malloc.conf default=NAME — overrides distro drop-ins and
+#      built-in heuristics when no higher match applies
+#   6. DATADIR/glibc/malloc.d/*.conf (distro-provided, arch-independent)
+#   7. Built-in heuristics (toolchain / GUI SONAME scan)
+#   8. Compile-time --with-default-malloc, else first configured impl
+#
+# Drop-in priority= only orders files within the same directory tier and
+# is clamped to 0..99 (default 50), so a distro snippet cannot outrank
+# /etc/glibc/malloc.conf.  Equal effective priorities: lexicographically
+# smaller source path wins.  Unknown or unavailable impl= names are
+# ignored (fall through), including when a conf names a backend not
+# embedded in this architecture's libc.  Duplicate priority=/impl= keys
+# in one drop-in invalidate that file.
+#
+# Example (distro or admin drop-in):
+#   priority=50
+#   match-basename=clang,clang++,clang-20,clang++-20
+#   impl=snmalloc
+#
+# User override in /etc/glibc/malloc.conf (no priority= key):
+#   clang,clang++=mimalloc
+#   default=rpmalloc
+#
+# Keys in *.conf drop-ins:
+#   priority=N          in-tier order only, 0..99 (default 50)
+#   impl=LIST           preference list of backend names (required).
+#                       Comma-separated tokens [A-Za-z0-9._+-] or a single
+#                       '*'.  First installed match wins; '*' means any
+#                       remaining installed dynamic DSO (see
+#                       $libdir/glibc/malloc/libglibc_malloc_*.so), else
+#                       the embedded default.  Unavailable names are
+#                       skipped.  Example: impl=snmalloc,rpmalloc,*
+
+#   match-basename=LIST match /proc/self/exe basename against any entry
+#                       in a comma-separated list (entries [A-Za-z0-9._+-],
+#                       whitespace around commas ignored).  Repeat the key
+#                       on extra lines to OR additional names.
+#   match-path=LIST     match full executable path against any entry in a
+#                       comma-separated list (same OR semantics)
+#
+# A file without match-* rules applies to every process.  Drop-in file
+# names must be NAME.conf with NAME in [A-Za-z0-9._+-].  Under AT_SECURE,
+# only root-owned non-group/other-writable regular files are honored;
+# argv[0] is never used for matching.  Install distro tuning under
+# DATADIR/glibc/malloc.d (e.g. /usr/share/glibc/malloc.d); keep user
+# overrides in /etc/glibc/malloc.conf or /etc/glibc/malloc.d.
