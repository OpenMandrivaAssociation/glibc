+      atomic_store_relaxed (&selection_state, SEL_UNSET);
+      atomic_store_relaxed (&selection_owner, NULL);
+      atomic_store_relaxed (&selection_owner_backend, NULL);
+      atomic_store_relaxed (&__libc_malloc_active, NULL);
+      atomic_store_relaxed (&__libc_malloc_external, 0);
+    }
