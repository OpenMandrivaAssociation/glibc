+  bool seen_prio = false;
+  bool seen_impl = false;
+  struct stat64 st;
+
+  fd = __open64_nocancel (path, O_RDONLY | O_CLOEXEC | O_NOFOLLOW | O_NONBLOCK);
+  if (fd < 0)
+    return;
+  if (__fstat64 (fd, &st) != 0 || !S_ISREG (st.st_mode) || st.st_size > 65536)
+    {
+      __close_nocancel_nostatus (fd);
+      return;
+    }
+  if (__libc_enable_secure
+      && (st.st_uid != 0 || (st.st_mode & (S_IWGRP | S_IWOTH)) != 0))
+    {
+      __close_nocancel_nostatus (fd);
+      return;
+    }
+
+  impl[0] = '\0';
+  for (;;)
+    {
+      ssize_t n = __read_nocancel (fd, chunk, sizeof chunk);
+      ssize_t i;
+
+      if (n <= 0)
+	break;
+      for (i = 0; i < n; i++)
+	{
+	  char c = chunk[i];
+	  if (c == '\n')
+	    {
+	      if (!skip && line_len > 0 && line_len < sizeof line)
+		{
+		  char *p, *eq, *k, *v;
+
+		  line[line_len] = '\0';
+		  p = line;
+		  while (*p == ' ' || *p == '\t')
+		    p++;
+		  if (*p != '\0' && *p != '#')
+		    {
+		      eq = p;
+		      while (*eq && *eq != '=')
+			eq++;
+		      if (*eq == '=')
+			{
+			  *eq = '\0';
+			  k = p;
+			  v = eq + 1;
+			  while (*v == ' ' || *v == '\t')
+			    v++;
+			  {
+			    char *ke = k + strlen (k);
+			    char *ve = v + strlen (v);
+			    while (ke > k
+				   && (ke[-1] == ' ' || ke[-1] == '\t'))
+			      *--ke = '\0';
+			    while (ve > v
+				   && (ve[-1] == ' ' || ve[-1] == '\t'
+				       || ve[-1] == '\r'))
+			      *--ve = '\0';
+			  }
+			  if (strcmp (k, "priority") == 0 && !seen_prio)
+			    {
+			      seen_prio = true;
+			      file_prio = 0;
+			      {
+				const char *q = v;
+				int sign = 1;
+				if (*q == '-')
+				  {
+				    sign = -1;
+				    q++;
+				  }
+				while (*q >= '0' && *q <= '9')
+				  {
+				    file_prio = file_prio * 10 + (*q - '0');
+				    q++;
+				  }
+				file_prio *= sign;
+			      }
+			    }
+			  else if (strcmp (k, "impl") == 0 && !seen_impl
+				   && *v != '\0')
+			    {
+			      size_t vl = strlen (v);
+			      if (vl < sizeof impl)
+				{
+				  seen_impl = true;
+				  memcpy (impl, v, vl + 1);
+				}
+			    }
+			  else if (strcmp (k, "match-basename") == 0)
+			    {
+			      char tmp[MALLOC_PREF_LIST_MAX];
+			      size_t vl = strlen (v);
+
+			      have_match_rule = true;
+			      if (vl < sizeof tmp && exe_base != NULL)
+				{
+				  memcpy (tmp, v, vl + 1);
+				  if (list_matches (tmp, exe_base, true))
+				    match = true;
+				}
+			    }
+			  else if (strcmp (k, "match-path") == 0)
+			    {
+			      char tmp[512];
+			      size_t vl = strlen (v);
+
+			      have_match_rule = true;
+			      if (vl < sizeof tmp && exe_path != NULL)
+				{
+				  memcpy (tmp, v, vl + 1);
+				  if (list_matches (tmp, exe_path, false))
+				    match = true;
+				}
+			    }
+			}
+		    }
+		}
+	      line_len = 0;
+	      skip = false;
+	    }
+	  else if (!skip)
+	    {
+	      if (line_len + 1 >= sizeof line)
+		skip = true;
+	      else
+		line[line_len++] = c;
+	    }
+	}
+    }
+  __close_nocancel_nostatus (fd);
+
+  if (!have_match_rule)
+    match = true;
+  if (!match || impl[0] == '\0')
+    return;
+
+  {
+    int prio = tier_base + file_prio;
+    int cmp;
+
+    if (file_prio < 0)
+      prio = tier_base;
+    else if (file_prio > 99)
+      prio = tier_base + 99;
+
+    if (*best_prio < 0)
+      cmp = 1;
+    else if (prio > *best_prio)
+      cmp = 1;
+    else if (prio < *best_prio)
+      cmp = -1;
+    else
+      cmp = strcmp (path, best_src) < 0 ? 1 : -1;
+    if (cmp > 0)
+      {
+	size_t il = strlen (impl);
+	size_t sl = strlen (path);
+	if (il >= best_impl_len || sl >= best_src_len)
+	  return;
+	memcpy (best_impl, impl, il + 1);
+	memcpy (best_src, path, sl + 1);
+	*best_prio = prio;
+      }
+  }
+}
+
+static void
+scan_dropin_dir_early (const char *dir, const char *exe_path,
+		       const char *exe_base, int tier_base,
+		       char *best_impl, size_t best_impl_len,
+		       char *best_src, size_t best_src_len, int *best_prio)
+{
+  int fd;
+  char dentbuf[2048];
+
+  if (dir == NULL || *dir == '\0')
+    return;
+  fd = __open64_nocancel (dir,
+			  O_RDONLY | O_DIRECTORY | O_CLOEXEC | O_NOFOLLOW
+			  | O_NONBLOCK);
+  if (fd < 0)
+    return;
+  if (!secure_fd_ok (fd, true))
+    {
+      __close_nocancel_nostatus (fd);
+      return;
+    }
+  for (;;)
+    {
+      ssize_t nread = __getdents64 (fd, dentbuf, sizeof dentbuf);
+      ssize_t bpos = 0;
+      if (nread <= 0)
+	break;
+      while (bpos < nread)
+	{
+	  struct dirent64 *d = (struct dirent64 *) (dentbuf + bpos);
+	  char path[384];
+	  size_t dlen, nlen;
+
+	  bpos += d->d_reclen;
+	  if (!valid_dropin_filename (d->d_name))
+	    continue;
+	  dlen = strlen (dir);
+	  nlen = strlen (d->d_name);
+	  if (dlen + 1 + nlen + 1 > sizeof path)
+	    continue;
+	  memcpy (path, dir, dlen);
+	  path[dlen] = '/';
+	  memcpy (path + dlen + 1, d->d_name, nlen + 1);
+	  scan_dropin_file_early (path, exe_path, exe_base, tier_base,
+				  best_impl, best_impl_len,
+				  best_src, best_src_len, best_prio);
+	}
+    }
+  __close_nocancel_nostatus (fd);
+}
+
+struct malloc_map_args
+{
+  const char *path;
+  struct link_map *loader;
+  struct link_map *map;
+};
+
+static void
+malloc_map_doit (void *a)
+{
+  struct malloc_map_args *args = a;
+  args->map = _dl_map_object (args->loader, args->path, lt_library, 0,
+			      __RTLD_SECURE, LM_ID_BASE);
+}
+
+static bool
+try_map_path (struct link_map *main_map, const char *dir, const char *name)
+{
+  char path[256];
+  size_t dlen, nlen, need;
+  const char *objname;
+  const char *err_str = NULL;
+  bool malloced;
+  struct malloc_map_args args;
+  unsigned int old_nloaded;
+
+  if (dir == NULL || *dir == '\0')
+    return false;
+  dlen = strlen (dir);
+  nlen = strlen (name);
+  /* "/libglibc_malloc_" is 17 bytes; ".so" plus NUL is 4.  */
+  need = dlen + 17 + nlen + 4;
+  if (need > sizeof path)
+    return false;
+  memcpy (path, dir, dlen);
+  memcpy (path + dlen, "/libglibc_malloc_", 17);
+  memcpy (path + dlen + 17, name, nlen);
+  memcpy (path + dlen + 17 + nlen, ".so", 4);
+
+  args.path = path;
+  args.loader = main_map;
+  args.map = NULL;
+  old_nloaded = GL (dl_ns)[LM_ID_BASE]._ns_nloaded;
+  (void) _dl_catch_error (&objname, &err_str, &malloced, malloc_map_doit,
+			  &args);
+  if (err_str != NULL)
+    {
+      _dl_error_printf ("\
+ERROR: ld.so: object '%s' from malloc impl selection cannot be preloaded"
+			" (%s): ignored.\n", path, err_str);
+      return false;
+    }
+  if (args.map == NULL
+      || GL (dl_ns)[LM_ID_BASE]._ns_nloaded == old_nloaded)
+    return false;
+  args.map->l_free_initfini = 0;
+  GLRO (dl_malloc_impl_map) = args.map;
+  return true;
+}
+
+static void
+map_dynamic_impl (struct link_map *main_map, const char *name)
+{
+  if (main_map == NULL || name == NULL || *name == '\0')
+    return;
+  if (try_map_path (main_map, GLRO (dl_malloc_impl_dir), name))
+    return;
+  if (MALLOC_IMPL_DIR_BUILD[0] != '\0'
+      && strcmp (MALLOC_IMPL_DIR_BUILD, GLRO (dl_malloc_impl_dir)) != 0)
+    try_map_path (main_map, MALLOC_IMPL_DIR_BUILD, name);
+}
+
+/* Match SYM name without consulting l_versyms (not initialized yet).  */
+static const ElfW(Sym) *
+match_backend_sym (const struct link_map *map, const char *name,
+		   Elf_Symndx symidx)
+{
+  const ElfW(Sym) *symtab = (const void *) D_PTR (map, l_info[DT_SYMTAB]);
+  const char *strtab = (const void *) D_PTR (map, l_info[DT_STRTAB]);
+  const ElfW(Sym) *sym = &symtab[symidx];
+  unsigned int stt;
+
+  if (sym->st_value == 0 && sym->st_shndx != SHN_ABS)
+    return NULL;
+  stt = ELFW (ST_TYPE) (sym->st_info);
+  if (stt != STT_OBJECT && stt != STT_NOTYPE && stt != STT_COMMON)
+    return NULL;
+  if (strcmp (strtab + sym->st_name, name) != 0)
+    return NULL;
+  return sym;
+}
+
+/* Resolve __libc_malloc_backend_<id> inside MAP.  */
+static void *
+lookup_backend_in_map (struct link_map *map, const char *token)
+{
+  char sym[64];
+  size_t i, j = 0;
+  const ElfW(Sym) *ref = NULL;
+  uint32_t new_hash;
+
+  memcpy (sym, "__libc_malloc_backend_", 22);
+  for (i = 0; token[i] != '\0' && j + 22 < sizeof sym - 1; i++)
+    sym[22 + j++] = (token[i] == '-') ? '_' : token[i];
+  sym[22 + j] = '\0';
+
+  if (map->l_info[DT_SYMTAB] == NULL || map->l_info[DT_STRTAB] == NULL)
+    return NULL;
+  if (map->l_nbuckets == 0)
+    _dl_setup_hash (map);
+  if (map->l_nbuckets == 0)
+    return NULL;
+
+  new_hash = _dl_new_hash (sym);
+  if (map->l_gnu_bitmask != NULL)
+    {
+      Elf32_Word bucket = map->l_gnu_buckets[new_hash % map->l_nbuckets];
+      if (bucket != 0)
+	{
+	  const Elf32_Word *hasharr = &map->l_gnu_chain_zero[bucket];
+	  do
+	    if (((*hasharr ^ new_hash) >> 1) == 0)
+	      {
+		ref = match_backend_sym (map, sym,
+					 ELF_MACHINE_HASH_SYMIDX (map,
+								  hasharr));
+		if (ref != NULL)
+		  break;
+	      }
+	  while ((*hasharr++ & 1u) == 0);
+	}
+    }
+  else if (map->l_buckets != NULL)
+    {
+      uint32_t old_hash = _dl_elf_hash (sym);
+      Elf_Symndx symidx;
+      for (symidx = map->l_buckets[old_hash % map->l_nbuckets];
+	   symidx != STN_UNDEF; symidx = map->l_chain[symidx])
+	{
+	  ref = match_backend_sym (map, sym, symidx);
+	  if (ref != NULL)
+	    break;
+	}
+    }
+  if (ref == NULL)
+    return NULL;
+  return DL_SYMBOL_ADDRESS (map, ref);
+}
+
+/* Apply PREF preference list; returns 1 if a new DSO was mapped.  */
+static unsigned int
+apply_pref_list (struct link_map *main_map, char *pref)
+{
+  char resolved[MALLOC_IMPL_NAME_MAX];
+  const char *def = MALLOC_DEFAULT_NAME;
+  size_t n;
+  struct link_map *before;
+
+  if (pref == NULL || *pref == '\0')
+    return 0;
+  /* Preference tokens other than the embedded default (and '*') need the
+     installed-DSO inventory.  Scan once, lazily.  */
+  scan_installed ();
+  if (!malloc_pref_resolve (pref, def,
+			    GLRO (dl_malloc_impl_installed),
+			    GLRO (dl_malloc_impl_installed_len),
+			    resolved, sizeof resolved))
+    return 0;
+  if (strcmp (resolved, def) == 0)
+    return 0;
+  n = strlen (resolved);
+  if (n >= sizeof pick_storage)
+    return 0;
+  memcpy (pick_storage, resolved, n + 1);
+  GLRO (dl_malloc_impl_pick) = pick_storage;
+  before = GLRO (dl_malloc_impl_map);
+  map_dynamic_impl (main_map, resolved);
+  if (GLRO (dl_malloc_impl_map) != NULL
+      && GLRO (dl_malloc_impl_map) != before)
+    {
+      GLRO (dl_malloc_impl_backend)
+	= lookup_backend_in_map (GLRO (dl_malloc_impl_map), resolved);
+      if (GLRO (dl_malloc_impl_backend) == NULL)
+	{
+	  GLRO (dl_malloc_impl_pick) = NULL;
+	  GLRO (dl_malloc_impl_map) = NULL;
+	  return 0;
+	}
+      return 1u;
+    }
+  return 0;
+}
+
+unsigned int
+_dl_malloc_impl_setup (struct link_map *main_map)
+{
+  char envbuf[MALLOC_PREF_LIST_MAX];
+  const char *s = NULL;
+  size_t n;
+
+  if (GLRO (dl_malloc_impl_dir) == NULL)
+    GLRO (dl_malloc_impl_dir) = MALLOC_IMPL_DIR;
+
+  GLRO (dl_malloc_impl_pick) = NULL;
+  GLRO (dl_malloc_impl_map) = NULL;
+  GLRO (dl_malloc_impl_backend) = NULL;
+  /* Do not scan MALLOC_IMPL_DIR here — see scan_installed().  */
+
+  if (__libc_enable_secure)
+    return 0;
+
+  if (__environ != NULL)
+    {
+      const size_t key_len = sizeof ("GLIBC_MALLOC_IMPL") - 1;
+      for (char **ep = __environ; *ep != NULL; ep++)
+	if (strncmp (*ep, "GLIBC_MALLOC_IMPL=", key_len + 1) == 0)
+	  {
+	    s = *ep + key_len + 1;
+	    break;
+	  }
+    }
+  if (s != NULL && *s != '\0')
+    {
+      n = strlen (s);
+      if (n < sizeof envbuf)
+	{
+	  memcpy (envbuf, s, n + 1);
+	  return apply_pref_list (main_map, envbuf);
+	}
+    }
+
+  /* Optional conf path override (non-secure only; used by tests).  */
+  s = NULL;
+  if (__environ != NULL)
+    {
+      const size_t key_len = sizeof ("GLIBC_MALLOC_CONF") - 1;
+      for (char **ep = __environ; *ep != NULL; ep++)
+	if (strncmp (*ep, "GLIBC_MALLOC_CONF=", key_len + 1) == 0)
+	  {
+	    s = *ep + key_len + 1;
+	    break;
+	  }
+    }
+  if (s != NULL && *s != '\0'
+      && read_default_pref (s, conf_pref_storage, sizeof conf_pref_storage))
+    return apply_pref_list (main_map, conf_pref_storage);
+
+  /* Fall back to default= from $(sysconfdir)/glibc/malloc.conf.  */
+  if (read_default_pref (MALLOC_SYSCONF_CONF, conf_pref_storage,
+			 sizeof conf_pref_storage))
+    return apply_pref_list (main_map, conf_pref_storage);
+
+  /* Per-executable drop-ins (match-basename / match-path).  These must
+     be applied here in ld.so so a non-default *dynamic* backend
+     (libglibc_malloc_NAME.so) can be pre-mapped before the first
+     malloc.  libc's choose_backend can only honor dynamic picks that
+     were already mapped (v1).  Without this, e.g. DATADIR drop-ins
+     selecting glibc for chrome/helium are silently ignored when the
+     compile-time default is snmalloc — and snmalloc's multi-GiB
+     MAP_NORESERVE reserves trip Chromium's RLIMIT_DATA sandbox.  */
+  {
+    const char *exe_path = NULL;
+    const char *exe_base = NULL;
+    char basebuf[MALLOC_IMPL_NAME_MAX];
+    char best_impl[MALLOC_PREF_LIST_MAX];
+    char best_src[256];
+    int best_prio = -1;
+
+    /* Prefer the real path from the main map when set; otherwise fall
+       back to argv[0] (main_map->l_name is often "" this early).  */
+    if (main_map != NULL && main_map->l_name != NULL
+	&& main_map->l_name[0] != '\0')
+      exe_path = main_map->l_name;
+    else if (_dl_argv != NULL && _dl_argv[0] != NULL && _dl_argv[0][0] != '\0')
+      exe_path = _dl_argv[0];
+
+    if (exe_path != NULL)
+      {
+	/* rtld has no strrchr; walk for the last slash.  */
+	const char *base = exe_path;
+	const char *q;
+	size_t blen;
+
+	for (q = exe_path; *q != '\0'; q++)
+	  if (*q == '/')
+	    base = q + 1;
+	blen = strlen (base);
+	if (blen > 0 && blen < sizeof basebuf
+	    && malloc_pref_valid_token (base))
+	  {
+	    memcpy (basebuf, base, blen + 1);
+	    exe_base = basebuf;
+	  }
+      }
+
+    if (exe_base != NULL || exe_path != NULL)
+      {
+	best_impl[0] = '\0';
+	best_src[0] = '\0';
+	/* Higher tier first so sysconfdir wins over distro DATADIR.  */
+	scan_dropin_dir_early (MALLOC_SYSCONF_DROPIN, exe_path, exe_base,
+			       600, best_impl, sizeof best_impl,
+			       best_src, sizeof best_src, &best_prio);
+	scan_dropin_dir_early (MALLOC_DATA_DROPIN, exe_path, exe_base,
+			       400, best_impl, sizeof best_impl,
+			       best_src, sizeof best_src, &best_prio);
+	if (best_prio >= 0 && best_impl[0] != '\0')
+	  return apply_pref_list (main_map, best_impl);
+      }
+  }
+
+  return 0;
+}
+
+#else /* !IS_IN (rtld) */
+#include <ldsodefs.h>
+unsigned int
+_dl_malloc_impl_setup (struct link_map *main_map __attribute__ ((unused)))
+{
+  return 0;
+}
+#endif
