+$(objpfx)glibc-malloc-profile: malloc-profile.sh
+	rm -f $@.new
+	sed -e 's|@VERSION@|$(version)|' \
+	    -e 's|@PKGVERSION@|$(PKGVERSION)|' \
+	    -e 's|@REPORT_BUGS_TO@|$(REPORT_BUGS_TO)|' \
+	    -e 's|@MALLOC_DEFAULT@|$(malloc-default)|' \
+	    -e 's|@MALLOC_IMPLS@|$(malloc-impls)|' $< > $@.new \
+	&& rm -f $@ && mv $@.new $@ && chmod +x $@
+endif
