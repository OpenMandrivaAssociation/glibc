+  const char *def;
+
+  def = gnu_get_libc_malloc_default ();
+  TEST_VERIFY (def != NULL && def[0] != '\0');
+  active = gnu_get_libc_malloc_active ();
+  TEST_COMPARE_STRING (active, def);
+  TEST_VERIFY (gnu_get_libc_malloc_impls (buf, sizeof buf) == 0);
+  TEST_VERIFY (strstr (buf, def) != NULL);
+
+  p = malloc (64);
+  TEST_VERIFY_EXIT (p != NULL);
+  memset (p, 0x5a, 64);
+  free (p);
+
+  /* No dynamic DSO should be mapped on the default path.  */
+  TEST_COMPARE (dso_mapped ("rpmalloc"), 0);
+  TEST_COMPARE (dso_mapped ("snmalloc"), 0);
+  return 0;
+}
+
