+
+#ifndef _MALLOC_BACKEND_H
+#define _MALLOC_BACKEND_H
+
+#include <stdio.h>
+#include <stddef.h>
+#include <malloc.h>
+
+/* Operations implemented by each embedded malloc implementation.  */
+struct libc_malloc_backend
+{
+  const char *name;
+  void (*init) (void);
+  void *(*malloc) (size_t);
+  void (*free) (void *);
+  void *(*realloc) (void *, size_t);
+  void *(*calloc) (size_t, size_t);
+  void *(*memalign) (size_t, size_t);
+  void *(*valloc) (size_t);
+  void *(*pvalloc) (size_t);
+  int (*posix_memalign) (void **, size_t, size_t);
+  void *(*aligned_alloc) (size_t, size_t);
+  void (*free_sized) (void *, size_t);
+  void (*free_aligned_sized) (void *, size_t, size_t);
+  size_t (*usable_size) (void *);
+  int (*mallopt) (int, int);
+  struct mallinfo (*mallinfo) (void);
+  struct mallinfo2 (*mallinfo2) (void);
+  int (*malloc_info) (int, FILE *);
+  void (*malloc_stats) (void);
+  int (*malloc_trim) (size_t);
+  void (*fork_lock_parent) (void);
+  void (*fork_unlock_parent) (void);
+  void (*fork_unlock_child) (void);
+  void (*arena_thread_freeres) (void);
+  void (*check_init) (void);
+};
+
+/* Null-terminated list of backends linked into this libc, strongest
+   symbol provided by malloc-select-backends.c (generated).  */
+extern const struct libc_malloc_backend *const __libc_malloc_backends[];
+
+/* Compile-time default backend name (--with-default-malloc).  */
+extern const char __libc_malloc_default_name[];
+
+/* Currently selected backend.  NULL until selection finishes (SEL_DONE*);
+   then points at the single published backend (compile-time default when
+   public malloc is interposed).  Never replaced after publish.  */
+extern const struct libc_malloc_backend *__libc_malloc_active;
+libc_hidden_proto (__libc_malloc_active)
+
+/* True if an external library interposes the public malloc family.  */
+extern int __libc_malloc_external;
+libc_hidden_proto (__libc_malloc_external)
+
+/* Return 1 if NAME is the embedded default or an installed dynamic DSO.  */
+int __libc_malloc_impl_available (const char *name) attribute_hidden;
+
+/* Scan $(slibdir)/glibc/malloc for libglibc_malloc_*.so basenames.
+   Fills NAMES with sorted unique tokens; returns count.  */
+#ifndef MALLOC_IMPL_NAME_MAX
+# define MALLOC_IMPL_NAME_MAX 32
+#endif
+int __libc_malloc_scan_installed (char names[][MALLOC_IMPL_NAME_MAX],
+				  int max_names) attribute_hidden;
+libc_hidden_proto (__libc_malloc_scan_installed)
+
+/* Public query APIs.  */
+int gnu_get_libc_malloc_impls (char *buf, size_t len);
+const char *gnu_get_libc_malloc_default (void);
+const char *gnu_get_libc_malloc_active (void);
+
+#endif /* _MALLOC_BACKEND_H */
