+/* Trim and test whether NEED equals a comma-separated entry in LIST.
+   Mutates LIST (inserts NULs).  TOKEN_ONLY requires malloc_pref_valid_token
+   for each entry.  */
+static bool
+list_matches (char *list, const char *need, bool token_only)
+{
+  char *p;
+
+  if (list == NULL || *list == '\0' || need == NULL || *need == '\0')
+    return false;
+  p = list;
+  while (*p)
+    {
+      char *start, *end;
+
+      while (*p == ' ' || *p == '\t')
+	p++;
+      if (*p == '\0')
+	break;
+      start = p;
+      while (*p && *p != ',')
+	p++;
+      end = p;
+      if (*p == ',')
+	*p++ = '\0';
+      while (end > start && (end[-1] == ' ' || end[-1] == '\t'))
+	*--end = '\0';
+      if (*start == '\0')
+	continue;
+      if (token_only && !malloc_pref_valid_token (start))
+	continue;
+      if (strcmp (start, need) == 0)
+	return true;
+    }
+  return false;
+}
