+/* Immortal process-private bootstrap arena for owner re-entry during
+   choose_backend (before any real backend is published).  Pointers from
+   this range must never be handed to a real backend free.  */
+enum { BOOTSTRAP_ALIGN = 16, BOOTSTRAP_SIZE = 65536 };
+static unsigned char bootstrap_mem[BOOTSTRAP_SIZE]
+  __attribute__ ((aligned (BOOTSTRAP_ALIGN)));
+static size_t bootstrap_bump;
+
+static bool
+ptr_in_bootstrap (const void *p)
+{
+  const unsigned char *u = p;
+  return u >= bootstrap_mem && u < bootstrap_mem + BOOTSTRAP_SIZE;
+}
+
+static void *
+bootstrap_malloc (size_t n)
+{
+  size_t aligned = (n + BOOTSTRAP_ALIGN - 1) & ~(size_t) (BOOTSTRAP_ALIGN - 1);
+  size_t old, neu;
+  if (aligned == 0)
+    aligned = BOOTSTRAP_ALIGN;
+  do
+    {
+      old = atomic_load_relaxed (&bootstrap_bump);
+      neu = old + aligned;
+      if (neu > BOOTSTRAP_SIZE || neu < old)
+	return NULL;
+    }
+  while (atomic_compare_and_exchange_bool_acq (&bootstrap_bump, neu, old));
+  return bootstrap_mem + old;
+}
+
+static void
+bootstrap_free (void *p)
+{
+  (void) p;
+}
+
+static void *
+bootstrap_realloc (void *p, size_t n)
+{
+  void *q;
+  size_t old_cap;
+  if (p == NULL)
+    return bootstrap_malloc (n);
+  if (!ptr_in_bootstrap (p))
+    return NULL;
+  if (n == 0)
+    return NULL;
+  old_cap = (size_t) (bootstrap_mem + BOOTSTRAP_SIZE - (unsigned char *) p);
+  if (n <= old_cap)
+    return p;
+  q = bootstrap_malloc (n);
+  if (q != NULL)
+    memcpy (q, p, old_cap < n ? old_cap : n);
+  return q;
+}
+
+static void *
+bootstrap_calloc (size_t a, size_t b)
+{
+  size_t n;
+  void *p;
+  if (b != 0 && a > (size_t) -1 / b)
+    return NULL;
+  n = a * b;
+  p = bootstrap_malloc (n);
+  if (p != NULL)
+    memset (p, 0, n);
+  return p;
+}
+
+static void *
+bootstrap_memalign (size_t a, size_t n)
+{
+  size_t mask, old, neu, pad;
+  void *p;
+  if (a < BOOTSTRAP_ALIGN)
+    a = BOOTSTRAP_ALIGN;
+  if ((a & (a - 1)) != 0)
+    return NULL;
+  mask = a - 1;
+  do
+    {
+      old = atomic_load_relaxed (&bootstrap_bump);
+      pad = (a - (old & mask)) & mask;
+      neu = old + pad + n;
+      if (neu > BOOTSTRAP_SIZE || neu < old)
+	return NULL;
+    }
+  while (atomic_compare_and_exchange_bool_acq (&bootstrap_bump, neu, old));
+  p = bootstrap_mem + old + pad;
+  return p;
+}
+
+static void *
+bootstrap_valloc (size_t n)
+{
+  return bootstrap_memalign (4096, n);
+}
+
+static void *
+bootstrap_pvalloc (size_t n)
+{
+  size_t page = 4096;
+  size_t rounded = (n + page - 1) & ~(page - 1);
+  return bootstrap_memalign (page, rounded ? rounded : page);
