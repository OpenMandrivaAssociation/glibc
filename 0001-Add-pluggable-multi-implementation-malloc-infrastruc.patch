diff --git a/malloc/tst-aligned-alloc.c b/malloc/tst-aligned-alloc.c
index e321bf3d6d..d55cced1e7 100644
--- a/malloc/tst-aligned-alloc.c
+++ b/malloc/tst-aligned-alloc.c
@@ -1,4 +1,4 @@
-/* Test for C17 alignment requirements.
+/* Test for aligned_alloc alignment requirements (C23).
    Copyright (C) 2023-2026 Free Software Foundation, Inc.
    This file is part of the GNU C Library.
 
@@ -75,6 +75,82 @@ do_test (void)
 
   free (p1);
   free (p2);
+
+  /* C23: size need NOT be a multiple of alignment.  Verify that
+     aligned_alloc succeeds when size % alignment != 0, and that the
+     returned pointer is correctly aligned.  This catches shims that
+     still enforce the removed C17 restriction.  */
+
+  /* Test various sizes that are not multiples of their alignment.
+     This pattern is what triggers the bug in real-world programs
+     like dd(1) with small block sizes (e.g. bs=7).  */
+  static const struct {
+    size_t alignment;
+    size_t size;
+  } c23_tests[] = {
+    { 2, 1 },       /* 1 % 2 != 0 */
+    { 2, 3 },       /* 3 % 2 != 0 */
+    { 4, 1 },       /* 1 % 4 != 0 */
+    { 4, 7 },       /* 7 % 4 != 0 */
+    { 8, 7 },       /* dd bs=7 pattern */
+    { 16, 3072 },   /* 3072 % 16 == 0, control */
+    { 32, 3072 },   /* 3072 % 32 == 0, control */
+    { 64, 3072 },   /* 3072 % 64 == 0, control */
+    { 128, 3072 },  /* 3072 % 128 != 0 */
+    { 256, 3072 },  /* 3072 % 256 == 0, control */
+    { 512, 3072 },  /* 3072 % 512 == 0, control */
+    { 1024, 3072 }, /* 3072 % 1024 == 0, control */
+    { 2048, 3072 }, /* 3072 % 2048 != 0 */
+    { 4096, 3072 }, /* 3072 % 4096 != 0 */
+    { 8192, 3072 }, /* 3072 % 8192 != 0 */
+    { 4096, 1 },    /* extreme: 1-byte alloc, page-aligned */
+    { 4096, 100 },  /* page-aligned, non-multiple size */
+    { 4096, 4095 }, /* just under a page */
+    { 4096, 4097 }, /* just over a page */
+  };
+
+  for (size_t i = 0; i < sizeof (c23_tests) / sizeof (c23_tests[0]); i++)
+    {
+      size_t al = c23_tests[i].alignment;
+      size_t sz = c23_tests[i].size;
+      void *p = aligned_alloc (al, sz);
+
+      if (p == NULL)
+        FAIL_EXIT1 ("aligned_alloc(%zu, %zu) failed (C23 case)", al, sz);
+
+      if ((uintptr_t) p % al != 0)
+        FAIL_EXIT1 ("aligned_alloc(%zu, %zu) returned %p (misaligned)",
+                     al, sz, p);
+
+      /* Write to the allocation to verify it is usable.  */
+      memset (p, 0xAA, sz);
+
+      free (p);
+    }
+
+  /* Sweep: for every power-of-2 alignment up to 2^15, allocate a size
+     that is NOT a multiple of the alignment.  */
+  for (int shift = 0; shift < 16; shift++)
+    {
+      size_t al = (size_t) 1 << shift;
+      /* Pick a size that is never a multiple of al (for al >= 2).  */
+      size_t sz = al + 1;
+      if (al == 1)
+        sz = 1; /* trivial: everything is a multiple of 1 */
+
+      void *p = aligned_alloc (al, sz);
+
+      if (p == NULL)
+        FAIL_EXIT1 ("aligned_alloc(%zu, %zu) sweep failed", al, sz);
+
+      if ((uintptr_t) p % al != 0)
+        FAIL_EXIT1 ("aligned_alloc(%zu, %zu) sweep misaligned (%p)",
+                     al, sz, p);
+
+      memset (p, 0xBB, sz);
+      free (p);
+    }
+
   return 0;
 }
 
diff --git a/malloc/tst-malloc-dynamic-conf.c b/malloc/tst-malloc-dynamic-conf.c
new file mode 100644
index 0000000000..674470e459
--- /dev/null
+++ b/malloc/tst-malloc-dynamic-conf.c
@@ -0,0 +1,71 @@
+/* Dynamic malloc: default= from conf file via GLIBC_MALLOC_CONF.
+   Copyright (C) 2026 Free Software Foundation, Inc.
+   This file is part of the GNU C Library.  */
+
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <malloc.h>
+#include <support/check.h>
+#include <support/support.h>
+#include <support/test-driver.h>
+
+static char *selected;
+
+static void
+init (int argc __attribute__ ((unused)), char **argv __attribute__ ((unused)))
+{
+  selected = getenv ("TST_MALLOC_DYNAMIC_EXPECT");
+}
+
+static int
+dso_mapped (const char *token)
+{
+  char needle[128];
+  FILE *f;
+  char line[512];
+  int found = 0;
+  snprintf (needle, sizeof needle, "libglibc_malloc_%s.so", token);
+  f = fopen ("/proc/self/maps", "r");
+  if (f == NULL)
+    return -1;
+  while (fgets (line, sizeof line, f) != NULL)
+    if (strstr (line, needle) != NULL)
+      {
+	found = 1;
+	break;
+      }
+  fclose (f);
+  return found;
+}
+
+static int
+do_test (void)
+{
+  void *p;
+  const char *active;
+  const char *def;
+  const char *conf;
+
+  if (selected == NULL || *selected == '\0')
+    FAIL_UNSUPPORTED ("TST_MALLOC_DYNAMIC_EXPECT not set");
+  conf = getenv ("GLIBC_MALLOC_CONF");
+  if (conf == NULL || *conf == '\0')
+    FAIL_UNSUPPORTED ("GLIBC_MALLOC_CONF not set");
+
+  def = gnu_get_libc_malloc_default ();
+  active = gnu_get_libc_malloc_active ();
+  TEST_COMPARE_STRING (active, selected);
+
+  p = malloc (64);
+  TEST_VERIFY_EXIT (p != NULL);
+  memset (p, 0x3c, 64);
+  free (p);
+
+  if (strcmp (selected, def) != 0)
+    TEST_COMPARE (dso_mapped (selected), 1);
+  return 0;
+}
+
+#define PREPARE init
+#include <support/test-driver.c>
