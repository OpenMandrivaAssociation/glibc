diff --git a/malloc/malloc-shim-compat.h b/malloc/malloc-shim-compat.h
new file mode 100644
index 0000000000..06fb8f946a
--- /dev/null
+++ b/malloc/malloc-shim-compat.h
@@ -0,0 +1,94 @@
+/* Shared glibc-compatibility helpers for alternate malloc shims.
+   Copyright (C) 2026 Free Software Foundation, Inc.
+   This file is part of the GNU C Library.
+
+   These checks mirror ptmalloc2 entry-point policy (malloc.c) so alternate
+   backends behave predictably on overflow and realloc edge cases without
+   changing allocator hot paths beyond one predictable unlikely branch.  */
+
+#ifndef _MALLOC_SHIM_COMPAT_H
+#define _MALLOC_SHIM_COMPAT_H
+
+#include <errno.h>
+#include <stdint.h>
+#include <unistd.h>
+
+static inline void *
+malloc_shim_fail_oom (void)
+{
+  __set_errno (ENOMEM);
+  return NULL;
+}
+
+static inline int
+malloc_shim_size_too_large (size_t bytes)
+{
+  return __glibc_unlikely (bytes > (size_t) PTRDIFF_MAX);
+}
+
+/* Round alignment up to the next power of two.  Returns 0 on overflow.  */
+static inline size_t
+malloc_shim_align_pow2 (size_t alignment)
+{
+  if (alignment == 0)
+    return sizeof (void *);
+  if ((alignment & (alignment - 1)) == 0)
+    return alignment;
+  if (alignment > (size_t) PTRDIFF_MAX / 2 + 1)
+    return 0;
+  alignment |= alignment >> 1;
+  alignment |= alignment >> 2;
+  alignment |= alignment >> 4;
+  alignment |= alignment >> 8;
+  alignment |= alignment >> 16;
+#if __SIZEOF_SIZE_T__ > 4
+  alignment |= alignment >> 32;
+#endif
+  return alignment + 1;
+}
+
+/* Call BACKEND (args...) and set ENOMEM if it returns NULL.  */
+#define MALLOC_SHIM_CALL(backend_call) \
+  ({ \
+    void *_p = (backend_call); \
+    if (_p == NULL) \
+      __set_errno (ENOMEM); \
+    _p; \
+  })
+
+/* Preserve errno across free-like calls (tst-free-errno).  */
+#define MALLOC_SHIM_FREE(backend_free_stmt) \
+  do { \
+    int _err = errno; \
+    backend_free_stmt; \
+    __set_errno (_err); \
+  } while (0)
+
+/* glibc pvalloc rounds SIZE up to a multiple of the page size and
+   guarantees a non-NULL result for SIZE == 0 (one page).  Returns 0 on
+   overflow so the caller can OOM.  */
+static inline size_t
+malloc_shim_pvalloc_size (size_t bytes)
+{
+  size_t pagesize = __getpagesize ();
+  size_t rounded;
+  if (bytes == 0)
+    return pagesize;
+  if (__builtin_add_overflow (bytes, pagesize - 1, &rounded))
+    return 0;
+  rounded &= ~(pagesize - 1);
+  if (rounded == 0 || malloc_shim_size_too_large (rounded))
+    return 0;
+  return rounded;
+}
+
+/* Alternate backends generally ignore mallopt tunables.  glibc documents
+   a non-zero return as success, and several tests require that.  */
+static inline int
+malloc_shim_mallopt_ignore (int param_number __attribute__ ((unused)),
+			    int value __attribute__ ((unused)))
+{
+  return 1;
+}
+
+#endif /* _MALLOC_SHIM_COMPAT_H */
