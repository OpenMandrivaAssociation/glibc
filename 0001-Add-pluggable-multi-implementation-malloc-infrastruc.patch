+/* Compute the winning backend without publishing or calling init.
+   Must not invoke libc malloc.  */
+static const struct libc_malloc_backend *
+choose_backend (int *external_out)
+{
+  *external_out = 0;
+  if (malloc_is_interposed ())
+    {
+      *external_out = 1;
+      return default_backend ();
+    }
+
+  char exe_path[512];
+  char exe_base[256];
+  const char *exe_path_p = NULL;
+  const char *exe_base_p = NULL;
+  bool have_exe = read_exe_path (exe_path, sizeof exe_path);
+
+  /* AT_SECURE: no argv[0], no drop-ins/heuristics — compile-time default.  */
+  if (__libc_enable_secure)
+    return default_backend ();
+
+  if (have_exe)
+    {
+      exe_path_p = exe_path;
+      basename_of (exe_path, exe_base, sizeof exe_base);
+      if (exe_base[0] != '\0' && valid_conf_token (exe_base))
+	exe_base_p = exe_base;
+    }
+
+  struct match_result best = { .priority = -1, .set = false };
+
+  {
+    char envbuf[32];
+    const char *env = early_getenv ("GLIBC_MALLOC_IMPL", envbuf, sizeof envbuf);
+    if (env != NULL && env[0] != '\0')
+      consider (&best, PRIO_ENV, env, "env:GLIBC_MALLOC_IMPL");
+  }
+
+  /* Scan all sources; effective priorities enforce:
+     $(sysconfdir)/malloc.conf per-basename >
+     $(sysconfdir)/malloc.d >
+     $(sysconfdir)/malloc.conf default= >
+     distro $(datadir)/malloc.d.  */
+#ifndef SYSCONFDIR
+# define SYSCONFDIR "/etc"
+#endif
+  scan_global_conf (SYSCONFDIR "/glibc/malloc.conf", exe_base_p, &best);
+  scan_dropin_dir (SYSCONFDIR "/glibc/malloc.d", exe_path_p, exe_base_p,
+		   PRIO_ETC_MALLOCD_BASE, &best);
+  scan_dropin_dir (DATADIR "/glibc/malloc.d", exe_path_p, exe_base_p,
+		   PRIO_DATA_MALLOCD_BASE, &best);
+
+  const struct libc_malloc_backend *chosen = NULL;
+#if defined (SHARED) && IS_IN (libc)
+  /* Honor loader pre-selection of a dynamic DSO.  Symbol address is
+     resolved in ld.so (searchlist is not ready for _dl_sym yet).  */
+  if (GLRO (dl_malloc_impl_backend) != NULL)
+    return (const struct libc_malloc_backend *) GLRO (dl_malloc_impl_backend);
+#endif
+  if (best.set)
+    chosen = find_backend (best.impl);
+  if (chosen == NULL && exe_base_p != NULL)
+    {
+      const char *h = heuristic_impl (exe_base_p, exe_path_p);
+      if (h != NULL)
+	chosen = find_backend (h);
+    }
+  if (chosen == NULL)
+    chosen = default_backend ();
+  return chosen;
+}
