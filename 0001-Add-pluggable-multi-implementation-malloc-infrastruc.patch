+static bool
+valid_dropin_filename (const char *name)
+{
+  size_t n = strlen (name);
+  size_t i;
+
+  if (n < 6 || strcmp (name + n - 5, ".conf") != 0 || name[0] == '.')
+    return false;
+  for (i = 0; i < n - 5; i++)
+    if (!malloc_pref_safe_name_char ((unsigned char) name[i]))
+      return false;
+  return true;
+}
