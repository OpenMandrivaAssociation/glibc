+/* Init then publish exactly once.  Owner re-entry during init uses
+   selection_owner_backend; waiters require SEL_DONE*.  */
+static void
+finalize_backend (const struct libc_malloc_backend *chosen, int external)
+{
+  atomic_store_release (&selection_owner_backend, chosen);
+  if (chosen != NULL && chosen->init != NULL)
+    chosen->init ();
+  atomic_store_release (&__libc_malloc_active, chosen);
+  if (external)
+    {
+      atomic_store_release (&__libc_malloc_external, 1);
+      atomic_store_release (&selection_state, SEL_DONE_EXTERNAL);
+    }
+  else
+    {
+      atomic_store_release (&__libc_malloc_external, 0);
+      atomic_store_release (&selection_state, SEL_DONE);
+    }
+  atomic_store_release (&selection_owner_backend, NULL);
+  atomic_store_release (&selection_owner, NULL);
