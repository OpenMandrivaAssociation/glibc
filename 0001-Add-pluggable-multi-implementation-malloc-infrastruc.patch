+static bool
+toolchain_match (const char *exe_base)
+{
+  static const char *const exact[] = {
+    "clang", "clang++", "gcc", "g++", "cc1", "cc1plus", "collect2",
+    "ld", "ld.bfd", "ld.gold", "ld.lld", "lld", "lld-link",
+    "rustc", "rustdoc", "cargo", "c++", "cc", "c99", "c11",
+    NULL
+  };
+  static const char *const prefixes[] = {
+    "clang-", "clang++-", "gcc-", "g++-",
+    NULL
+  };
+  for (int i = 0; exact[i]; i++)
+    if (strcmp (exe_base, exact[i]) == 0)
+      return true;
+  for (int i = 0; prefixes[i]; i++)
+    {
+      size_t pl = strlen (prefixes[i]);
+      if (strncmp (exe_base, prefixes[i], pl) == 0 && exe_base[pl] != '\0')
+	{
+	  bool digits = true;
+	  for (const char *p = exe_base + pl; *p; p++)
+	    if (!(*p >= '0' && *p <= '9') && *p != '.')
+	      {
+		digits = false;
+		break;
+	      }
+	  if (digits)
+	    return true;
+	}
+    }
+  return false;
+}
+
+static const char *
+heuristic_impl (const char *exe_base, const char *exe_path)
+{
+  if (exe_base != NULL && toolchain_match (exe_base))
+    {
+      if (__libc_malloc_impl_available ("snmalloc"))
+	return "snmalloc";
+      if (__libc_malloc_impl_available ("rpmalloc"))
+	return "rpmalloc";
+      return NULL;
+    }
+  if (exe_path == NULL || exe_path[0] == '\0')
+    return NULL;
+
+  int fd = open (exe_path, O_RDONLY | O_CLOEXEC | O_NOFOLLOW | O_NONBLOCK);
+  if (fd < 0)
+    return NULL;
+  struct stat st;
+  if (fstat (fd, &st) != 0 || !S_ISREG (st.st_mode))
+    {
+      close (fd);
+      return NULL;
+    }
+  static const char *const gui_libs[] = {
+    "libQt5Core.so", "libQt6Core.so", "libQt5Gui.so", "libQt6Gui.so",
+    "libgtk-3.so", "libgtk-4.so", "libgdk-3.so",
+    "libX11.so", "libwayland-client.so", "libSDL2-2.0.so",
+    NULL
+  };
+  bool gui = false;
+  char chunk[4096];
+  off_t off = 0;
+  const off_t limit = 256 * 1024;
+  while (off < limit && !gui)
+    {
+      ssize_t cn = pread (fd, chunk, sizeof chunk, off);
+      if (cn <= 0)
+	break;
+      for (int i = 0; gui_libs[i]; i++)
+	if (memmem (chunk, (size_t) cn, gui_libs[i], strlen (gui_libs[i]))
+	    != NULL)
+	  {
+	    gui = true;
+	    break;
+	  }
+      if (cn < (ssize_t) sizeof chunk)
+	break;
+      off += cn - 64;
+      if (off < 0)
+	break;
+    }
+  close (fd);
+  if (gui)
+    {
+      if (__libc_malloc_impl_available ("mimalloc"))
+	return "mimalloc";
+      if (__libc_malloc_impl_available ("glibc"))
+	return "glibc";
+    }
+  return NULL;
+}
