+# GrapheneOS hardened_malloc is 64-bit only (static_assert(sizeof(void*)==8),
+# unsigned __int128, large class-region layout).  Drop it on 32-bit; error if
+# it was requested as the embedded default (cannot silently change libc malloc).
+# Use a compile-only test (not AC_CHECK_SIZEOF which links and may fail when
+# LDFLAGS contains flags the C++ link test also chokes on).
+AC_CACHE_CHECK([pointer size for malloc backend selection], [libc_cv_malloc_ptr_size],
+  [AC_COMPILE_IFELSE(
+    [AC_LANG_SOURCE([[char test[(sizeof (void *) == 4) ? 1 : -1];]])],
+    [libc_cv_malloc_ptr_size=4],
+    [libc_cv_malloc_ptr_size=8])])
