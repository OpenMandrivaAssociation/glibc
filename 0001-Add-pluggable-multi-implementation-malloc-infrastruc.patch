+static const struct libc_malloc_backend *
+get_active (void)
+{
+  int st = atomic_load_acquire (&selection_state);
+  if (selection_ready (st))
+    return atomic_load_acquire (&__libc_malloc_active);
+
+  if (i_am_selection_owner ())
+    {
+      const struct libc_malloc_backend *ob
+	= atomic_load_acquire (&selection_owner_backend);
+      if (ob != NULL)
+	return ob;
+      /* Owner still in choose_backend: immortal bootstrap only.  */
+      return &bootstrap_backend;
+    }
