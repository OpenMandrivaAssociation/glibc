diff --git a/malloc/malloc-multi-smoke.sh b/malloc/malloc-multi-smoke.sh
new file mode 100755
index 0000000000..cfdfbc6448
--- /dev/null
+++ b/malloc/malloc-multi-smoke.sh
@@ -0,0 +1,50 @@
+#!/bin/bash
+# Minimal multi-malloc smoke against a built libc tree.
+# Usage: malloc-multi-smoke.sh BUILD_DIR
+set -euo pipefail
+BUILD=${1:?build dir}
+test -f "$BUILD/libc.so" || test -f "$BUILD/libc.so.6"
+LDSO=$BUILD/elf/ld.so
+test -x "$LDSO"
+SRC=$(mktemp --suffix=.c)
+BIN=$(mktemp)
+trap 'rm -f "$SRC" "$BIN"' EXIT
+cat >"$SRC" <<'C'
+#define _GNU_SOURCE
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+int gnu_get_libc_malloc_impls(char *, size_t);
+const char *gnu_get_libc_malloc_default(void);
+const char *gnu_get_libc_malloc_active(void);
+int main(void) {
+  char buf[256];
+  if (gnu_get_libc_malloc_impls(buf, sizeof buf) != 0) return 1;
+  void *p = malloc(32);
+  printf("%s|%s|%s|%p\n", buf, gnu_get_libc_malloc_default(),
+         gnu_get_libc_malloc_active(), p);
+  free(p);
+  return p ? 0 : 1;
+}
+C
+gcc -O0 -fPIE -c "$SRC" -o "$BIN.o"
+gcc -nostdlib -nostartfiles -o "$BIN" -pie \
+  "$BUILD/csu/Scrt1.o" "$BUILD/csu/crti.o" $(gcc --print-file-name=crtbeginS.o) \
+  "$BIN.o" -Wl,--dynamic-linker="$LDSO" \
+  -Wl,-rpath="$BUILD:$BUILD/elf:$BUILD/nptl" \
+  "$BUILD/libc.so" "$BUILD/libc_nonshared.a" "$LDSO" -lgcc \
+  $(gcc --print-file-name=crtendS.o) "$BUILD/csu/crtn.o"
+run() { "$LDSO" --library-path "$BUILD:$BUILD/elf:$BUILD/nptl" "$@"; }
+ln -sfn libc.so "$BUILD/libc.so.6" 2>/dev/null || true
+out=$(run "$BIN")
+echo "default: $out"
+echo "$out" | grep -q '|'
+def=$(echo "$out" | cut -d'|' -f2)
+for impl in $(echo "$out" | cut -d'|' -f1 | tr ',' ' '); do
+  got=$(GLIBC_MALLOC_IMPL=$impl run "$BIN" | cut -d'|' -f3)
+  echo "GLIBC_MALLOC_IMPL=$impl -> $got"
+  test "$got" = "$impl"
+done
+got=$(GLIBC_MALLOC_IMPL=no-such-impl run "$BIN" | cut -d'|' -f3)
+test "$got" = "$def"
+echo OK
diff --git a/malloc/malloc-pref.h b/malloc/malloc-pref.h
new file mode 100644
index 0000000000..20bae69111
--- /dev/null
+++ b/malloc/malloc-pref.h
@@ -0,0 +1,264 @@
+/* Preference-list parsing for pluggable malloc selection.
+   Copyright (C) 2026 Free Software Foundation, Inc.
+   This file is part of the GNU C Library.
+
+   Shared by ld.so (minimal malloc) and libc malloc-select.  All
+   functions are static inline / macros so both sides can include this
+   header without link dependencies.  */
+
+#ifndef _MALLOC_PREF_H
+#define _MALLOC_PREF_H
+
+#include <stdbool.h>
+#include <stddef.h>
+#include <string.h>
+
+#define MALLOC_IMPL_NAME_MAX 32
+#define MALLOC_IMPL_MAX_INSTALLED 32
+#define MALLOC_PREF_LIST_MAX 256
+
+static inline bool
+malloc_pref_safe_name_char (unsigned char c)
+{
+  return ((c >= 'A' && c <= 'Z')
+	  || (c >= 'a' && c <= 'z')
+	  || (c >= '0' && c <= '9')
+	  || c == '.' || c == '_' || c == '+' || c == '-');
+}
+
+static inline bool
+malloc_pref_valid_token (const char *s)
+{
+  if (s == NULL || *s == '\0')
+    return false;
+  for (const unsigned char *p = (const unsigned char *) s; *p; p++)
+    if (!malloc_pref_safe_name_char (*p))
+      return false;
+  return true;
+}
+
+/* True if NAME is in the sorted installed set (count NAMES_LEN).  */
+static inline bool
+malloc_pref_in_installed (const char *name,
+			  const char installed[][MALLOC_IMPL_NAME_MAX],
+			  int installed_len)
+{
+  int i;
+  if (name == NULL)
+    return false;
+  for (i = 0; i < installed_len; i++)
+    if (strcmp (installed[i], name) == 0)
+      return true;
+  return false;
+}
+
+/* Resolve PREF_LIST against embedded default and installed dynamic
+   names.  Writes the chosen impl into OUT (OUTLEN bytes).  Returns
+   true on success.  PREF_LIST is mutated (commas nulled).  */
+static inline bool
+malloc_pref_resolve (char *pref_list,
+		     const char *embedded_default,
+		     const char installed[][MALLOC_IMPL_NAME_MAX],
+		     int installed_len,
+		     char *out, size_t outlen)
+{
+  bool seen_star = false;
+  bool any_token = false;
+  char tried[MALLOC_IMPL_MAX_INSTALLED + 1][MALLOC_IMPL_NAME_MAX];
+  int tried_len = 0;
+  char *p;
+
+  if (out == NULL || outlen == 0)
+    return false;
+  out[0] = '\0';
+  if (pref_list == NULL)
+    goto fallback;
+
+  p = pref_list;
+  while (*p)
+    {
+      char *start, *end;
+      size_t len;
+      int i;
+      bool already;
+
+      while (*p == ' ' || *p == '\t')
+	p++;
+      if (*p == '\0')
+	break;
+      start = p;
+      while (*p && *p != ',')
+	p++;
+      end = p;
+      if (*p == ',')
+	*p++ = '\0';
+      while (end > start && (end[-1] == ' ' || end[-1] == '\t'))
+	*--end = '\0';
+      if (*start == '\0')
+	continue;
+      any_token = true;
+
+      if (start[0] == '*' && start[1] == '\0')
+	{
+	  if (seen_star)
+	    continue;
+	  seen_star = true;
+	  for (i = 0; i < installed_len; i++)
+	    {
+	      int j;
+	      already = false;
+	      for (j = 0; j < tried_len; j++)
+		if (strcmp (tried[j], installed[i]) == 0)
+		  {
+		    already = true;
+		    break;
+		  }
+	      if (already)
+		continue;
+	      len = strlen (installed[i]);
+	      if (len >= outlen)
+		continue;
+	      memcpy (out, installed[i], len + 1);
+	      return true;
+	    }
+	  goto fallback;
+	}
+
+      if (!malloc_pref_valid_token (start))
+	continue;
+
+      already = false;
+      for (i = 0; i < tried_len; i++)
+	if (strcmp (tried[i], start) == 0)
+	  {
+	    already = true;
+	    break;
+	  }
+      if (!already && tried_len < MALLOC_IMPL_MAX_INSTALLED + 1)
+	{
+	  len = strlen (start);
+	  if (len < MALLOC_IMPL_NAME_MAX)
+	    {
+	      memcpy (tried[tried_len], start, len + 1);
+	      tried_len++;
+	    }
+	}
+
+      if (embedded_default != NULL && strcmp (start, embedded_default) == 0)
+	{
+	  len = strlen (start);
+	  if (len >= outlen)
+	    continue;
+	  memcpy (out, start, len + 1);
+	  return true;
+	}
+      if (malloc_pref_in_installed (start, installed, installed_len))
+	{
+	  len = strlen (start);
+	  if (len >= outlen)
+	    continue;
+	  memcpy (out, start, len + 1);
+	  return true;
+	}
+    }
+
+  if (!any_token)
+    goto fallback;
+
+fallback:
+  if (embedded_default != NULL && embedded_default[0] != '\0')
+    {
+      size_t len = strlen (embedded_default);
+      if (len < outlen)
+	{
+	  memcpy (out, embedded_default, len + 1);
+	  return true;
+	}
+    }
+  out[0] = '\0';
+  return false;
+}
+
+/* Derive impl token from filename libglibc_malloc_NAME.so[.N].
+   Returns true and writes NAME into OUT on success.  */
+static inline bool
+malloc_pref_name_from_soname (const char *fname, char *out, size_t outlen)
+{
+  static const char prefix[] = "libglibc_malloc_";
+  static const char suffix[] = ".so";
+  size_t flen, plen = sizeof prefix - 1;
+  size_t slen = sizeof suffix - 1;
+  const char *name;
+  size_t nlen;
+  size_t i;
+
+  if (fname == NULL || out == NULL || outlen == 0)
+    return false;
+  flen = strlen (fname);
+  if (flen <= plen + slen || memcmp (fname, prefix, plen) != 0)
+    return false;
+  name = fname + plen;
+  nlen = flen - plen;
+  if (nlen > slen && memcmp (name + nlen - slen, suffix, slen) == 0)
+    nlen -= slen;
+  else
+    {
+      /* Allow libglibc_malloc_NAME.so.1 */
+      size_t j;
+      bool found = false;
+      for (j = 0; j + 4 <= nlen; j++)
+	if (name[j] == '.' && name[j + 1] == 's' && name[j + 2] == 'o'
+	    && name[j + 3] == '.')
+	  {
+	    nlen = j;
+	    found = true;
+	    break;
+	  }
+      if (!found)
+	return false;
+    }
+  if (nlen == 0 || nlen >= outlen || nlen >= MALLOC_IMPL_NAME_MAX)
+    return false;
+  if (name[0] == '.')
+    return false;
+  for (i = 0; i < nlen; i++)
+    {
+      if (!malloc_pref_safe_name_char ((unsigned char) name[i]))
+	return false;
+      if (name[i] == '.' && i + 1 < nlen && name[i + 1] == '.')
+	return false;
+    }
+  memcpy (out, name, nlen);
+  out[nlen] = '\0';
+  return true;
+}
+
+/* Insert NAME into sorted installed[] if not present.  */
+static inline void
+malloc_pref_add_installed (char installed[][MALLOC_IMPL_NAME_MAX],
+			   int *installed_len, const char *name)
+{
+  int i, j;
+  size_t len;
+  if (name == NULL || *installed_len >= MALLOC_IMPL_MAX_INSTALLED)
+    return;
+  if (!malloc_pref_valid_token (name))
+    return;
+  for (i = 0; i < *installed_len; i++)
+    {
+      int c = strcmp (installed[i], name);
+      if (c == 0)
+	return;
+      if (c > 0)
+	break;
+    }
+  len = strlen (name);
+  if (len >= MALLOC_IMPL_NAME_MAX)
+    return;
+  for (j = *installed_len; j > i; j--)
+    memcpy (installed[j], installed[j - 1], MALLOC_IMPL_NAME_MAX);
+  memcpy (installed[i], name, len + 1);
+  (*installed_len)++;
+}
+
+#endif /* _MALLOC_PREF_H */
diff --git a/malloc/malloc-profile.sh b/malloc/malloc-profile.sh
new file mode 100755
index 0000000000..02e810e33b
--- /dev/null
+++ b/malloc/malloc-profile.sh
@@ -0,0 +1,291 @@
+#!/bin/bash
+# Copyright (C) 2026 Free Software Foundation, Inc.
+# This file is part of the GNU C Library.
+
+# The GNU C Library is free software; you can redistribute it and/or
+# modify it under the terms of the GNU Lesser General Public
+# License as published by the Free Software Foundation; either
+# version 2.1 of the License, or (at your option) any later version.
+
+# The GNU C Library is distributed in the hope that it will be useful,
+# but WITHOUT ANY WARRANTY; without even the implied warranty of
+# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the GNU
+# Lesser General Public License for more details.
+
+# You should have received a copy of the GNU Lesser General Public
+# License along with the GNU C Library; if not, see
+# <https://www.gnu.org/licenses/>.
+
+# Requires a multi-implementation libc (comma-separated --with-malloc=...).
+# Single-impl builds expose the query APIs but only one name; profiling is
+# then a no-op beyond measuring that implementation.
+
+TEXTDOMAIN=libc
+VERSION='@VERSION@'
+PKGVERSION='@PKGVERSION@'
+REPORT_BUGS_TO='@REPORT_BUGS_TO@'
+MALLOC_DEFAULT='@MALLOC_DEFAULT@'
+MALLOC_IMPLS='@MALLOC_IMPLS@'
+
+output_path=''
+impls_list=$MALLOC_IMPLS
+runs=3
+warmup=1
+margin_pct=0
+libc_dir=''
+ldso=''
+
+do_usage() {
+  printf >&2 "Try \`%s --help' for more information.\n" glibc-malloc-profile
+  exit 1
+}
+
+do_help() {
+  cat <<'HELP'
+Usage: glibc-malloc-profile [OPTION]... -- COMMAND [ARG]...
+Profile COMMAND under each embedded malloc implementation and optionally
+write a drop-in configuration selecting the fastest one.
+
+Pass a representative invocation with real arguments.  Results from a
+bare command with no operands (for example plain 'grep') do not predict
+behavior under production workloads.
+
+Requires a glibc built with multiple --with-malloc implementations.
+Trials set GLIBC_MALLOC_IMPL; non-zero exits discard that timing.
+
+      --output=PATH     write winning drop-in conf to PATH
+      --impls=LIST      comma-separated implementations to test
+      --runs=N          timed runs per implementation (default: 3)
+      --warmup=N        warm-up runs per implementation (default: 1)
+      --margin=PCT      require PCT percent improvement over the compile-time
+                        default before writing output (default: 0)
+      --libc-dir=DIR    run via DIR/ld.so and DIR/libc.so.6 when present
+  -?, --help            print this help and exit
+      --version         print version information and exit
+
+Environment GLIBC_MALLOC_IMPL selects the implementation for each trial.
+Interactive commands are skipped.  Basenames written to conf files are
+restricted to [A-Za-z0-9._+-].
+HELP
+}
+
+do_version() {
+  echo "glibc-malloc-profile (GNU libc) $VERSION"
+  printf $"Copyright (C) %s Free Software Foundation, Inc.
+This is free software; see the source for copying conditions.  There is NO
+warranty; not even for MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.
+" "2026"
+  printf $"Written by %s.\n" "${PKGVERSION}glibc-malloc-profile"
+}
+
+is_interactive_cmd() {
+  local base
+  base=$(basename -- "$1")
+  case $base in
+    bash|sh|zsh|fish|ksh|tcsh|csh|dash) return 0 ;;
+    python|python2|python3|perl|ruby|lua|irb|node) return 0 ;;
+    vi|vim|nvim|emacs|nano|less|more|top|htop|gdb|lldb) return 0 ;;
+    ssh|scp|sftp|screen|tmux|watch) return 0 ;;
+  esac
+  return 1
+}
+
+sanitize_token() {
+  local s=$1
+  case $s in
+    ''|*[!A-Za-z0-9._+-]* ) return 1 ;;
+  esac
+  printf '%s' "$s"
+}
+
+run_with_impl() {
+  local impl=$1
+  shift
+  if test -n "$ldso" && test -n "$libc_dir"; then
+    GLIBC_MALLOC_IMPL=$impl "$ldso" --library-path "$libc_dir" "$@"
+  else
+    GLIBC_MALLOC_IMPL=$impl "$@"
+  fi
+}
+
+# Print average ms on stdout; return non-zero if any timed run failed.
+time_impl() {
+  local impl=$1
+  shift
+  local total=0 i elapsed start end ok=0 fail=0
+  for i in $(seq 1 "$warmup"); do
+    run_with_impl "$impl" "$@" >/dev/null 2>&1 || true
+  done
+  for i in $(seq 1 "$runs"); do
+    start=$(date +%s%N)
+    if run_with_impl "$impl" "$@" >/dev/null 2>&1; then
+      end=$(date +%s%N)
+      elapsed=$(( (end - start) / 1000000 ))
+      total=$((total + elapsed))
+      ok=$((ok + 1))
+    else
+      fail=$((fail + 1))
+    fi
+  done
+  if test "$ok" -eq 0; then
+    echo FAIL
+    return 1
+  fi
+  echo $((total / ok))
+  return 0
+}
+
+query_impls_from_libc() {
+  local tmp csrc out
+  tmp=$(mktemp -d) || return 1
+  csrc=$tmp/q.c
+  cat >"$csrc" <<'C'
+#define _GNU_SOURCE
+#include <stdio.h>
+#include <malloc.h>
+int main(void) {
+  char buf[256];
+  if (gnu_get_libc_malloc_impls(buf, sizeof buf) == 0) {
+    fputs(buf, stdout);
+    return 0;
+  }
+  return 1;
+}
+C
+  out=
+  if test -n "$ldso" && test -n "$libc_dir"; then
+    if gcc -O0 -o "$tmp/q" "$csrc" >/dev/null 2>&1; then
+      out=$("$ldso" --library-path "$libc_dir" "$tmp/q" 2>/dev/null) || out=
+    fi
+  else
+    if gcc -O0 -o "$tmp/q" "$csrc" >/dev/null 2>&1; then
+      out=$("$tmp/q" 2>/dev/null) || out=
+    fi
+  fi
+  rm -rf "$tmp"
+  if test -z "$out"; then
+    return 1
+  fi
+  printf '%s\n' "$out"
+}
+
+while test $# -gt 0; do
+  case $1 in
+    --output=*) output_path=${1#*=}; shift ;;
+    --output) test $# -ge 2 || do_usage; output_path=$2; shift 2 ;;
+    --impls=*) impls_list=${1#*=}; shift ;;
+    --impls) test $# -ge 2 || do_usage; impls_list=$2; shift 2 ;;
+    --runs=*) runs=${1#*=}; shift ;;
+    --runs) test $# -ge 2 || do_usage; runs=$2; shift 2 ;;
+    --warmup=*) warmup=${1#*=}; shift ;;
+    --warmup) test $# -ge 2 || do_usage; warmup=$2; shift 2 ;;
+    --margin=*) margin_pct=${1#*=}; shift ;;
+    --margin) test $# -ge 2 || do_usage; margin_pct=$2; shift 2 ;;
+    --libc-dir=*) libc_dir=${1#*=}; shift ;;
+    --libc-dir) test $# -ge 2 || do_usage; libc_dir=$2; shift 2 ;;
+    -'?'|--help) do_help; exit 0 ;;
+    --version) do_version; exit 0 ;;
+    --) shift; break ;;
+    -*) printf >&2 "%s: unrecognized option '%s'\n" glibc-malloc-profile "$1"; do_usage ;;
+    *) break ;;
+  esac
+done
+
+if test -n "$libc_dir"; then
+  if test -x "$libc_dir/ld.so"; then
+    ldso=$libc_dir/ld.so
+  elif test -x "$libc_dir/elf/ld.so"; then
+    ldso=$libc_dir/elf/ld.so
+  elif test -x "$libc_dir/elf/ld-linux-x86-64.so.2"; then
+    ldso=$libc_dir/elf/ld-linux-x86-64.so.2
+  fi
+  # Prepend build-tree dirs; keep system paths so COMMAND's NEEDED libs resolve.
+  libc_dir=$libc_dir:$libc_dir/math:$libc_dir/elf:$libc_dir/dlfcn:$libc_dir/nss:$libc_dir/nis:$libc_dir/rt:$libc_dir/resolv:$libc_dir/mathvec:$libc_dir/support:$libc_dir/misc:$libc_dir/debug:$libc_dir/nptl:${LD_LIBRARY_PATH:-/usr/lib64:/lib64}
+fi
+
+if test $# -eq 0; then
+  printf >&2 "%s: missing command\n" glibc-malloc-profile
+  do_usage
+fi
+
+if is_interactive_cmd "$1"; then
+  printf >&2 "%s: refusing to profile interactive command '%s'\n" \
+    glibc-malloc-profile "$1"
+  exit 0
+fi
+
+# If make did not substitute placeholders (running the .sh from the
+# source tree), probe the live libc.  The string is split so sed that
+# replaces @MALLOC_IMPLS@ does not rewrite this sentinel.
+if test -z "$impls_list" || test "$impls_list" = "@""MALLOC_IMPLS@"; then
+  probed=$(query_impls_from_libc) || probed=
+  if test -n "$probed"; then
+    impls_list=$probed
+  else
+    impls_list=$MALLOC_DEFAULT
+  fi
+fi
+
+impls_list=$(printf '%s' "$impls_list" | tr ',' ' ')
+best_impl=''
+best_ms=999999999
+default_ms=''
+any_ok=0
+
+for impl in $impls_list; do
+  sanitize_token "$impl" >/dev/null || continue
+  ms=$(time_impl "$impl" "$@") || ms=FAIL
+  if test "$ms" = FAIL; then
+    printf '%s: skipped (command failed)\n' "$impl"
+    continue
+  fi
+  any_ok=1
+  printf '%s: %s ms average\n' "$impl" "$ms"
+  if test "$impl" = "$MALLOC_DEFAULT"; then
+    default_ms=$ms
+  fi
+  if test "$ms" -lt "$best_ms" 2>/dev/null; then
+    best_ms=$ms
+    best_impl=$impl
+  fi
+done
+
+if test "$any_ok" -eq 0 || test -z "$best_impl"; then
+  printf >&2 "%s: no successful timings\n" glibc-malloc-profile
+  exit 1
+fi
+
+printf 'winner: %s (%s ms)\n' "$best_impl" "$best_ms"
+
+if test -z "$output_path"; then
+  exit 0
+fi
+
+if test "$best_impl" = "$MALLOC_DEFAULT"; then
+  printf '%s: winner is compile-time default; not writing %s\n' \
+    glibc-malloc-profile "$output_path"
+  exit 0
+fi
+
+if test -n "$default_ms" && test "$default_ms" -gt 0 2>/dev/null; then
+  improve=$(( (default_ms - best_ms) * 100 / default_ms ))
+  if test "$improve" -lt "$margin_pct"; then
+    printf '%s: improvement %s%% < margin %s%%; not writing %s\n' \
+      glibc-malloc-profile "$improve" "$margin_pct" "$output_path"
+    exit 0
+  fi
+fi
+
+base=$(basename -- "$1")
+base=$(sanitize_token "$base") || {
+  printf >&2 "%s: refusing unsafe basename for conf\n" glibc-malloc-profile
+  exit 1
+}
+impl_safe=$(sanitize_token "$best_impl") || exit 1
+mkdir -p "$(dirname -- "$output_path")"
+cat >"$output_path" <<CONF
+priority=50
+match-basename=$base
+impl=$impl_safe
+CONF
+printf 'wrote %s\n' "$output_path"
