+/* Read default= preference list from PATH into BUF.  Returns true if found.  */
+static bool
+read_default_pref (const char *path, char *buf, size_t buflen)
+{
+  int fd;
+  char chunk[512];
+  char line[MALLOC_PREF_LIST_MAX];
+  size_t line_len = 0;
+  bool skip = false;
+  bool found = false;
+  struct stat64 st;
+
+  fd = __open64_nocancel (path, O_RDONLY | O_CLOEXEC | O_NOFOLLOW | O_NONBLOCK);
+  if (fd < 0)
+    return false;
+  if (__fstat64 (fd, &st) != 0 || !S_ISREG (st.st_mode) || st.st_size > 65536)
+    {
+      __close_nocancel_nostatus (fd);
+      return false;
+    }
+  if (__libc_enable_secure
+      && (st.st_uid != 0 || (st.st_mode & (S_IWGRP | S_IWOTH)) != 0))
+    {
+      __close_nocancel_nostatus (fd);
+      return false;
+    }
+  for (;;)
+    {
+      ssize_t n = __read_nocancel (fd, chunk, sizeof chunk);
+      ssize_t i;
+      if (n <= 0)
+	break;
+      for (i = 0; i < n; i++)
+	{
+	  char c = chunk[i];
+	  if (c == '\n')
+	    {
+	      if (!skip && line_len > 0 && line_len < sizeof line)
+		{
+		  char *p, *eq;
+		  line[line_len] = '\0';
+		  p = line;
+		  while (*p == ' ' || *p == '\t')
+		    p++;
+		  if (*p != '\0' && *p != '#')
+		    {
+		      eq = p;
+		      while (*eq && *eq != '=')
+			eq++;
+		      if (*eq == '='
+			  && (eq - p == 7 && memcmp (p, "default", 7) == 0))
+			{
+			  char *v = eq + 1;
+			  size_t vl;
+			  while (*v == ' ' || *v == '\t')
+			    v++;
+			  vl = strlen (v);
+			  while (vl > 0
+				 && (v[vl - 1] == ' ' || v[vl - 1] == '\t'
+				     || v[vl - 1] == '\r'))
+			    vl--;
+			  if (vl > 0 && vl < buflen)
+			    {
+			      memcpy (buf, v, vl);
+			      buf[vl] = '\0';
+			      found = true;
+			    }
+			}
+		    }
+		}
+	      line_len = 0;
+	      skip = false;
+	    }
+	  else if (!skip)
+	    {
+	      if (line_len + 1 >= sizeof line)
+		skip = true;
+	      else
+		line[line_len++] = c;
+	    }
+	}
+    }
+  __close_nocancel_nostatus (fd);
+  return found;
+}
