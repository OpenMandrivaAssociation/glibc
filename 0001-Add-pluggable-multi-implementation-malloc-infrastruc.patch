diff --git a/Makeconfig b/Makeconfig
index 01d02180b9..ee080cdb55 100644
--- a/Makeconfig
+++ b/Makeconfig
@@ -666,8 +666,12 @@ link-extra-libs-static = $(link-extra-libs)
 endif
 
 # The static libraries.
-link-libc-static = -Wl,--start-group $(common-objpfx)libc.a $(static-gnulib) -Wl,--end-group
-link-libc-static-tests = -Wl,--start-group $(common-objpfx)libc.a $(static-gnulib-tests) -Wl,--end-group
+link-libc-static = -Wl,--start-group $(common-objpfx)libc.a $(static-gnulib) $(malloc-static-libs) -Wl,--end-group
+link-libc-static-tests = -Wl,--start-group $(common-objpfx)libc.a $(static-gnulib-tests) $(malloc-static-libs) -Wl,--end-group
+
+# Alternative malloc backends are compiled in-tree; no extra static
+# libraries are required at link time.
+malloc-static-libs =
 
 # How to link against libgcc.  Some libgcc functions, such as those
 # for "long long" arithmetic or software floating point, can always be
@@ -1051,9 +1055,19 @@ endif
 # include files (including ones given in angle brackets) in the parent
 # library source directory, in the include directory, and in the
 # current directory.
-+includes = -I$(..)include $(if $(subdir),$(objpfx:%/=-I%)) \
+# Subdir $(objpfx) must stay before $(..): generated headers such as
+# timezone/version.h (TZVERSION) must win over the top-level version.h.
+# Keep $(..) before $(common-objpfx): the build root contains object-only
+# subdirs (e.g. elf/) and if it precedes the source root GCC can fail
+# `#include <elf/elf.h>` (via include/elf.h) before finding the real
+# header.  Generated headers under $(common-objpfx) (e.g.
+# misc/bits/syscall.h) are still found via the build-root -I below.
++includes = -I$(..)include \
+	    $(if $(subdir),$(objpfx:%/=-I%)) \
 	    $(+sysdep-includes) $(includes) \
-	    $(patsubst %/,-I%,$(..)) $(libio-include) \
+	    $(patsubst %/,-I%,$(..)) \
+	    $(common-objpfx:%/=-I%) \
+	    $(libio-include) \
 	    $(if $($(<F)-no-include-dot),,-I.) $(sysincludes)
 
 # Since libio has several internal header files, we use a -I instead
diff --git a/Makerules b/Makerules
index 30c3559a28..3e9c2a9094 100644
--- a/Makerules
+++ b/Makerules
@@ -603,6 +603,10 @@ build-shlib-objlist = $(build-module-helper-objlist) \
 LDFLAGS-c.so = -nostdlib -nostartfiles
 # But we still want to link libc.so against $(libc.so-gnulib).
 LDLIBS-c.so += $(libc.so-gnulib)
+# Alternative malloc backends are compiled in-tree from sources under
+# malloc/<backend>/.  C++ allocators that need libstdc++ (Mesh,
+# PartitionAlloc) are built as separate preload DSOs only — never linked
+# into libc.so (that would be a libc <-> libstdc++ cycle).
 # Give libc.so an entry point and make it directly runnable itself.
 LDFLAGS-c.so += -e __libc_main
 # Pre-link the objects of libc_pic.a for .gnu.glibc-stub.* processing.
diff --git a/config.make.in b/config.make.in
index fca75ab5d3..61806225e3 100644
--- a/config.make.in
+++ b/config.make.in
@@ -139,4 +139,14 @@ PKGVERSION_TEXI = @PKGVERSION_TEXI@
 REPORT_BUGS_TO = @REPORT_BUGS_TO@
 REPORT_BUGS_TEXI = @REPORT_BUGS_TEXI@
 
+# Malloc implementation selection (glibc, mimalloc, jemalloc, snmalloc,
+# rpmalloc, mallocng, or multi).
+malloc-impl = @malloc_impl@
+malloc-impls = @malloc_impls@
+malloc-default = @malloc_default@
+malloc-embedded = @malloc_embedded@
+malloc-dynamic-impls = @malloc_dynamic_impls@
+malloc-multi = @malloc_multi@
+malloc-preloads = @malloc_preloads@
+
 # More variables may be inserted below by configure.
diff --git a/configure b/configure
index 0cd2269859..b9a9cdabfb 100755
--- a/configure
+++ b/configure
@@ -615,6 +615,13 @@ LIBOBJS
 pthread_in_libc
 RELEASE
 VERSION
+malloc_impl
+malloc_impls
+malloc_default
+malloc_multi
+malloc_preloads
+malloc_dynamic_impls
+malloc_embedded
 mach_interface_list
 DEFINES
 static_nss
@@ -790,6 +797,9 @@ enable_static_c___link_check
 with_gd
 with_gd_include
 with_gd_lib
+with_malloc
+with_default_malloc
+with_malloc_preload
 with_binutils
 with_selinux
 with_headers
@@ -1517,6 +1527,18 @@ Optional Packages:
   --with-gd=DIR           find libgd include dir and library with prefix DIR
   --with-gd-include=DIR   find libgd include files in DIR
   --with-gd-lib=DIR       find libgd library files in DIR
+  --with-malloc=IMPL[,IMPL...]
+                          select malloc implementation(s) embedded in libc:
+                          glibc (default), mimalloc, mimalloc-secure,
+                          jemalloc, snmalloc, rpmalloc, mallocng,
+                          hardened-malloc (64-bit only), and/or phasecast;
+                          comma-separated list enables runtime selection
+  --with-default-malloc=NAME
+                          default malloc implementation when multiple are
+                          built (defaults to the first entry in --with-malloc)
+  --with-malloc-preload=IMPL[,IMPL...]
+                          build LD_PRELOAD DSOs for C++ allocators that cannot
+                          live in libc (mesh, partitionalloc, tcmalloc)
   --with-binutils=PATH    specify location of binutils (as and ld)
   --with-selinux          if building with SELinux support
   --with-headers=PATH     location of system headers to use (for example
@@ -4383,6 +4405,9 @@ fi
 { printf "%s\n" "$as_me:${as_lineno-$LINENO}: result: $libc_cv_cxx_link_ok" >&5
 printf "%s\n" "$libc_cv_cxx_link_ok" >&6; }
 CXX="$saved_CXX"
+# Remember the compile-capable CXX before we potentially clear it; malloc
+# backends only need "$(CXX) -c" and can reuse this even when linking fails.
+libc_cv_cxx_compile_only="$CXX"
 if test $libc_cv_cxx_link_ok != yes
 then :
   CXX=; TEST_CXX=
@@ -4438,6 +4463,292 @@ libgd-LDFLAGS = $libgd_ldflags"
 fi
 
 
+# Keep in sync with configure.ac malloc multi-impl block (autoconf 2.72).
+# Check whether --with-malloc was given.
+if test ${with_malloc+y}
+then :
+  withval=$with_malloc; malloc_impl_arg=$withval
+else case e in #(
+  e) malloc_impl_arg=glibc ;;
+esac
+fi
+
+# Check whether --with-default-malloc was given.
+if test ${with_default_malloc+y}
+then :
+  withval=$with_default_malloc; malloc_default_arg=$withval
+else case e in #(
+  e) malloc_default_arg= ;;
+esac
+fi
+
+malloc_valid_impls="glibc mimalloc mimalloc-secure jemalloc snmalloc rpmalloc mallocng hardened-malloc phasecast"
+malloc_valid_preload="mesh partitionalloc tcmalloc"
+malloc_preload_arg=''
+# Check whether --with-malloc-preload was given.
+if test ${with_malloc_preload+y}
+then :
+  withval=$with_malloc_preload; malloc_preload_arg=$withval
+fi
+malloc_impls=""
+malloc_impl_count=0
+malloc_save_IFS=$IFS
+IFS=,
+for malloc_tok in $malloc_impl_arg; do
+  IFS=$malloc_save_IFS
+  # Trim leading/trailing space and tab.  Avoid [[:space:]]: autoconf m4
+  # treats [ ] as quotes, emitting [:space:] which GNU sed rejects and
+  # yields empty tokens ("--with-malloc must list at least one implementation").
+  malloc_tok=`echo "$malloc_tok" | sed 's/^[ 	]*//;s/[ 	]*$//'`
+  if test -z "$malloc_tok"; then
+    continue
+  fi
+  malloc_tok_ok=no
+  for malloc_v in $malloc_valid_impls; do
+    if test "$malloc_tok" = "$malloc_v"; then
+      malloc_tok_ok=yes
+      break
+    fi
+  done
+  if test "$malloc_tok_ok" != yes; then
+    as_fn_error $? "--with-malloc entry '$malloc_tok' is invalid; valid names: $malloc_valid_impls" "$LINENO" 5
+  fi
+  for malloc_prev in $malloc_impls; do
+    if test "$malloc_prev" = "$malloc_tok"; then
+      as_fn_error $? "--with-malloc lists '$malloc_tok' more than once" "$LINENO" 5
+    fi
+  done
+  if test -z "$malloc_impls"; then
+    malloc_impls=$malloc_tok
+  else
+    malloc_impls="$malloc_impls $malloc_tok"
+  fi
+  malloc_impl_count=`expr $malloc_impl_count + 1`
+done
+IFS=$malloc_save_IFS
+if test $malloc_impl_count -eq 0; then
+  as_fn_error $? "--with-malloc must list at least one implementation" "$LINENO" 5
+fi
+
+if test -n "$malloc_default_arg"; then
+  malloc_default=$malloc_default_arg
+else
+  malloc_default=`echo "$malloc_impls" | sed 's/ .*//'`
+fi
+malloc_default_ok=no
+for malloc_tok in $malloc_impls; do
+  if test "$malloc_tok" = "$malloc_default"; then
+    malloc_default_ok=yes
+    break
+  fi
+done
+if test "$malloc_default_ok" != yes; then
+  as_fn_error $? "--with-default-malloc='$malloc_default' is not in --with-malloc list ($malloc_impls)" "$LINENO" 5
+fi
+
+# Embed only the default; every other configured impl is a dynamic DSO.
+malloc_embedded=$malloc_default
+malloc_dynamic_impls=""
+for malloc_tok in $malloc_impls; do
+  if test "$malloc_tok" != "$malloc_default"; then
+    if test -z "$malloc_dynamic_impls"; then
+      malloc_dynamic_impls=$malloc_tok
+    else
+      malloc_dynamic_impls="$malloc_dynamic_impls $malloc_tok"
+    fi
+  fi
+done
+
+if test -n "$malloc_dynamic_impls"; then
+  malloc_impl=multi
+  malloc_multi=yes
+else
+  malloc_impl=$malloc_embedded
+  malloc_multi=no
+fi
+
+# GrapheneOS hardened_malloc is 64-bit only (static_assert(sizeof(void*)==8),
+# unsigned __int128, large class-region layout).  Drop it on 32-bit; error if
+# it was requested as the embedded default (cannot silently change libc malloc).
+# Compile-time sizeof check (works for cross-compiles; no need to run code).
+{ printf "%s\n" "$as_me:${as_lineno-$LINENO}: checking pointer size for malloc backend selection" >&5
+printf %s "checking pointer size for malloc backend selection... " >&6; }
+cat > conftest.malloc_ptr.c <<'EOF'
+char glibc_malloc_ptr_size_check[(sizeof (void *) == 4) ? 1 : -1];
+EOF
+if ${CC-cc} $CFLAGS $CPPFLAGS -c conftest.malloc_ptr.c -o conftest.malloc_ptr.o > /dev/null 2>&1
+then
+  libc_cv_malloc_ptr_size=4
+else
+  libc_cv_malloc_ptr_size=8
+fi
+rm -f conftest.malloc_ptr.c conftest.malloc_ptr.o
+{ printf "%s\n" "$as_me:${as_lineno-$LINENO}: result: $libc_cv_malloc_ptr_size" >&5
+printf "%s\n" "$libc_cv_malloc_ptr_size" >&6; }
+if test "$libc_cv_malloc_ptr_size" = 4; then
+  malloc_impls_new=""
+  malloc_dropped_hm=no
+  for malloc_tok in $malloc_impls; do
+    if test "$malloc_tok" = "hardened-malloc"; then
+      malloc_dropped_hm=yes
+      continue
+    fi
+    if test -z "$malloc_impls_new"; then
+      malloc_impls_new=$malloc_tok
+    else
+      malloc_impls_new="$malloc_impls_new $malloc_tok"
+    fi
+  done
+  if test "$malloc_dropped_hm" = yes; then
+    if test "$malloc_default" = "hardened-malloc" \
+       || test "$malloc_embedded" = "hardened-malloc"; then
+      as_fn_error $? "hardened-malloc is 64-bit only; cannot use it as the default/embedded malloc on this architecture" "$LINENO" 5
+    fi
+    { printf "%s\n" "$as_me:${as_lineno-$LINENO}: WARNING: hardened-malloc is 64-bit only; omitting it from --with-malloc on this architecture" >&5
+printf "%s\n" "$as_me: WARNING: hardened-malloc is 64-bit only; omitting it from --with-malloc on this architecture" >&2;}
+    malloc_impls=$malloc_impls_new
+    malloc_impl_count=0
+    for malloc_tok in $malloc_impls; do
+      malloc_impl_count=`expr $malloc_impl_count + 1`
+    done
+    if test $malloc_impl_count -eq 0; then
+      as_fn_error $? "no malloc implementations remain after dropping 64-bit-only hardened-malloc" "$LINENO" 5
+    fi
+    malloc_dynamic_impls=""
+    for malloc_tok in $malloc_impls; do
+      if test "$malloc_tok" != "$malloc_default"; then
+        if test -z "$malloc_dynamic_impls"; then
+          malloc_dynamic_impls=$malloc_tok
+        else
+          malloc_dynamic_impls="$malloc_dynamic_impls $malloc_tok"
+        fi
+      fi
+    done
+    if test -n "$malloc_dynamic_impls"; then
+      malloc_impl=multi
+      malloc_multi=yes
+    else
+      malloc_impl=$malloc_embedded
+      malloc_multi=no
+    fi
+  fi
+fi
+
+for malloc_tok in $malloc_impls; do
+  for malloc_v in $malloc_valid_preload; do
+    if test "$malloc_tok" = "$malloc_v"; then
+      as_fn_error $? "--with-malloc=$malloc_tok is not supported inside libc (would require linking libstdc++ into libc). Use --with-malloc-preload=$malloc_tok instead" "$LINENO" 5
+    fi
+  done
+done
+
+malloc_preloads=""
+malloc_save_IFS=$IFS
+IFS=,
+for malloc_tok in $malloc_preload_arg; do
+  IFS=$malloc_save_IFS
+  # Trim leading/trailing space and tab.  Avoid [[:space:]]: autoconf m4
+  # treats [ ] as quotes, emitting [:space:] which GNU sed rejects and
+  # yields empty tokens ("--with-malloc must list at least one implementation").
+  malloc_tok=`echo "$malloc_tok" | sed 's/^[ 	]*//;s/[ 	]*$//'`
+  if test -z "$malloc_tok"; then
+    continue
+  fi
+  malloc_tok_ok=no
+  for malloc_v in $malloc_valid_preload; do
+    if test "$malloc_tok" = "$malloc_v"; then
+      malloc_tok_ok=yes
+      break
+    fi
+  done
+  if test "$malloc_tok_ok" != yes; then
+    as_fn_error $? "--with-malloc-preload entry '$malloc_tok' is invalid; valid names: $malloc_valid_preload" "$LINENO" 5
+  fi
+  for malloc_prev in $malloc_preloads; do
+    if test "$malloc_prev" = "$malloc_tok"; then
+      as_fn_error $? "--with-malloc-preload lists '$malloc_tok' more than once" "$LINENO" 5
+    fi
+  done
+  if test -z "$malloc_preloads"; then
+    malloc_preloads=$malloc_tok
+  else
+    malloc_preloads="$malloc_preloads $malloc_tok"
+  fi
+done
+IFS=$malloc_save_IFS
+
+# snmalloc is C++; the preload-only backends (mesh, partitionalloc, tcmalloc)
+# also need CXX.  The in-tree backends only compile with CXX (never link);
+# preload DSOs link via $(LINK.o) + -lstdc++.  So a compile-only CXX suffices.
+# glibc's earlier check clears CXX when the C++ *link* test fails, but we
+# only need CXX for "$(CXX) $< -c".  Recover it when possible.
+malloc_needs_cxx=no
+for malloc_tok in $malloc_impls; do
+  case $malloc_tok in
+    snmalloc) malloc_needs_cxx=yes ;;
+  esac
+done
+for malloc_tok in $malloc_preloads; do
+  case $malloc_tok in
+    mesh|partitionalloc|tcmalloc) malloc_needs_cxx=yes ;;
+  esac
+done
+if test "$malloc_needs_cxx" = yes && test -z "$CXX"; then
+  # CXX was cleared because the C++ link test failed, but malloc backends
+  # only compile with CXX (never link).  Try to recover a compile-only CXX.
+  # First candidate is the original CXX that configure detected (with all
+  # the user's flags like -m32); fall back to bare compiler names.
+  malloc_cxx_tried=""
+  cat > conftest.cc <<EOF
+int foo() { return 42; }
+EOF
+  for malloc_try_cxx in \
+      ${libc_cv_cxx_compile_only:+"$libc_cv_cxx_compile_only"} \
+      g++ c++ ${host_alias:+${host_alias}-g++}; do
+    { printf "%s\n" "$as_me:${as_lineno-$LINENO}: checking whether $malloc_try_cxx can compile C++ sources" >&5
+printf %s "checking whether $malloc_try_cxx can compile C++ sources... " >&6; }
+    malloc_cxx_cmd="$malloc_try_cxx -c conftest.cc -o conftest.o"
+    malloc_cxx_err=$($malloc_cxx_cmd 2>&1)
+    malloc_cxx_rc=$?
+    if test $malloc_cxx_rc -eq 0; then
+      { printf "%s\n" "$as_me:${as_lineno-$LINENO}: result: yes" >&5
+printf "%s\n" "yes" >&6; }
+      CXX="$malloc_try_cxx"
+      test -z "$TEST_CXX" && TEST_CXX="$malloc_try_cxx"
+      break
+    else
+      { printf "%s\n" "$as_me:${as_lineno-$LINENO}: result: no" >&5
+printf "%s\n" "no" >&6; }
+      printf "%s\n" "malloc CXX probe failed: $malloc_cxx_cmd" >&5
+      printf "%s\n" "exit status: $malloc_cxx_rc" >&5
+      printf "%s\n" "$malloc_cxx_err" >&5
+      malloc_cxx_tried="${malloc_cxx_tried:+$malloc_cxx_tried, }$malloc_try_cxx (exit $malloc_cxx_rc)"
+    fi
+  done
+  rm -f conftest.cc conftest.o
+  if test -z "$CXX"; then
+    as_fn_error $? "selected malloc backend(s) require a C++ compiler but none could compile a trivial source file.
+  Tried: $malloc_cxx_tried
+  See config.log for the exact commands and error messages.
+  Install g++ or clang++ and re-run configure." "$LINENO" 5
+  fi
+fi
+
+config_vars="$config_vars
+malloc-impl = $malloc_impl"
+config_vars="$config_vars
+malloc-impls = $malloc_impls"
+config_vars="$config_vars
+malloc-default = $malloc_default"
+config_vars="$config_vars
+malloc-embedded = $malloc_embedded"
+config_vars="$config_vars
+malloc-dynamic-impls = $malloc_dynamic_impls"
+config_vars="$config_vars
+malloc-multi = $malloc_multi"
+config_vars="$config_vars
+malloc-preloads = $malloc_preloads"
+
 # Check whether --with-binutils was given.
 if test ${with_binutils+y}
 then :
diff --git a/configure.ac b/configure.ac
index 3e4a601c01..cb1acd05ef 100644
--- a/configure.ac
+++ b/configure.ac
@@ -110,6 +110,9 @@ main()
 fi
 AC_LANG_POP([C++])])
 CXX="$saved_CXX"
+# Remember the compile-capable CXX before we potentially clear it; malloc
