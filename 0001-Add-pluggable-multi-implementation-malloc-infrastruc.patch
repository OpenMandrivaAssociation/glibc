+      if (n >= len)
+	return -1;
+      memcpy (buf, __libc_malloc_default_name, n + 1);
+      return 0;
+    }
+  size_t off = 0;
+  buf[0] = '\0';
+  ensure_installed_scanned ();
+  for (size_t i = 0; __libc_malloc_backends[i] != NULL; i++)
+    {
+      const char *n = __libc_malloc_backends[i]->name;
+      size_t nl = strlen (n);
+      if (off && off + 1 < len)
+	buf[off++] = ',';
+      if (off + nl >= len)
+	return -1;
+      memcpy (buf + off, n, nl);
+      off += nl;
+      buf[off] = '\0';
+    }
+  for (int i = 0; i < installed_impls_len; i++)
+    {
+      const char *n = installed_impls[i];
+      size_t nl;
+      bool dup = false;
+      for (size_t j = 0; __libc_malloc_backends[j] != NULL; j++)
+	if (strcmp (__libc_malloc_backends[j]->name, n) == 0)
+	  {
+	    dup = true;
+	    break;
+	  }
+      if (dup)
+	continue;
+      nl = strlen (n);
+      if (off && off + 1 < len)
+	buf[off++] = ',';
+      if (off + nl >= len)
+	return -1;
+      memcpy (buf + off, n, nl);
+      off += nl;
+      buf[off] = '\0';
+    }
+  return 0;
+}
+
+const char *
+gnu_get_libc_malloc_default (void)
+{
+  return __libc_malloc_default_name;
+}
+
+const char *
+gnu_get_libc_malloc_active (void)
+{
+  int st = atomic_load_acquire (&selection_state);
+  if (__libc_enable_secure)
+    return __libc_malloc_default_name;
+  if (st == SEL_DONE_EXTERNAL
+      || atomic_load_acquire (&__libc_malloc_external))
+    return "external";
+  const struct libc_malloc_backend *b = get_active ();
+  return b ? b->name : __libc_malloc_default_name;
+}
