diff --git a/malloc/tst-malloc-dynamic-version.c b/malloc/tst-malloc-dynamic-version.c
new file mode 100644
index 0000000000..cb0baba1b7
--- /dev/null
+++ b/malloc/tst-malloc-dynamic-version.c
@@ -0,0 +1,51 @@
+/* Dynamic malloc DSO exports only GLIBC_PRIVATE backend symbol.
+   Copyright (C) 2026 Free Software Foundation, Inc.
+   This file is part of the GNU C Library.  */
+
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <support/check.h>
+#include <support/support.h>
+#include <support/test-driver.h>
+
+static const char *dso_path;
+
+static void
+init (int argc __attribute__ ((unused)), char **argv __attribute__ ((unused)))
+{
+  dso_path = getenv ("TST_MALLOC_DYNAMIC_DSO");
+}
+
+static int
+do_test (void)
+{
+  char cmd[512];
+  FILE *f;
+  char line[256];
+  int saw_backend = 0;
+  int saw_public_malloc = 0;
+
+  if (dso_path == NULL || *dso_path == '\0')
+    FAIL_UNSUPPORTED ("TST_MALLOC_DYNAMIC_DSO not set");
+
+  snprintf (cmd, sizeof cmd, "nm -D %s", dso_path);
+  f = popen (cmd, "r");
+  if (f == NULL)
+    FAIL_EXIT1 ("popen nm failed");
+  while (fgets (line, sizeof line, f) != NULL)
+    {
+      if (strstr (line, "__libc_malloc_backend_") != NULL)
+	saw_backend = 1;
+      if (strstr (line, " T malloc\n") != NULL
+	  || strstr (line, " T malloc@@") != NULL)
+	saw_public_malloc = 1;
+    }
+  pclose (f);
+  TEST_VERIFY (saw_backend);
+  TEST_VERIFY (!saw_public_malloc);
+  return 0;
+}
+
+#define PREPARE init
+#include <support/test-driver.c>
