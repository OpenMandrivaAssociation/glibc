@@ -0,0 +1,112 @@
+/* Query APIs for single-implementation malloc builds.
+   Copyright (C) 2026 Free Software Foundation, Inc.
+   This file is part of the GNU C Library.
+
+   The GNU C Library is free software; you can redistribute it and/or
+   modify it under the terms of the GNU Lesser General Public License as
+   published by the Free Software Foundation; either version 2.1 of the
+   License, or (at your option) any later version.
+
+   The GNU C Library is distributed in the hope that it will be useful,
+   but WITHOUT ANY WARRANTY; without even the implied warranty of
+   MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the GNU
+   Lesser General Public License for more details.
+
+   You should have received a copy of the GNU Lesser General Public
+   License along with the GNU C Library; see the file COPYING.LIB.  If
+   not, see <https://www.gnu.org/licenses/>.  */
+
+#include <stdbool.h>
+#include <string.h>
+#include <malloc.h>
+#if defined (SHARED) && IS_IN (libc)
+# include <ldsodefs.h>
+# include <dlfcn.h>
+# include <link.h>
+# ifndef RETURN_ADDRESS
+#  define RETURN_ADDRESS(nr) \
+  __builtin_extract_return_addr (__builtin_return_address (nr))
+# endif
+extern void *_dl_sym (void *handle, const char *name, void *who);
+void *__libc_malloc (size_t);
+libc_hidden_proto (__libc_malloc)
+#endif
+
+#ifndef MALLOC_QUERY_IMPL_NAME
+# error MALLOC_QUERY_IMPL_NAME must be defined
+#endif
+
+static const char malloc_query_impl_name[] = MALLOC_QUERY_IMPL_NAME;
+
+static bool
+malloc_is_interposed (void)
+{
+#if defined (SHARED) && IS_IN (libc)
+  void *sym = _dl_sym (RTLD_DEFAULT, "malloc", RETURN_ADDRESS (0));
+  struct link_map *self_map;
+  struct link_map *sym_map;
+  if (sym == NULL || sym == (void *) &__libc_malloc)
+    return false;
+  self_map = _dl_find_dso_for_object ((ElfW (Addr)) &__libc_malloc);
+  sym_map = _dl_find_dso_for_object ((ElfW (Addr)) sym);
+  if (self_map == NULL)
+    return sym_map != NULL;
+  return sym_map != self_map;
+#else
+  return false;
+#endif
+}
+
+int
+gnu_get_libc_malloc_impls (char *buf, size_t len)
+{
+  size_t n;
+  if (buf == NULL || len == 0)
+    return -1;
+  n = strlen (malloc_query_impl_name);
+  if (n >= len)
+    return -1;
+  memcpy (buf, malloc_query_impl_name, n + 1);
+  return 0;
+}
+
+const char *
+gnu_get_libc_malloc_default (void)
+{
+  return malloc_query_impl_name;
+}
+
+const char *
+gnu_get_libc_malloc_active (void)
+{
+  if (malloc_is_interposed ())
+    return "external";
+  return malloc_query_impl_name;
+}
+
+/* No-op fallbacks; overridden by strong defs when phasecast is embedded.  */
+void
+weak_function
+gnu_malloc_phase_push (const char *name __attribute__ ((unused)))
+{
+}
+
+void
+weak_function
+gnu_malloc_phase_pop (void)
+{
+}
+
+int
+weak_function
+gnu_malloc_phase_load_profile (const char *path __attribute__ ((unused)))
+{
+  return -1;
+}
+
+int
+weak_function
+gnu_malloc_phase_save_profile (const char *path __attribute__ ((unused)))
+{
+  return -1;
+}
diff --git a/malloc/malloc-scan.c b/malloc/malloc-scan.c
new file mode 100644
index 0000000000..20d6bb4dd1
--- /dev/null
+++ b/malloc/malloc-scan.c
@@ -0,0 +1,111 @@
+/* Scan installed libglibc_malloc_*.so dynamic backends.
+   Copyright (C) 2026 Free Software Foundation, Inc.
+   This file is part of the GNU C Library.  */
+
+#include <dirent.h>
+#include <errno.h>
+#include <fcntl.h>
+#include <stdbool.h>
+#include <stdio.h>
+#include <string.h>
+#include <sys/stat.h>
+#include <unistd.h>
+#include "malloc-pref.h"
+#include <malloc-backend.h>
+
+#ifndef O_NOFOLLOW
+# define O_NOFOLLOW 0
+#endif
+
+#ifndef MALLOC_IMPL_DIR
+# error MALLOC_IMPL_DIR must be defined
+#endif
+#ifndef MALLOC_IMPL_DIR_BUILD
+# define MALLOC_IMPL_DIR_BUILD ""
+#endif
+
+static bool
+dir_is_trusted (int fd)
+{
+  struct stat st;
+  if (fstat (fd, &st) != 0 || !S_ISDIR (st.st_mode))
+    return false;
+  if (__libc_enable_secure
+      && (st.st_uid != 0 || (st.st_mode & (S_IWGRP | S_IWOTH)) != 0))
+    return false;
+  return true;
+}
+
+static bool
+file_is_trusted (int dirfd, const char *name)
+{
+  struct stat st;
+  if (fstatat (dirfd, name, &st, AT_SYMLINK_NOFOLLOW) != 0)
+    return false;
+  if (!S_ISREG (st.st_mode))
+    return false;
+  if (__libc_enable_secure
+      && (st.st_uid != 0 || (st.st_mode & (S_IWGRP | S_IWOTH)) != 0))
+    return false;
+  return true;
+}
+
+static void
+scan_one_dir (const char *dir, char names[][MALLOC_IMPL_NAME_MAX], int *count,
+	      int max_names)
+{
+  int fd;
+  char dentbuf[2048];
+
+  if (dir == NULL || *dir == '\0')
+    return;
+  fd = open (dir, O_RDONLY | O_DIRECTORY | O_CLOEXEC | O_NOFOLLOW | O_NONBLOCK);
+  if (fd < 0)
+    return;
+  if (!dir_is_trusted (fd))
+    {
+      close (fd);
+      return;
+    }
+  for (;;)
+    {
+      ssize_t nread = __getdents64 (fd, dentbuf, sizeof dentbuf);
+      ssize_t bpos;
+      if (nread <= 0)
+	break;
+      bpos = 0;
+      while (bpos < nread)
+	{
+	  struct dirent64 *d = (struct dirent64 *) (dentbuf + bpos);
+	  char token[MALLOC_IMPL_NAME_MAX];
+	  bpos += d->d_reclen;
+	  if (d->d_name[0] == '.')
+	    continue;
+	  if (!malloc_pref_name_from_soname (d->d_name, token, sizeof token))
+	    continue;
+	  if (!file_is_trusted (fd, d->d_name))
+	    continue;
+	  if (*count < max_names)
+	    malloc_pref_add_installed (names, count, token);
+	}
+    }
+  close (fd);
+}
+
+int
+__libc_malloc_scan_installed (char names[][MALLOC_IMPL_NAME_MAX], int max_names)
+{
+  int count = 0;
+
+  if (names == NULL || max_names <= 0)
+    return 0;
+  if (max_names > MALLOC_IMPL_MAX_INSTALLED)
+    max_names = MALLOC_IMPL_MAX_INSTALLED;
+
+  scan_one_dir (MALLOC_IMPL_DIR, names, &count, max_names);
+  if (MALLOC_IMPL_DIR_BUILD[0] != '\0'
+      && strcmp (MALLOC_IMPL_DIR_BUILD, MALLOC_IMPL_DIR) != 0)
+    scan_one_dir (MALLOC_IMPL_DIR_BUILD, names, &count, max_names);
+  return count;
+}
+libc_hidden_def (__libc_malloc_scan_installed)
diff --git a/malloc/malloc-select.c b/malloc/malloc-select.c
new file mode 100644
index 0000000000..1746b375b7
--- /dev/null
+++ b/malloc/malloc-select.c
@@ -0,0 +1,1713 @@
+#define _GNU_SOURCE 1
+/* Select and dispatch among embedded malloc implementations.
+   Copyright (C) 2026 Free Software Foundation, Inc.
+   This file is part of the GNU C Library.
+
+   The GNU C Library is free software; you can redistribute it and/or
+   modify it under the terms of the GNU Lesser General Public License as
+   published by the Free Software Foundation; either version 2.1 of the
+   License, or (at your option) any later version.
+
+   The GNU C Library is distributed in the hope that it will be useful,
+   but WITHOUT ANY WARRANTY; without even the implied warranty of
+   MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the GNU
+   Lesser General Public License for more details.
+
+   You should have received a copy of the GNU Lesser General Public
+   License along with the GNU C Library; see the file COPYING.LIB.  If
+   not, see <https://www.gnu.org/licenses/>.  */
+
+#include <atomic.h>
+#include <dirent.h>
+#include <errno.h>
+#include <fcntl.h>
+#include <stdbool.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <unistd.h>
+#include <sys/stat.h>
+#include <stdint.h>
+#include <libc-symbols.h>
+#include <shlib-compat.h>
+#include <dso_handle.h>
+#include <register-atfork.h>
+#include <tls.h>
+#include <malloc-internal.h>
+#include <malloc-backend.h>
+#include "malloc-pref.h"
+#if defined (SHARED) && IS_IN (libc)
+# include <ldsodefs.h>
+# include <dlfcn.h>
+# include <link.h>
+# ifndef RETURN_ADDRESS
+#  define RETURN_ADDRESS(nr) \
+  __builtin_extract_return_addr (__builtin_return_address (nr))
+# endif
+/* Implemented in ld.so; does not allocate via libc malloc.  */
+extern void *_dl_sym (void *handle, const char *name, void *who);
+#endif
+
+void *__libc_malloc (size_t);
+libc_hidden_proto (__libc_malloc)
+
+/* Selection state packed with optional external-interposition flag.
+   Waiters may allocate only when state is SEL_DONE or SEL_DONE_EXTERNAL
+   (active is published and init has finished).  */
+enum
+  {
+    SEL_UNSET = 0,
+    SEL_INPROGRESS = 1,
+    SEL_DONE = 2,
+    SEL_DONE_EXTERNAL = 3
+  };
+
+static int selection_state;
+
+/* Thread cookie of the selection owner (THREAD_SELF).  Zero means none.  */
+static void *selection_owner;
+
+/* Backend being initialized by the owner thread only; waiters ignore this.  */
+static const struct libc_malloc_backend *selection_owner_backend;
+
+const struct libc_malloc_backend *__libc_malloc_active attribute_hidden;
+libc_hidden_data_def (__libc_malloc_active)
+
+int __libc_malloc_external attribute_hidden;
+libc_hidden_data_def (__libc_malloc_external)
+
+#if !defined (MALLOC_MULTI_HAS_GLIBC)
+void *__malloc_initialize_hook = NULL;
+void *__free_hook = NULL;
+void *__malloc_hook = NULL;
+void *__realloc_hook = NULL;
+void *__memalign_hook = NULL;
+void *__after_morecore_hook = NULL;
+void *__morecore = NULL;
+
+void *
+__glibc_morecore (ptrdiff_t increment __attribute__ ((unused)))
+{
+  return NULL;
+}
+#if SHLIB_COMPAT (libc, GLIBC_2_0, GLIBC_2_34)
+compat_symbol (libc, __glibc_morecore, __default_morecore, GLIBC_2_0);
+#endif
+#endif /* !MALLOC_MULTI_HAS_GLIBC */
+
+static const struct libc_malloc_backend *
+find_backend (const char *name)
+{
+  if (name == NULL || *name == '\0')
+    return NULL;
+  for (size_t i = 0; __libc_malloc_backends[i] != NULL; i++)
+    if (strcmp (__libc_malloc_backends[i]->name, name) == 0)
+      return __libc_malloc_backends[i];
+  return NULL;
+}
+
+/* Installed dynamic impl tokens discovered under MALLOC_IMPL_DIR.  */
+static char installed_impls[MALLOC_IMPL_MAX_INSTALLED][MALLOC_IMPL_NAME_MAX];
+static int installed_impls_len = -1;
+
+static void
+ensure_installed_scanned (void)
+{
+  if (installed_impls_len >= 0)
+    return;
+#if defined (SHARED) && IS_IN (libc)
+  if (GLRO (dl_malloc_impl_installed_len) > 0)
+    {
+      int n = GLRO (dl_malloc_impl_installed_len);
+      int i;
+      if (n > MALLOC_IMPL_MAX_INSTALLED)
+	n = MALLOC_IMPL_MAX_INSTALLED;
+      for (i = 0; i < n; i++)
+	memcpy (installed_impls[i], GLRO (dl_malloc_impl_installed)[i],
+		MALLOC_IMPL_NAME_MAX);
+      installed_impls_len = n;
+      return;
+    }
+  installed_impls_len
+    = __libc_malloc_scan_installed (installed_impls,
+				    MALLOC_IMPL_MAX_INSTALLED);
+#else
+  installed_impls_len = 0;
+#endif
+}
+
+static bool
+impl_is_available (const char *name)
+{
+  if (name == NULL || *name == '\0')
+    return false;
+  if (find_backend (name) != NULL)
+    return true;
+  ensure_installed_scanned ();
+  return malloc_pref_in_installed (name, installed_impls, installed_impls_len);
+}
+
+int
+__libc_malloc_impl_available (const char *name)
+{
+  return impl_is_available (name);
+}
+
+static const struct libc_malloc_backend *
+default_backend (void)
+{
+  const struct libc_malloc_backend *b
+    = find_backend (__libc_malloc_default_name);
+  if (b != NULL)
+    return b;
+  return __libc_malloc_backends[0];
+}
+
+/* True if the process-global malloc binding is outside this libc.
+   Uses the dynamic linker's non-allocating _dl_sym lookup (not libdl
+   wrappers) and compares link-map identity — no spoofable SONAME prefix.  */
+static bool
+malloc_is_interposed (void)
+{
+#if defined (SHARED) && IS_IN (libc)
+  void *sym;
+  struct link_map *self_map;
+  struct link_map *sym_map;
+  sym = _dl_sym (RTLD_DEFAULT, "malloc", RETURN_ADDRESS (0));
+  if (sym == NULL || sym == (void *) &__libc_malloc)
+    return false;
+  self_map = _dl_find_dso_for_object ((ElfW (Addr)) &__libc_malloc);
+  sym_map = _dl_find_dso_for_object ((ElfW (Addr)) sym);
+  if (self_map == NULL)
+    return sym_map != NULL;
+  return sym_map != self_map;
+#else
+  return false;
+#endif
+}
+
+static bool
+safe_name_char (unsigned char c)
+{
+  return ((c >= 'A' && c <= 'Z')
+	  || (c >= 'a' && c <= 'z')
+	  || (c >= '0' && c <= '9')
+	  || c == '.' || c == '_' || c == '+' || c == '-');
+}
+
+static bool
+valid_conf_token (const char *s)
+{
+  if (s == NULL || *s == '\0')
+    return false;
+  for (const unsigned char *p = (const unsigned char *) s; *p; p++)
+    if (!safe_name_char (*p))
+      return false;
+  return true;
+}
+
+static bool
+valid_conf_filename (const char *name)
+{
+  size_t n = strlen (name);
+  if (n < 6 || strcmp (name + n - 5, ".conf") != 0 || name[0] == '.')
+    return false;
+  for (size_t i = 0; i < n - 5; i++)
+    if (!safe_name_char ((unsigned char) name[i]))
+      return false;
+  return true;
+}
+
+/* True if NEED equals one comma-separated entry in LIST.  Entries are
+   trimmed of surrounding whitespace.  When TOKEN_ONLY, each entry must
+   pass valid_conf_token (basenames); otherwise entries are compared as
+   literal paths (no commas allowed inside an entry).  Empty LIST or an
+   empty/invalid entry yields false and, if invalid_out is non-NULL,
+   sets *invalid_out.  */
+static bool
+list_matches_value (char *list, const char *need, bool token_only,
+		    bool *invalid_out)
+{
+  if (invalid_out != NULL)
+    *invalid_out = false;
+  if (list == NULL || *list == '\0')
+    {
+      if (invalid_out != NULL)
+	*invalid_out = true;
+      return false;
+    }
+  bool any = false;
+  bool matched = false;
+  char *p = list;
+  while (*p)
+    {
+      while (*p == ' ' || *p == '\t')
+	p++;
+      if (*p == '\0')
+	break;
+      char *start = p;
+      while (*p && *p != ',')
+	p++;
+      char *end = p;
+      if (*p == ',')
+	*p++ = '\0';
+      while (end > start && (end[-1] == ' ' || end[-1] == '\t'))
+	*--end = '\0';
+      if (*start == '\0')
+	{
+	  if (invalid_out != NULL)
+	    *invalid_out = true;
+	  return false;
+	}
+      if (token_only)
+	{
+	  if (!valid_conf_token (start))
+	    {
+	      if (invalid_out != NULL)
+		*invalid_out = true;
+	      return false;
+	    }
+	}
+      else
+	{
+	  for (const unsigned char *q = (const unsigned char *) start; *q; q++)
+	    if (*q < 0x20 || *q == 0x7f)
+	      {
+		if (invalid_out != NULL)
+		  *invalid_out = true;
+		return false;
+	      }
+	}
+      any = true;
+      if (need != NULL && *need != '\0' && strcmp (start, need) == 0)
+	matched = true;
+    }
+  if (!any)
+    {
+      if (invalid_out != NULL)
+	*invalid_out = true;
+      return false;
+    }
+  return matched;
+}
+
+static bool
+parse_kv (char *line, char **key, char **val)
+{
+  while (*line == ' ' || *line == '\t')
+    line++;
+  if (*line == '\0' || *line == '#' || *line == '\n')
+    return false;
+  char *eq = strchr (line, '=');
+  if (eq == NULL)
+    return false;
+  *eq = '\0';
+  char *k = line;
+  char *v = eq + 1;
+  while (*k == ' ' || *k == '\t')
+    k++;
+  char *ke = k + strlen (k);
+  while (ke > k && (ke[-1] == ' ' || ke[-1] == '\t' || ke[-1] == '\r'))
+    *--ke = '\0';
+  while (*v == ' ' || *v == '\t')
+    v++;
+  char *ve = v + strlen (v);
+  while (ve > v
+	 && (ve[-1] == ' ' || ve[-1] == '\t' || ve[-1] == '\r' || ve[-1] == '\n'))
+    *--ve = '\0';
+  *key = k;
+  *val = v;
+  return *k != '\0' && *v != '\0';
+}
+
+struct match_result
+{
+  int priority;
+  char impl[32];
+  char source[256];
+  bool set;
+};
+
+/* Selection tiers (effective priority, higher wins).  In-file priority=
+   only orders within a drop-in tier and is clamped to [0, 99] so a
+   distro snippet cannot outrank $(sysconfdir)/glibc/malloc.conf.
+
+     1000       GLIBC_MALLOC_IMPL
+      800       $(sysconfdir)/glibc/malloc.conf per-basename lines
+      600..699  $(sysconfdir)/glibc/malloc.d/<name>.conf  (admin / local)
+      500       $(sysconfdir)/glibc/malloc.conf default= (overrides distro)
+      400..499  $(datadir)/glibc/malloc.d/<name>.conf (distro-provided)
+      <0        heuristics / compile-time default (fallthrough)  */
+enum
+  {
+    PRIO_ENV = 1000,
+    PRIO_ETC_CONF_BASENAME = 800,
+    PRIO_ETC_MALLOCD_BASE = 600,
+    PRIO_ETC_CONF_DEFAULT = 500,
+    PRIO_DATA_MALLOCD_BASE = 400,
+    PRIO_IN_TIER_MAX = 99,
+    PRIO_DROPIN_DEFAULT = 50
+  };
+
+static int
+clamp_in_tier_priority (int p)
+{
+  if (p < 0)
+    return 0;
+  if (p > PRIO_IN_TIER_MAX)
+    return PRIO_IN_TIER_MAX;
+  return p;
+}
+
+static int
+dropin_effective_priority (int tier_base, int file_priority)
+{
+  return tier_base + clamp_in_tier_priority (file_priority);
+}
+
+/* True if PREF is a single token or a comma-separated preference list
+   (tokens and optional '*').  */
+static bool
+valid_pref_list (const char *pref)
+{
+  bool any = false;
+  bool seen_star = false;
+  if (pref == NULL || *pref == '\0')
+    return false;
+  const char *p = pref;
+  while (*p)
+    {
+      while (*p == ' ' || *p == '\t')
+	p++;
+      if (*p == '\0')
+	break;
+      const char *start = p;
+      while (*p && *p != ',')
+	p++;
+      const char *end = p;
+      if (*p == ',')
+	p++;
+      while (end > start && (end[-1] == ' ' || end[-1] == '\t'))
+	end--;
+      if (end == start)
+	return false;
+      if (end == start + 1 && *start == '*')
+	{
+	  if (seen_star)
+	    return false;
+	  seen_star = true;
+	}
+      else
+	{
+	  for (const char *q = start; q < end; q++)
+	    if (!safe_name_char ((unsigned char) *q))
+	      return false;
+	}
+      any = true;
+    }
+  return any;
+}
+
+/* Higher priority wins.  Equal priority: lexicographically smaller
+   source path wins for stable ordering independent of directory order.
+   IMPL_OR_LIST may be a single name or a comma-separated preference
+   list (see malloc-pref.h); unavailable names are skipped.  */
+static void
+consider (struct match_result *best, int prio, const char *impl_or_list,
+	  const char *source)
+{
+  int cmp;
+  char buf[MALLOC_PREF_LIST_MAX];
+  char resolved[MALLOC_IMPL_NAME_MAX];
+  size_t len;
+
+  if (impl_or_list == NULL || *impl_or_list == '\0' || !valid_pref_list (impl_or_list))
+    return;
+  len = strlen (impl_or_list);
+  if (len >= sizeof buf)
+    return;
+  memcpy (buf, impl_or_list, len + 1);
+  ensure_installed_scanned ();
+  if (!malloc_pref_resolve (buf, __libc_malloc_default_name,
+			    installed_impls, installed_impls_len,
+			    resolved, sizeof resolved))
+    return;
+  /* Only accept embedded backends here for publish; dynamic picks are
+     honored when ld.so already mapped the DSO (GLRO).  v1: if resolved
+     name is not embedded, skip unless it equals an installed dynamic
+     that the loader pre-selected.  */
+  if (find_backend (resolved) == NULL)
+    {
+#if defined (SHARED) && IS_IN (libc)
+      if (!malloc_pref_in_installed (resolved, installed_impls,
+				     installed_impls_len))
+	return;
+      /* Dynamic name from conf/env without loader pre-map: ignore in v1.  */
+      if (GLRO (dl_malloc_impl_pick) == NULL
+	  || strcmp (GLRO (dl_malloc_impl_pick), resolved) != 0)
+	return;
+#else
+      return;
+#endif
+    }
+  if (source == NULL)
+    source = "";
+  if (!best->set)
+    {
+      best->set = true;
+      best->priority = prio;
+      strncpy (best->impl, resolved, sizeof best->impl - 1);
+      best->impl[sizeof best->impl - 1] = '\0';
+      strncpy (best->source, source, sizeof best->source - 1);
+      best->source[sizeof best->source - 1] = '\0';
+      return;
+    }
+  if (prio > best->priority)
+    cmp = 1;
+  else if (prio < best->priority)
+    cmp = -1;
+  else
+    cmp = strcmp (source, best->source) < 0 ? 1 : -1;
+  if (cmp > 0)
+    {
+      best->priority = prio;
+      strncpy (best->impl, resolved, sizeof best->impl - 1);
+      best->impl[sizeof best->impl - 1] = '\0';
+      strncpy (best->source, source, sizeof best->source - 1);
+      best->source[sizeof best->source - 1] = '\0';
+    }
+}
+
+static void
+basename_of (const char *path, char *out, size_t outlen)
+{
+  const char *b = strrchr (path, '/');
+  size_t len;
+  b = b ? b + 1 : path;
+  len = strlen (b);
+  if (len >= outlen)
+    len = outlen - 1;
+  memcpy (out, b, len);
+  out[len] = '\0';
+}
+
+static bool
+read_exe_path (char *buf, size_t len)
+{
+  ssize_t n = readlink ("/proc/self/exe", buf, len - 1);
+  /* Reject truncated results (mirror elf/dl-tunables.c).  */
+  if (n <= 0 || n >= (ssize_t) (len - 1))
+    return false;
+  buf[n] = '\0';
+  return true;
+}
+
+static bool
+open_trusted_conf (const char *path, int *fd_out, struct stat *st_out)
+{
+  int fd = open (path, O_RDONLY | O_CLOEXEC | O_NOFOLLOW | O_NONBLOCK);
+  if (fd < 0)
+    return false;
+  struct stat st;
+  if (fstat (fd, &st) != 0 || !S_ISREG (st.st_mode) || st.st_size > 65536)
+    {
+      close (fd);
+      return false;
+    }
+  if (__libc_enable_secure)
+    {
+      if (st.st_uid != 0
+	  || (st.st_mode & (S_IWGRP | S_IWOTH)) != 0)
+	{
+	  close (fd);
+	  return false;
+	}
+    }
+  *fd_out = fd;
+  if (st_out)
+    *st_out = st;
+  return true;
+}
+
+struct dropin_parse_state
+{
+  int priority;
+  char impl[32];
+  bool match;
+  bool have_match_rule;
+  bool seen_priority;
+  bool seen_impl;
+  bool invalid;
+  const char *exe_path;
+  const char *exe_base;
+};
+
+/* Returns false if the drop-in must be discarded (duplicate/invalid keys).  */
+static bool
+dropin_parse_line (struct dropin_parse_state *st, char *line)
+{
+  char *k, *v;
+  char tmp[512];
+  size_t len = strlen (line);
+  if (len >= sizeof tmp)
+    {
+      st->invalid = true;
+      return false;
+    }
+  memcpy (tmp, line, len + 1);
+  if (!parse_kv (tmp, &k, &v))
+    return true;
+  if (strcmp (k, "priority") == 0)
+    {
+      if (st->seen_priority)
+	{
+	  st->invalid = true;
+	  return false;
+	}
+      st->seen_priority = true;
+      st->priority = atoi (v);
+    }
+  else if (strcmp (k, "impl") == 0)
+    {
+      if (st->seen_impl || !valid_pref_list (v))
+	{
+	  st->invalid = true;
+	  return false;
+	}
+      st->seen_impl = true;
+      strncpy (st->impl, v, sizeof st->impl - 1);
+      st->impl[sizeof st->impl - 1] = '\0';
+    }
+  else if (strcmp (k, "match-basename") == 0)
+    {
+      bool bad = false;
+      st->have_match_rule = true;
+      if (list_matches_value (v, st->exe_base, true, &bad))
+	st->match = true;
+      else if (bad)
+	{
+	  st->invalid = true;
+	  return false;
+	}
+    }
+  else if (strcmp (k, "match-path") == 0)
+    {
+      bool bad = false;
+      st->have_match_rule = true;
+      if (list_matches_value (v, st->exe_path, false, &bad))
+	st->match = true;
+      else if (bad)
+	{
+	  st->invalid = true;
+	  return false;
+	}
+    }
+  return true;
+}
+
+static void
+scan_dropin_file (const char *path, const char *exe_path, const char *exe_base,
+		  int tier_base, struct match_result *best)
+{
+  int fd;
+  struct stat stbuf;
+  if (!open_trusted_conf (path, &fd, &stbuf))
+    return;
+
+  struct dropin_parse_state st;
+  memset (&st, 0, sizeof st);
+  st.priority = PRIO_DROPIN_DEFAULT;
+  st.exe_path = exe_path;
+  st.exe_base = exe_base;
+  char chunk[512];
+  char line[512];
+  size_t line_len = 0;
+  bool skip_line = false;
+
+  for (;;)
+    {
+      ssize_t n = read (fd, chunk, sizeof chunk);
+      if (n < 0)
+	{
+	  close (fd);
+	  return;
+	}
+      if (n == 0)
+	break;
+      for (ssize_t i = 0; i < n; i++)
+	{
+	  char c = chunk[i];
+	  if (c == '\n')
+	    {
+	      if (!skip_line && line_len < sizeof line)
+		{
+		  line[line_len] = '\0';
+		  if (!dropin_parse_line (&st, line))
+		    {
+		      close (fd);
+		      return;
+		    }
+		}
+	      line_len = 0;
+	      skip_line = false;
+	    }
+	  else if (!skip_line)
+	    {
+	      if (line_len + 1 >= sizeof line)
+		skip_line = true;
+	      else
+		line[line_len++] = c;
+	    }
+	}
+    }
+  close (fd);
+
+  if (line_len > 0 && !skip_line)
+    {
+      line[line_len] = '\0';
+      if (!dropin_parse_line (&st, line))
+	return;
+    }
+  if (st.invalid)
+    return;
+
+  if (!st.have_match_rule)
+    st.match = true;
+  if (st.match && st.impl[0] != '\0')
+    consider (best, dropin_effective_priority (tier_base, st.priority),
+	      st.impl, path);
+}
+
+
+static void
+scan_dropin_dir (const char *dir, const char *exe_path, const char *exe_base,
+		 int tier_base, struct match_result *best)
+{
+  int fd = open (dir, O_RDONLY | O_DIRECTORY | O_CLOEXEC | O_NOFOLLOW | O_NONBLOCK);
+  if (fd < 0)
+    return;
+  if (__libc_enable_secure)
+    {
+      struct stat st;
+      if (fstat (fd, &st) != 0 || st.st_uid != 0
+	  || (st.st_mode & (S_IWGRP | S_IWOTH)) != 0)
+	{
+	  close (fd);
+	  return;
+	}
+    }
+  char dentbuf[2048];
+  for (;;)
+    {
+      ssize_t nread = __getdents64 (fd, dentbuf, sizeof dentbuf);
+      if (nread <= 0)
+	break;
+      ssize_t bpos = 0;
+      while (bpos < nread)
+	{
+	  struct dirent64 *d = (struct dirent64 *) (dentbuf + bpos);
+	  bpos += d->d_reclen;
+	  if (!valid_conf_filename (d->d_name))
+	    continue;
+	  char path[384];
+	  int m = snprintf (path, sizeof path, "%s/%s", dir, d->d_name);
+	  if (m < 0 || m >= (int) sizeof path)
+	    continue;
+	  scan_dropin_file (path, exe_path, exe_base, tier_base, best);
+	}
+    }
+  close (fd);
+}
+
+static void
+scan_global_conf (const char *path, const char *exe_base,
+		  struct match_result *best)
+{
+  int fd;
+  if (!open_trusted_conf (path, &fd, NULL))
+    return;
+  char chunk[512];
+  char line[512];
+  size_t line_len = 0;
+  bool skip_line = false;
+  for (;;)
+    {
+      ssize_t n = read (fd, chunk, sizeof chunk);
+      if (n <= 0)
+	break;
+      for (ssize_t i = 0; i < n; i++)
+	{
+	  char c = chunk[i];
+	  if (c == '\n')
+	    {
+	      if (!skip_line && line_len < sizeof line)
+		{
+		  line[line_len] = '\0';
+		  char *k, *v;
+		  char tmp[512];
+		  memcpy (tmp, line, line_len + 1);
+		  if (parse_kv (tmp, &k, &v) && valid_pref_list (v))
+		    {
+		      if (strcmp (k, "default") == 0)
+			consider (best, PRIO_ETC_CONF_DEFAULT, v, path);
+		      else if (exe_base != NULL)
+			{
+			  bool bad = false;
+			  if (list_matches_value (k, exe_base, true, &bad)
+			      && !bad)
+			    consider (best, PRIO_ETC_CONF_BASENAME, v,
+				      path);
+			}
+		    }
+		}
+	      line_len = 0;
+	      skip_line = false;
+	    }
+	  else if (!skip_line)
+	    {
+	      if (line_len + 1 >= sizeof line)
+		skip_line = true;
+	      else
+		line[line_len++] = c;
+	    }
+	}
+    }
+  close (fd);
+}
+
+static const char *
+early_getenv (const char *name, char *out, size_t outlen)
+{
+  if (__libc_enable_secure || name == NULL || out == NULL || outlen == 0)
+    return NULL;
+  size_t nlen = strlen (name);
+  char **ep = __environ;
+  if (ep != NULL)
+    {
+      for (; *ep != NULL; ep++)
+	if (strncmp (*ep, name, nlen) == 0 && (*ep)[nlen] == '=')
+	  {
+	    size_t vlen = strlen (*ep + nlen + 1);
+	    if (vlen >= outlen)
+	      vlen = outlen - 1;
+	    memcpy (out, *ep + nlen + 1, vlen);
+	    out[vlen] = '\0';
+	    return out;
+	  }
+    }
+  /* Loop over /proc/self/environ in 512-byte windows with carry for
+     records spanning reads.  */
+  int fd = open ("/proc/self/environ", O_RDONLY | O_CLOEXEC | O_NONBLOCK);
+  if (fd < 0)
+    return NULL;
+  char carry[256];
+  size_t carry_len = 0;
+  char buf[512];
+  for (;;)
+    {
+      ssize_t n = read (fd, buf, sizeof buf);
+      if (n <= 0)
+	break;
+      size_t pos = 0;
+      while (pos < (size_t) n)
+	{
+	  size_t start = pos;
+	  while (pos < (size_t) n && buf[pos] != '\0')
+	    pos++;
+	  if (pos >= (size_t) n)
+	    {
+	      size_t chunk = (size_t) n - start;
+	      if (carry_len + chunk >= sizeof carry)
+		carry_len = 0;
+	      else
+		{
+		  memcpy (carry + carry_len, buf + start, chunk);
+		  carry_len += chunk;
+		}
+	      break;
+	    }
+	  char rec[512];
+	  size_t rec_len = 0;
+	  if (carry_len)
+	    {
+	      if (carry_len >= sizeof rec)
+		carry_len = 0;
+	      else
+		{
+		  memcpy (rec, carry, carry_len);
+		  rec_len = carry_len;
+		  carry_len = 0;
+		}
+	    }
+	  size_t chunk = pos - start;
+	  if (rec_len + chunk >= sizeof rec)
+	    {
+	      pos++;
+	      continue;
+	    }
+	  memcpy (rec + rec_len, buf + start, chunk);
+	  rec_len += chunk;
+	  rec[rec_len] = '\0';
+	  if (strncmp (rec, name, nlen) == 0 && rec[nlen] == '=')
+	    {
+	      size_t vlen = strlen (rec + nlen + 1);
+	      if (vlen >= outlen)
+		vlen = outlen - 1;
+	      memcpy (out, rec + nlen + 1, vlen);
+	      out[vlen] = '\0';
+	      close (fd);
+	      return out;
+	    }
+	  pos++;
+	}
+    }
+  if (carry_len > 0)
+    {
+      carry[carry_len] = '\0';
+      if (strncmp (carry, name, nlen) == 0 && carry[nlen] == '=')
+	{
+	  size_t vlen = strlen (carry + nlen + 1);
+	  if (vlen >= outlen)
+	    vlen = outlen - 1;
+	  memcpy (out, carry + nlen + 1, vlen);
+	  out[vlen] = '\0';
+	  close (fd);
+	  return out;
+	}
+    }
+  close (fd);
+  return NULL;
+}
