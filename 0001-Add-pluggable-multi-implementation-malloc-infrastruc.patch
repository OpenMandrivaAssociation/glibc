+  if (st == SEL_UNSET
+      && atomic_compare_and_exchange_bool_acq (&selection_state,
+					       SEL_INPROGRESS, SEL_UNSET) == 0)
+    {
+      atomic_store_release (&selection_owner, selection_thread_cookie ());
+      select_backend_owner ();
+      return atomic_load_acquire (&__libc_malloc_active);
+    }
+
+  for (;;)
+    {
+      st = atomic_load_acquire (&selection_state);
+      if (selection_ready (st))
+	{
+	  const struct libc_malloc_backend *b
+	    = atomic_load_acquire (&__libc_malloc_active);
+	  if (b != NULL)
+	    return b;
+	}
+      atomic_spin_nop ();
+    }
