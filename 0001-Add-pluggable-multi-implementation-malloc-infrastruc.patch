+# define MALLOC_IMPL_DIR "/usr/lib/glibc/malloc"
+#endif
+#ifndef MALLOC_IMPL_DIR_BUILD
+# define MALLOC_IMPL_DIR_BUILD ""
+#endif
+#ifndef MALLOC_DEFAULT_NAME
+# define MALLOC_DEFAULT_NAME "glibc"
+#endif
+/* From configure via elf/Makefile CPPFLAGS-dl-malloc-impl.c.  */
+#ifndef SYSCONFDIR
+# define SYSCONFDIR "/etc"
+#endif
+#ifndef DATADIR
+# define DATADIR "/usr/share"
+#endif
+#define MALLOC_SYSCONF_CONF	SYSCONFDIR "/glibc/malloc.conf"
+#define MALLOC_SYSCONF_DROPIN	SYSCONFDIR "/glibc/malloc.d"
+#define MALLOC_DATA_DROPIN	DATADIR "/glibc/malloc.d"
+
+static char pick_storage[MALLOC_IMPL_NAME_MAX];
+static char conf_pref_storage[MALLOC_PREF_LIST_MAX];
+
+static bool
+secure_fd_ok (int fd, bool dir)
+{
+  struct stat64 st;
+  if (__fstat64 (fd, &st) != 0)
+    return false;
+  if (dir ? !S_ISDIR (st.st_mode) : !S_ISREG (st.st_mode))
+    return false;
+  if (__libc_enable_secure
+      && (st.st_uid != 0 || (st.st_mode & (S_IWGRP | S_IWOTH)) != 0))
+    return false;
+  return true;
+}
+
+static void
+scan_dir (const char *dir, int *count)
+{
+  int fd;
+  char dentbuf[2048];
+
+  if (dir == NULL || *dir == '\0')
+    return;
+  fd = __open64_nocancel (dir,
+			  O_RDONLY | O_DIRECTORY | O_CLOEXEC | O_NOFOLLOW);
+  if (fd < 0)
+    return;
+  if (!secure_fd_ok (fd, true))
+    {
+      __close_nocancel_nostatus (fd);
+      return;
+    }
+  for (;;)
+    {
+      ssize_t nread = __getdents64 (fd, dentbuf, sizeof dentbuf);
+      ssize_t bpos = 0;
+      if (nread <= 0)
+	break;
+      while (bpos < nread)
+	{
+	  struct dirent64 *d = (struct dirent64 *) (dentbuf + bpos);
+	  char token[MALLOC_IMPL_NAME_MAX];
+	  struct stat64 st;
+	  bpos += d->d_reclen;
+	  if (d->d_name[0] == '.')
+	    continue;
+	  if (!malloc_pref_name_from_soname (d->d_name, token, sizeof token))
+	    continue;
+	  if (__fstatat64 (fd, d->d_name, &st, AT_SYMLINK_NOFOLLOW) != 0
+	      || !S_ISREG (st.st_mode))
+	    continue;
+	  if (__libc_enable_secure
+	      && (st.st_uid != 0 || (st.st_mode & (S_IWGRP | S_IWOTH)) != 0))
+	    continue;
+	  malloc_pref_add_installed (GLRO (dl_malloc_impl_installed), count,
+				     token);
+	}
+    }
+  __close_nocancel_nostatus (fd);
+}
+
+/* Directory scan is relatively expensive (open + getdents + fstatat per
+   candidate) and runs in every process.  Defer until a preference list
+   actually needs to resolve against installed dynamic backends.  When no
+   GLIBC_MALLOC_IMPL / conf default applies, the scan is skipped entirely;
+   libc's malloc-select re-scans later if a query API needs the list.  */
+static bool installed_scanned;
+
+static void
+scan_installed (void)
+{
+  int count = 0;
+  if (installed_scanned)
+    return;
+  installed_scanned = true;
+  GLRO (dl_malloc_impl_installed_len) = 0;
+  scan_dir (GLRO (dl_malloc_impl_dir), &count);
+  if (MALLOC_IMPL_DIR_BUILD[0] != '\0'
+      && strcmp (MALLOC_IMPL_DIR_BUILD, GLRO (dl_malloc_impl_dir)) != 0)
+    scan_dir (MALLOC_IMPL_DIR_BUILD, &count);
+  GLRO (dl_malloc_impl_installed_len) = count;
+}
