+dnl Select malloc implementation(s).  A single name embeds that impl in
+dnl libc (zero-overhead).  A comma-separated list embeds only the default
+dnl (see --with-default-malloc) and builds the others as
+dnl $slibdir/glibc/malloc/libglibc_malloc_<name>.so, discovered at runtime.
+dnl NOTE: keep the matching block in `configure` in sync when editing.
+AC_ARG_WITH([malloc],
+	    AS_HELP_STRING([--with-malloc=IMPL[,IMPL...]],
+			   [select malloc implementation(s): glibc (default), mimalloc, mimalloc-secure, jemalloc, snmalloc, rpmalloc, mallocng, hardened-malloc (64-bit only), and/or phasecast; first/default is embedded in libc, any further names are dynamic DSOs]),
+	    [malloc_impl_arg=$withval],
+	    [malloc_impl_arg=glibc])
+AC_ARG_WITH([default-malloc],
+	    AS_HELP_STRING([--with-default-malloc=NAME],
+			   [impl embedded in libc and used when no dynamic DSO is selected (defaults to the first entry in --with-malloc)]),
+	    [malloc_default_arg=$withval],
+	    [malloc_default_arg=])
+AC_ARG_WITH([malloc-preload],
+	    AS_HELP_STRING([--with-malloc-preload=IMPL[,IMPL...]],
+			   [build interposing LD_PRELOAD DSOs for C++ allocators (mesh, partitionalloc, tcmalloc)]),
+	    [malloc_preload_arg=$withval],
+	    [malloc_preload_arg=])
+
+malloc_valid_impls="glibc mimalloc mimalloc-secure jemalloc snmalloc rpmalloc mallocng hardened-malloc phasecast"
+malloc_valid_preload="mesh partitionalloc tcmalloc"
+malloc_impls=""
+malloc_impl_count=0
+malloc_save_IFS=$IFS
+IFS=,
+for malloc_tok in $malloc_impl_arg; do
+  IFS=$malloc_save_IFS
+  # Trim leading/trailing space and tab.  Avoid [[:space:]]: autoconf m4
+  # treats [ ] as quotes, emitting [:space:] which GNU sed rejects and
+  # yields empty tokens ("--with-malloc must list at least one implementation").
+  malloc_tok=`echo "$malloc_tok" | sed 's/^[ 	]*//;s/[ 	]*$//'`
+  if test -z "$malloc_tok"; then
+    continue
+  fi
+  malloc_tok_ok=no
+  for malloc_v in $malloc_valid_impls; do
+    if test "$malloc_tok" = "$malloc_v"; then
+      malloc_tok_ok=yes
+      break
+    fi
+  done
+  if test "$malloc_tok_ok" != yes; then
+    AC_MSG_ERROR([--with-malloc entry '$malloc_tok' is invalid; valid names: $malloc_valid_impls])
+  fi
+  for malloc_prev in $malloc_impls; do
+    if test "$malloc_prev" = "$malloc_tok"; then
+      AC_MSG_ERROR([--with-malloc lists '$malloc_tok' more than once])
+    fi
+  done
+  if test -z "$malloc_impls"; then
+    malloc_impls=$malloc_tok
+  else
+    malloc_impls="$malloc_impls $malloc_tok"
+  fi
+  malloc_impl_count=`expr $malloc_impl_count + 1`
+done
+IFS=$malloc_save_IFS
+if test $malloc_impl_count -eq 0; then
+  AC_MSG_ERROR([--with-malloc must list at least one implementation])
+fi
+
+if test -n "$malloc_default_arg"; then
+  malloc_default=$malloc_default_arg
+else
+  malloc_default=`echo "$malloc_impls" | sed 's/ .*//'`
+fi
+malloc_default_ok=no
+for malloc_tok in $malloc_impls; do
+  if test "$malloc_tok" = "$malloc_default"; then
+    malloc_default_ok=yes
+    break
+  fi
+done
+if test "$malloc_default_ok" != yes; then
+  AC_MSG_ERROR([--with-default-malloc='$malloc_default' is not in --with-malloc list ($malloc_impls)])
+fi
+
+# Embed only the default; every other configured impl is a dynamic DSO.
+malloc_embedded=$malloc_default
+malloc_dynamic_impls=""
+for malloc_tok in $malloc_impls; do
+  if test "$malloc_tok" != "$malloc_default"; then
+    if test -z "$malloc_dynamic_impls"; then
+      malloc_dynamic_impls=$malloc_tok
+    else
+      malloc_dynamic_impls="$malloc_dynamic_impls $malloc_tok"
+    fi
+  fi
+done
+
+if test -n "$malloc_dynamic_impls"; then
+  malloc_impl=multi
+  malloc_multi=yes
+else
+  malloc_impl=$malloc_embedded
+  malloc_multi=no
+fi
